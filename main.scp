                        <__p_description>Initializes a new GLSL parser with the given root program block.</__p_description>
                        <__p_static>0</__p_static>
                        <__p_abstract>0</__p_abstract>
                        <Object>
                            <__p_name>root</__p_name>
                            <__p_description>socref_glsl.program.Program
The root block of a GLSL project that this new parser will parse.</__p_description>
                        </Object>
