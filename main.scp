                <Package>
                    <__p_name>Model</__p_name>
                    <__p_description>Contains all model classes and singleton model instances.</__p_description>
                    <Package>
                        <__p_name>Abstract</__p_name>
                        <__p_description>Contains all abstract interface classes.</__p_description>
                        <Class>
                            <__p_name>AbstractCommand</__p_name>
                            <__p_description>This is the abstract command class. A command is an action interface designed to redo or undo a single action upon a project model. Because qt model indexes can become invalid when the model changes, the list of rows for each command must be saved. These rows are converted back to a valid index upon execution of the undo or redo action. Helper methods for converting between a Qt model index and a list of rows are provided to facilitate these requirements. The rows in the list start from the root down one level into the model tree for each row. An empty list represents the root index.</__p_description>
                            <__p_parents>ABC</__p_parents>
                            <__p_infile>0</__p_infile>
                            <Function>
                                <__p_name>__init__</__p_name>
                                <__p_description>Initialize a new command with the given project model.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
                                <Object>
                                    <__p_name>model</__p_name>
                                    <__p_description>socref.model.ProjectModel
The project model that this new command acts upon.</__p_description>
                                </Object>
                            </Function>
                            <Function>
                                <__p_name>redo</__p_name>
                                <__p_description>This interface acts on this command's project model to redo its command.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>1</__p_abstract>
                            </Function>
                            <Function>
                                <__p_name>undo</__p_name>
                                <__p_description>This interface acts on this command's project model to undo its command.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>1</__p_abstract>
                            </Function>
                            <Function>
