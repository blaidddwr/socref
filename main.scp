                                <__p_description>Sets this dock's project view to the one given. If this dock currently has a view it is disconnected from this dock.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
