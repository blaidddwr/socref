The input file that is scanned.</__p_description>
                        </Object>
                        <Object>
                            <__p_name>indent</__p_name>
                            <__p_description>The indent size for the block of code scanned or none to automatically determine it with the indent of the first line of code scanned. The default is none.</__p_description>
                            <__p_assignment>None</__p_assignment>
                        </Object>
                    </Function>
