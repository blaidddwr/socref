                        </Class>
                        <Class>
                            <__p_name>SpellChecker</__p_name>
                            <__p_description>This is the spell checker class. It provides a spell checking and correction interface using the Hunspell library. It begins spell checking with its start slot, providing it a qt text cursor that is used to parse the entire document of the text cursor, checking for misspelled words. Each misspelled word is highlighted and waits on the user to correct. The user is given options to use a suggestion, replace, ignore, stop, or add to dictionary. The cursor is updated to highlight each misspelled word found while waiting for the user to make a choice about it. Adding to dictionary is currently defunct but will be fixed.</__p_description>
                            <__p_parents>QGroupBox</__p_parents>
                            <__p_infile>0</__p_infile>
                            <Object>
                                <__p_name>cursorChanged</__p_name>
                                <__p_description>Signals this spell checker has changed the cursor given to it.</__p_description>
                                <__p_assignment>Signal(QTextCursor)</__p_assignment>
                            </Object>
                            <Object>
                                <__p_name>finished</__p_name>
                                <__p_description>Signals this spell checker has finished checking and correcting for misspelled words.</__p_description>
                                <__p_assignment>Signal()</__p_assignment>
                            </Object>
                            <Function>
                                <__p_name>__init__</__p_name>
                                <__p_description>Initializes a new speller checker with the given title, dictionary, and optional parent.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
                                <Object>
                                    <__p_name>title</__p_name>
                                    <__p_description>string
The title of this new spell checker's qt group box.</__p_description>
                                </Object>
                                <Object>
                                    <__p_name>dictionary</__p_name>
                                    <__p_description>string
The Hunspell dictionary used for spell checking. This does not include the directory or file extensions, for example &quot;en_US&quot;.</__p_description>
                                </Object>
                                <Object>
                                    <__p_name>parent</__p_name>
                                    <__p_description>object
An optional qt object parent for this new spell checker.</__p_description>
                                    <__p_assignment>None</__p_assignment>
                                </Object>
                            </Function>
                            <Function>
                                <__p_name>start</__p_name>
                                <__p_description>Called to have this spell checker begin checking for misspelled words in the document of the given qt text cursor. The entire document is checked for misspelled words. If this spell checker is already checking a document then this does nothing.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
                                <__p_decorators>Slot(QTextCursor)</__p_decorators>
                                <Object>
                                    <__p_name>cursor</__p_name>
                                    <__p_description>PySide2.QtGui.QTextCursor
It's document is checked for misspelled words.</__p_description>
                                </Object>
                            </Function>
                            <Function>
                                <__p_name>__findNextWord_</__p_name>
                                <__p_description>Finds the next misspelled word in the current document this spell checker is checking, optionally skipping the word this checker's cursor is currently under. If no misspelled word is found once the end of the document is reached then it stops this spell checker.</__p_description>
                                <__p_static>0</__p_static>
