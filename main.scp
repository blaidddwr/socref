            <Module>
                <__p_name>util</__p_name>
                <__p_description>Contains all utility functions and classes that provide basic utilities to the rest of the core application and language implementations.</__p_description>
                <Function>
                    <__p_name>wrap_blocks</__p_name>
                    <__p_description>Wraps the given text into separate blocks that are in turn wrapped into multiple lines with the given begin string appended to each one and limited by the given number of columns per line. The delimiter for each given block is double new lines. The output of each block is separated by a line with the given separator string.</__p_description>
                    <__p_return_description>Wrapped lines of text separated into multiple blocks of text using a given separator string.</__p_return_description>
                    <__p_static>0</__p_static>
                    <__p_abstract>0</__p_abstract>
                    <Object>
                        <__p_name>text</__p_name>
                        <__p_description>A string of text that is wrapped into multiple lines and separated into blocks.</__p_description>
                    </Object>
                    <Object>
                        <__p_name>begin</__p_name>
                        <__p_description>A string that is appended to every line of wrapped text generated.</__p_description>
                        <__p_assignment>&quot;&quot;</__p_assignment>
                    </Object>
                    <Object>
                        <__p_name>separator</__p_name>
                        <__p_description>A string of text that is used to separate each block of text.</__p_description>
                        <__p_assignment>&quot;&quot;</__p_assignment>
                    </Object>
                    <Object>
                        <__p_name>columns</__p_name>
                        <__p_description>The maximum column length for each line of wrapped text.</__p_description>
                        <__p_assignment>80</__p_assignment>
                    </Object>
                </Function>
                <Function>
                    <__p_name>wrap_text</__p_name>
                    <__p_description>Wraps given text into multiple lines that are limited by the given number of columns per line. Every line is appended with an optional begin string and every line after the first is also appended with an optional after line.</__p_description>
                    <__p_return_description>New line separated string of wrapped text generated from the given input text.</__p_return_description>
                    <__p_inlines>Initialize the return string, separate the given strings words into a list of word strings, and set the first line indicator to true.

Continue while there are still words to wrap.

If this is the first line then append with only the given begin string.

Else append the line with the given begin and then the given after strings.

While adding the next word does not make the current line become larger than the maximum column length keep adding words.

Add the next line to the wrapped text.

Return the wrapped text.</__p_inlines>
                    <__p_static>0</__p_static>
                    <__p_abstract>0</__p_abstract>
                    <Object>
                        <__p_name>text</__p_name>
                        <__p_description>A string of text that is wrapped into multiple lines.</__p_description>
                    </Object>
                    <Object>
                        <__p_name>begin</__p_name>
                        <__p_description>A string that is appended to every line of wrapped text generated.</__p_description>
                        <__p_assignment>&quot;&quot;</__p_assignment>
                    </Object>
                    <Object>
                        <__p_name>after</__p_name>
                        <__p_description>A string of text that is appended to every wrapped line of text after the begin string.</__p_description>
                        <__p_assignment>&quot;&quot;</__p_assignment>
                    </Object>
                    <Object>
                        <__p_name>columns</__p_name>
                        <__p_description>The maximum column length for each line of wrapped text.</__p_description>
                        <__p_assignment>80</__p_assignment>
                    </Object>
                </Function>
