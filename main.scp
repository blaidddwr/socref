                        <__p_static>0</__p_static>
                        <__p_abstract>0</__p_abstract>
                        <Object>
                            <__p_name>model</__p_name>
                            <__p_description>socref.model.ProjectModel
The project model that this new command acts upon.</__p_description>
                        </Object>
                    </Function>
                    <Function>
                        <__p_name>redo</__p_name>
                        <__p_description>This interface acts on this command's project model to redo its command.</__p_description>
                        <__p_static>0</__p_static>
                        <__p_abstract>1</__p_abstract>
                    </Function>
                    <Function>
                        <__p_name>undo</__p_name>
                        <__p_description>This interface acts on this command's project model to undo its command.</__p_description>
                        <__p_static>0</__p_static>
                        <__p_abstract>1</__p_abstract>
                    </Function>
                    <Function>
                        <__p_name>_buildRows_</__p_name>
                        <__p_description>Getter method.</__p_description>
                        <__p_returnDescription>list
Rows that represent the given qt model index of this command's project model. An empty list is the root index.</__p_returnDescription>
