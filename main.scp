                                <__p_description>Getter method.</__p_description>
                                <__p_returnsDescription>result
list
Rows that represent the given qt model index of this command's project model. An empty list is the root index.</__p_returnsDescription>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
                                <Object>
                                    <__p_name>index</__p_name>
                                    <__p_description>PySide2.QtCore.QModelIndex
An index of this command's project model.</__p_description>
                                </Object>
                            </Function>
