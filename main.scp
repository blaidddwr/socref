                <__p_name>gui_util</__p_name>
                <__p_description>Contains all GUI utility classes used by other GUI elements of the core application.</__p_description>
                <Class>
                    <__p_name>Spell_Highlighter</__p_name>
                    <__p_description>This is the spell highlighter class. It implements the qt syntax highlighter class. It provides highlighting of misspelled words in the document the highlighter is given on initialization. It uses the Hunspell library for all speller functions.</__p_description>
                    <__p_parents>qtg.QSyntaxHighlighter</__p_parents>
