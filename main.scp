                    </Object>
                    <Object>
                        <__p_name>progressed</__p_name>
                        <__p_description>Signals this parser has made the given percentage progress parsing. The range given is from 0 to 100.</__p_description>
                        <__p_assignment>qtc.Signal(int)</__p_assignment>
                    </Object>
                    <Object>
                        <__p_name>remained</__p_name>
