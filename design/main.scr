              <name>setValue</name>
              <operation>Set the new value of this object's model.</operation>
              <operation>Auto fit all new rows of text and reset this object's current model index to invalid.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>New string list that this edit widget is set to by copying it.</description>
                <initializer></initializer>
                <name>list</name>
                <type>const QStringList&amp;</type>
              </data>
            </variable>
          </function>
        </access>
