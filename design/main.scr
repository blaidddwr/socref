                  <data version="1">
                     <name>argv</name>
                     <description>The list of arguments from main.</description>
                     <type>char**</type>
                  </data>
               </variable>
            </constructor>
            <function type="2">
               <data version="1">
                  <name>notify</name>
                  <description>This implements the interface for handling events in the main event loop. The only thing this does is add a catch section so exceptions are handled.</description>
                  <type>bool</type>
                  <virtual/>
                  <override/>
                  <final/>
                  <return_description>True if the event was processed or false otherwise.</return_description>
                  <operation>Simply call the Qt notify method but wrap it in a catch statement so exceptions can be handled in this program.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>receiver</name>
                     <description>Pointer to the object that received the event.</description>
                     <type>QObject*</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="1">
                     <name>event</name>
                     <description>Pointer to the event that has happened.</description>
                     <type>QEvent*</type>
                  </data>
               </variable>
            </function>
            <variable type="1">
               <data version="1">
                  <name>_companyKey</name>
                  <description>The company key used to access this program's qt settings.</description>
                  <static/>
                  <type>const char*</type>
                  <initializer>"blaidddwr"</initializer>
               </data>
            </variable>
            <variable type="1">
               <data version="1">
                  <name>_programKey</name>
                  <description>The program key used to access this program's qt settings.</description>
                  <static/>
                  <type>const char*</type>
                  <initializer>"socref"</initializer>
               </data>
            </variable>
         </access>
      </class>
