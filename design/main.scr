      <class>
        <data>
          <description>This is the view class for the function block. This provides custom displays that show the arguments, templates, properties, return value, and operations of this view's function.</description>
          <name>FunctionView</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Basic::BlockView</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new view object with the given function block.</description>
              <explicit/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Function block this new view displays.</description>
                <initializer></initializer>
                <name>block</name>
                <type>const Function*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Returns rich text that displays any arguments this view's function block contains. If this view's function block has no arguments then this returns an empty string.</description>
              <name>displayArguments</name>
              <operation>Create an empty return string.</operation>
              <operation>Make a pointer list of all children variables of this view's function block and make sure it is not empty.</operation>
              <operation>Append a title.</operation>
              <operation>Iterate through all child variable blocks.</operation>
              <operation>If the child block has an initial value then add its rich text.</operation>
              <operation>Append the child variable information as rich text including the possible initial value.</operation>
              <operation>Return the arguments rich text.</operation>
              <return_description>Rich text that displays any arguments this view's function block contains or an empty string if there are no arguments.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <description>Wrapper method that calls the static method in _CppQt::Template_ of the same name.</description>
              <name>displayTemplates</name>
              <return_description>See wrapped method docs.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <description>Returns rich text that displays any properties this view's function block has set. If this view's function block has no properties set then this returns an empty string.</description>
              <name>displayProperties</name>
              <operation>Create an empty string list, appending any properties this view's function block has set.</operation>
              <operation>If the string list is empty then return an empty string.</operation>
              <operation>Else this view's block has set properties so return rich text displaying those set properties.</operation>
              <return_description>Rich text that displays any properties this view's function block has set or an empty string if no properties are set.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <description>Returns rich text that displays the return type field for this view's function block.</description>
              <name>displayReturn</name>
              <operation>Get the return type of this view's function block.</operation>
              <operation>If the return type is empty or is equal to "void" then return an empty string.</operation>
              <operation>Else this view's function block has a return type so return rich text displaying that return type and its description.</operation>
              <return_description>Rich text that displays the return type field of this view's function block.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <description>Returns rich text that displays the number of operations of this view's function block.</description>
              <name>displayOperations</name>
              <operation>Return rich text displaying the number of operations.</operation>
              <return_description>Rich text that displays the number of operations of this view's function block.</return_description>
              <type>QString</type>
            </data>
          </function>
        </access>
      </class>
      <class>
        <data>
          <description>This is the class block. This represents C++ classes. This inherits from the namespace block since a class expands upon the concept of a namespace. Because many properties of a class depend on the blocks it contains the class block is very dependent upon its child block properties.</description>
          <name>Class</name>
          <qtobject/>
        </data>
