              <name>headerLines</name>
              <return_description>Header lines setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the function lines setting.</description>
              <name>functionLines</name>
              <return_description>Function lines setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the max columns setting.</description>
              <name>maxColumns</name>
              <return_description>Max columns setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <description>Sets the indent spaces setting to the given value.</description>
              <name>setIndentSpaces</name>
              <operation>Update the setting to the new value given.</operation>
              <operation>Update the setting in qt settings for persistence.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The new value for the setting.</description>
                <initializer></initializer>
                <name>value</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Sets the header lines setting to the given value.</description>
              <name>setHeaderLines</name>
              <operation>Update the setting to the new value given.</operation>
