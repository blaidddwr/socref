            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this block contains any children of the given type.</description>
              <name>containsType</name>
              <operation>Iterate through list of this block's children.</operation>
              <operation>If the child matches the given type then return true.</operation>
              <operation>Return false because no child was found with the given type.</operation>
              <return_description>True if this block contains any children of the given type, else false.</return_description>
              <type>bool</type>
            </data>
            <variable>
              <data>
                <description>The block type to search for within this block's list of children.</description>
                <initializer></initializer>
