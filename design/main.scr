            <data>
              <const/>
              <description>Tests if this class or any parent classes contain any template arguments.</description>
              <name>hasAnyTemplates</name>
              <operation>Make sure this class block does not have any template arguments.</operation>
              <operation>Iterate up the chain of block parents starting with this block's parent until a namespace or null pointer is reached.</operation>
              <operation>If this parent is a class and it has template arguments then return true.</operation>
              <operation>Move up to the next parent block.</operation>
              <operation>If this is reached then no template arguments were found so return false.</operation>
              <return_description>True if this class or any parent class contains any template arguments, otherwise false is returned.</return_description>
              <type>bool</type>
            </data>
