         <class type="4">
            <data version="0">
               <name>BlockFactory</name>
               <description>This is the block factory for the C++/Qt project type. This class defines an enumeration representing all possible block types for its project type. This is a singleton class and has only one single global instance.</description>
            </data>
            <parent type="13">
               <data version="0">
                  <access>public</access>
                  <class>AbstractBlockFactory</class>
               </data>
            </parent>
            <parent type="13">
               <data version="0">
                  <access>public</access>
                  <class>Singleton&lt;BlockFactory></class>
               </data>
            </parent>
            <access type="5">
               <data version="0">
                  <type>public:</type>
               </data>
               <enumeration type="11">
                  <data version="0">
                     <description>Defines all possible block types for the C++/Qt project type.</description>
                  </data>
                  <enumval type="12">
                     <data version="0">
                        <name>NamespaceType</name>
                        <description>Defines the namespace block.</description>
                     </data>
                  </enumval>
                  <enumval type="12">
                     <data version="0">
                        <name>VariableType</name>
                        <description>Defines the variable block.</description>
                     </data>
                  </enumval>
                  <enumval type="12">
                     <data version="0">
                        <name>FunctionType</name>
                        <description>Defines the function block.</description>
                     </data>
                  </enumval>
                  <enumval type="12">
                     <data version="0">
                        <name>TemplateType</name>
                        <description>Defines the template block. This is used for template arguments in classes and functions.</description>
                     </data>
                  </enumval>
                  <enumval type="12">
                     <data version="0">
                        <name>ClassType</name>
                        <description>Defines the class block.</description>
                     </data>
                  </enumval>
                  <enumval type="12">
                     <data version="0">
                        <name>AccessType</name>
                        <description>Defines the access block. This is used for the different access types in classes such as public, private, signals, or slots.</description>
                     </data>
                  </enumval>
                  <enumval type="12">
                     <data version="0">
