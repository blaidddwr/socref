                  <initializer></initializer>
                  <name>_snippetView</name>
                  <type>QLabel*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>Pointer to the suggestions view label of this dialog that displayed possible corrections to the current misspelled word.</description>
                  <initializer></initializer>
                  <name>_suggestionsView</name>
                  <type>QLabel*</type>
