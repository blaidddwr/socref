              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>name</name>
              <operation>Create a string and set it to this variable's base name.</operation>
              <operation>Check to see if this variable has an initial vallue.</operation>
              <operation>Append the initial value indicator appropriate for the context of this variable.</operation>
              <operation>Append this variable's property markers.</operation>
              <operation>Return this variable's display name.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
          </function>
