      <class>
        <data>
          <description>This is the settings dialog. This allows the user to edit all global settings for the C++/Qt project type.</description>
          <name>SettingsDialog</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>::Gui::PersistentDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new settings dialog.</description>
              <explicit/>
              <name>^</name>
              <operation>Create the GUI for this new dialog and set its window title.</operation>
              <return_description></return_description>
              <type></type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when the OK button is clicked. This applies all global settings and closes the dialog.</description>
              <name>okClicked</name>
              <operation>Apply all global settings of this dialog and close it.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the apply button is clicked. This applies the global setting values of this dialog.</description>
              <name>applyClicked</name>
              <operation>Get the global settings object and apply all settings.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Creates and initializes all GUI elements for this new dialog.</description>
              <name>setupGui</name>
              <operation>Create a new vertical layout, adding the form layout and then the buttons layout.</operation>
              <operation>Set the layout of this new dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Creates and initializes all edit widgets for this new dialog, returning a form layout containing the edit widgets.</description>
              <name>setupForm</name>
              <operation>Get the global settings instance.</operation>
              <operation>Create the indent spaces edit widget and set its value to the current global setting.</operation>
              <operation>Create the header lines edit widget and set its value to the current global setting.</operation>
              <operation>Create the function lines edit widget and set its value to the current global setting.</operation>
              <operation>Create the max columns edit widget and set its value to the current global setting.</operation>
              <operation>Create a new form layout, adding the indent spaces widget then the header lines widget then the function lines widget and then the max columns widget.</operation>
              <operation>Return the form layout.</operation>
              <return_description>Form layout containing all edit widgets for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <function>
            <data>
              <description>Creates and initializes the OK, apply, and cancel buttons for this new dialog, returning the buttons layout.</description>
              <name>setupButtons</name>
              <operation>Create the OK button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the apply button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the cancel button for this dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the OK button then the apply button then a stretch and then the cancel button.</operation>
              <operation>Return the buttons layout.</operation>
              <return_description>Layout containing buttons for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <variable>
            <data>
              <description>The edit widget for the indent spaces setting.</description>
              <initializer></initializer>
              <name>_indentSpacesBox</name>
              <type>QSpinBox*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The edit widget for the header lines setting.</description>
              <initializer></initializer>
              <name>_headerLinesBox</name>
              <type>QSpinBox*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The edit widget for the function lines setting.</description>
              <initializer></initializer>
              <name>_functionLinesBox</name>
              <type>QSpinBox*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The edit widget for the max columns setting.</description>
              <initializer></initializer>
              <name>_maxColumnsBox</name>
              <type>QSpinBox*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is the block factory for the C++/Qt project type. This class defines an enumeration representing all possible block types for its project type. This is a singleton class and has only one single global instance. This also inherits from the basic block factory class to allow for XML definitions of block type data.</description>
          <name>Factory</name>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Basic::BlockFactory</class>
          </data>
        </parent>
        <parent>
          <data>
            <access>public</access>
            <class>Soc::Ut::Singleton&lt;Factory></class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <enumeration>
            <data>
              <description>Defines all possible block types for the C++/Qt project type.</description>
              <name></name>
            </data>
            <enumvalue>
              <data>
                <description>Defines the namespace block.</description>
                <name>NamespaceType</name>
                <value></value>
              </data>
            </enumvalue>
            <enumvalue>
              <data>
                <description>Defines the enumeration block. This is for C++ enumerations of all types.</description>
                <name>EnumerationType</name>
                <value></value>
              </data>
            </enumvalue>
            <enumvalue>
              <data>
