              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <variable>
            <data>
              <description>The boolean tag name of elements that define a boolean data field.</description>
              <initializer>"bool"</initializer>
              <name>_boolTag</name>
