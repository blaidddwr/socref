              <name>displayTemplates</name>
              <operation>Create an empty string that will contain the rich text.</operation>
              <operation>Create a pointer list of all template blocks this view's block contains as direct children, making sure that list is not empty.</operation>
              <operation>Append the rich text title for templates.</operation>
              <operation>Iterate through all template block pointers and append a rich text paragraph describing each one.</operation>
              <operation>Return the rich text.</operation>
              <return_description>Rich text containing list of any template arguments the given block may contain.</return_description>
              <static/>
              <type>QString</type>
            </data>
            <variable>
              <data>
                <description>The base block whose direct block children are searched for template blocks whose information is added to returned rich text.</description>
