            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns this variable block's type field value.</description>
              <name>variableType</name>
              <return_description>This variable's C++ type.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this variable block has an initial value.</description>
              <name>hasInitializer</name>
              <operation>Test if this variable's initial value string is empty to determine if it has one.</operation>
              <return_description>True if this variable has an initial value or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns this variable block's initial value or an empty string if none is set.</description>
              <name>initializer</name>
              <return_description>This variable's initial value or an empty string is none is set.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this variable block is a member of a C++ class, returning true if it is a member.</description>
              <name>isMember</name>
              <operation>Get this block's parent block pointer and make sure it is not null.</operation>
              <operation>Test if this variable is an argument by seeing if its parent block is an access type.</operation>
              <return_description>True if this variable is a class member or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if any class this variable block inherits from has any templates, returning true if so.</description>
              <name>hasAnyTemplates</name>
              <operation>If this variable block is a member then call on its class to determine if it or any parent classes contain templates.</operation>
              <operation>If this is reached then there are no templates so return false.</operation>
              <return_description>True if any inherited classes contain templates or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this variable block is an argument of a C++ function, returning true if it is an argument.</description>
              <name>isArgument</name>
              <operation>Test if this variable is an argument by seeing if its parent is a function block type.</operation>
              <return_description>True if this is a function argument or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
        </access>
