                <data>
                  <description>The layout that has the given item added to it.</description>
                  <initializer></initializer>
                  <name>layout</name>
                  <type>QLayout*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The XML element whose display attribute is used as the display title.</description>
                  <initializer></initializer>
                  <name>element</name>
                  <type>const QDomElement&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The item that is added to the given with a display title extracted from the given XML element.</description>
                  <initializer></initializer>
                  <name>item</name>
                  <type>QLayout*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Return the value of this editor's basic block's field with the given id, checking its type matches with the given type. This assumes this is being called to add a new edit widget so additional checks are done. If this editor already has an edit widget with the given id, no field exists with the given id, or the field type does not match the given type then an exception is thrown.</description>
                <name>fieldValue</name>
                <operation>Make sure this editor's list of edit widgets does not already contain the given id.</operation>
                <operation>Get this editor's basic block's field with the given id, making sure it exists.</operation>
                <operation>Make sure the field type matches the given type.</operation>
                <operation>Return the basic block field value.</operation>
                <return_description>Basic block field value with the given id.</return_description>
                <type>QVariant</type>
              </data>
              <variable>
                <data>
                  <description>The basic block field id whose value is returned.</description>
                  <initializer></initializer>
                  <name>id</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The basic block field type that is checked with the field type matched with the given id.</description>
                  <initializer></initializer>
                  <name>type</name>
                  <type>quint32</type>
                </data>
              </variable>
            </function>
            <variable>
              <data>
                <description>The basic block that this editor is editing.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>BasicBlock*</type>
