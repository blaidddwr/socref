               </data>
            </signal>
            <signal type="8">
               <data version="1">
                  <name>saveFileChanged</name>
                  <description>Signals that this project's file has been changed by an outside source and no longer contains the last save of this project.</description>
                  <type></type>
               </data>
            </signal>
