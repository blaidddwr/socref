                     <type>QLineEdit*</type>
                  </data>
               </variable>
            </access>
         </class>
         <class type="4">
            <data version="0">
               <name>ScanDialog</name>
               <description>This is the scan dialog which executes a scan thread and reports on its progress, closing once the scanning is complete or fails. Progress of scanning is presented to the user using a progress bar. This dialog allows the user to cancel the scanning process with a cancel button which requests the scan thread to interrupt itself before completion.</description>
               <qtobject/>
            </data>
            <parent type="13">
               <data version="0">
                  <access>public</access>
                  <class>PersistentDialog</class>
               </data>
            </parent>
            <access type="5">
               <data version="0">
                  <type>public:</type>
               </data>
               <constructor type="9">
                  <data version="0">
                     <description>Constructs a new scan dialog with the given scan thread and optional parent. This does not start the scanning process but only prepares the dialog to start execution. If the given scan thread pointer is null then an exception is thrown.</description>
                     <explicit/>
                     <operation>If the given scan thread pointer is null then throw an excpetion, else setup this GUI and window title of this new dialog.</operation>
                     <operation>Connect the progress changed and finished signals to this new dialog.</operation>
                  </data>
                  <variable type="1">
                     <data version="0">
                        <name>scanner</name>
                        <description>Pointer to the scan thread this new dialog will use for execution. This dialog does not take ownership of the scan thread. The pointer cannot be null.</description>
                        <type>ScanThread*</type>
                     </data>
                  </variable>
                  <variable type="1">
                     <data version="0">
                        <name>parent</name>
                        <description>Optional parent for this new dialog.</description>
                        <type>QWidget*</type>
                        <initializer>nullptr</initializer>
                     </data>
                  </variable>
               </constructor>
               <function type="2">
                  <data version="0">
                     <name>exec</name>
                     <description>Starts execution of the scan thread of this dialog and then beings execution of this dialog in modal mode.</description>
                     <virtual/>
                     <override/>
                     <final/>
                     <type>int</type>
                     <return_description>Always returns Qt dialog accept.</return_description>
                     <operation>Start the separate thread for scanning in this object's scan thread object and then begin execution of this dialog in modal mode returning the exit state.</operation>
                  </data>
               </function>
            </access>
            <access type="5">
               <data version="0">
                  <type>protected:</type>
               </data>
               <function type="2">
                  <data version="0">
                     <name>closeEvent</name>
                     <description>Implements the Qt interface for handling a close event on this dialog. This implementation requests its scan thread to finish and ignores the close event so the scan thread exits cleanly.</description>
                     <virtual/>
                     <override/>
                     <final/>
                     <type>void</type>
                     <operation>Request the scan thread for this dialog interrupts itself and ignore the given close event.</operation>
                  </data>
                  <variable type="1">
                     <data version="0">
                        <name>event</name>
                        <description>Pointer to the Qt close event handler.</description>
                        <type>QCloseEvent*</type>
                     </data>
                  </variable>
               </function>
            </access>
            <access type="5">
               <data version="0">
                  <type>private slots:</type>
               </data>
               <slot type="7">
                  <data version="0">
                     <name>cancelClicked</name>
                     <description>Called when the cancel button for this dialog is clicked, requesting the scan thread for this dialog to interrupt itself and exit.</description>
                  </data>
               </slot>
               <slot type="7">
                  <data version="0">
                     <name>progressChanged</name>
                     <description>Called when the scan thread's progress for this dialog has changed. This updates the progress bar for this dialog.</description>
                  </data>
                  <variable type="1">
                     <data version="0">
                        <name>index</name>
                        <description>The current file index that is being parsed by the scan thread of this dialog.</description>
                        <type>int</type>
                     </data>
                  </variable>
               </slot>
               <slot type="7">
                  <data version="0">
                     <name>scanFinished</name>
                     <description>Called when the scan thread for this dialog has finished scanning all files. This closes this dialog on accept. If the scan thread has an exception from its separate thread then it is shown to the user.</description>
                     <operation>If this object's scan thread contained an exception then show it to the user.</operation>
                     <operation>Exit the modal execution of this dialog with accept.</operation>
                  </data>
               </slot>
            </access>
            <access type="5">
               <data version="0">
                  <type>private:</type>
               </data>
               <function type="2">
                  <data version="0">
                     <name>setupGui</name>
                     <description>Constructs and initializes the GUI for this new dialog.</description>
                     <type>void</type>
                     <operation>Create and initialize the progress bar for this new dialog, using the total number of files this object's scan thread will parse as the progress bar's maximum value.</operation>
                     <operation>Create a new vertical layout _layout_, adding this object's progress bar then the bottom GUI.</operation>
                     <operation>Set the layout of this dialog to _layout_.</operation>
                  </data>
               </function>
               <function type="2">
                  <data version="0">
                     <name>setupBottom</name>
                     <description>Constructs and initializes the bottom GUI for this new dialog, returning its layout.</description>
                     <type>QLayout*</type>
                     <return_description>Pointer to layout of the bottom GUI for this new element.</return_description>
                     <operation>Create a push button for this object's cancel button, connecting its signal.</operation>
                     <operation>Create a new horizontal layout _ret_, adding a stretch then this object's cancel button then a another stretch.</operation>
                     <operation>Return _ret_.</operation>
                  </data>
               </function>
               <variable type="1">
                  <data version="0">
                     <name>_scanner</name>
                     <description>Pointer to the scan thread object for this dialog.</description>
                     <type>ScanThread*</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="0">
                     <name>_bar</name>
                     <description>Pointer to the progress bar widget for this dialog.</description>
                     <type>QProgressBar*</type>
                  </data>
               </variable>
            </access>
         </class>
         <class type="4">
            <data version="0">
               <name>AboutDialog</name>
               <description>This is a simple dialog that presents information about this program. The only functionality is to simply close it by clicking OK.</description>
               <qtobject/>
            </data>
            <parent type="13">
               <data version="0">
                  <access>public</access>
                  <class>PersistentDialog</class>
               </data>
            </parent>
            <access type="5">
               <data version="0">
                  <type>public:</type>
               </data>
               <constructor type="9">
                  <data version="0">
                     <description>Constructs a new about dialog with the given optional parent.</description>
                     <explicit/>
                     <operation>Setup this object's GUI and set the dialog window's title.</operation>
                  </data>
                  <variable type="1">
                     <data version="0">
                        <name>parent</name>
                        <description>Pointer to this new about dialog object's parent or null for no parent.</description>
                        <type>QWidget*</type>
                        <initializer>nullptr</initializer>
                     </data>
                  </variable>
               </constructor>
            </access>
            <access type="5">
               <data version="0">
                  <type>private:</type>
               </data>
               <function type="2">
                  <data version="0">
                     <name>setupGui</name>
                     <description>Constructs all GUI elements for this new about dialog.</description>
                     <type>void</type>
                     <operation>Create a new vertical box layout _layout_, adding the top and bottom layout sections of this object's GUI in that order.</operation>
                     <operation>Set this object's layout to _layout_.</operation>
                  </data>
               </function>
               <function type="2">
                  <data version="0">
                     <name>setupTop</name>
                     <description>Constructs the top part of this object's GUI consisting of an image to the left and description to the right, returning the layout.</description>
                     <type>QLayout*</type>
                     <return_description>Pointer to layout of the top section of this object's GUI.</return_description>
                     <operation>Create a new label _image_, setting its pixmap to the program's icon scaled to the correct dimensions.</operation>
                     <operation>Create a new horizontal box layout _ret_, adding the _image_ label and then the layout returned from this object's setup text method.</operation>
                     <operation>Return _ret_.</operation>
                  </data>
               </function>
               <function type="2">
                  <data version="0">
                     <name>setupText</name>
                     <description>Constructs the rich text displayed in the top right of this object's GUI, returning a pointer to the widget.</description>
                     <type>QWidget*</type>
                     <return_description>Pointer to the widget of rich text displayed in the top right of this object's GUI.</return_description>
                     <operation>Create a new label _ret_, setting its alignment, word wrapping, text format, and margin.</operation>
                     <operation>Create a new qt file device _file_ and open the about HTML file with it. If opening the file fails then throw an exception.</operation>
                     <operation>Set the text of the created label _ret_ with the contents of _file_, replacing the keys for this program version and the Qt version.</operation>
                     <operation>Return _ret_.</operation>
                  </data>
               </function>
               <function type="2">
                  <data version="0">
                     <name>setupBottom</name>
                     <description>Constructs the bottom part of this object's GUI which simply consists of an OK button on the bottom right, returning the layout.</description>
                     <type>QLayout*</type>
                     <return_description>Pointer to layout of the bottom section of this object's GUI.</return_description>
                     <operation>Create a new push button _ok_, connecting its clicked signal to close this dialog.</operation>
                     <operation>Create a new horizontal box layout _ret_, adding a stretch and then the _ok_ button.</operation>
                     <operation>Return _ret_.</operation>
                  </data>
               </function>
               <variable type="1">
                  <data version="0">
                     <name>_iconSize</name>
                     <description>The width and height of the program's icon displayed in the top left of this object's GUI.</description>
                     <constexpr/>
                     <static/>
                     <type>int</type>
                     <initializer>128</initializer>
                  </data>
               </variable>
            </access>
         </class>
