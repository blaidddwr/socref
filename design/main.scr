                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Called when the about action is triggered, executing the about message box.</description>
              <name>aboutTriggered</name>
              <operation>Open the internal file containing the HTML of the about dialog and make sure it worked.</operation>
              <operation>Read in the entire contents of the HTML and replace the application version string.</operation>
              <operation>Execute a message box about dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the about qt action is triggered, executing the about qt message box.</description>
