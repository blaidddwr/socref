              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <description>Sets the enabled state of this editor's spell checking with the given state.</description>
              <name>setSpellCheckEnabled</name>
              <operation>Check to see if spell checking is being disabled.</operation>
              <operation>Delete any highlighter this editor may have and set its pointer to null.</operation>
              <operation>Else if this editor has no highlighter then create a new one.</operation>
