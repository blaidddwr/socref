            <function type="2">
               <data version="0">
                  <name>setField</name>
                  <description>Sets the value of the field with the given index for this block. If the given index is out of range then an exception is thrown.</description>
                  <type>void</type>
                  <operation>If the given index is out of range then throw an exception.</operation>
                  <operation>If the new given value is different from the current value for the given field then call the interface to quietly set it to the new value and then call the interface to notify that field has been modified.</operation>
               </data>
