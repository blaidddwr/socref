            <operation>Set the organization and application name for this program.</operation>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The argument count from main.</description>
              <initializer></initializer>
              <name>argc</name>
              <type>int&amp;</type>
            </data>
          </variable>
