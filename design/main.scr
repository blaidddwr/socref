                  <data version="1">
                     <name>argv</name>
                     <description>The list of arguments from main.</description>
                     <type>char**</type>
                  </data>
               </variable>
            </constructor>
            <function type="2">
               <data version="1">
                  <name>notify</name>
                  <description>This implements the interface for handling events in the main event loop. The only thing this does is add a catch section so exceptions are handled.</description>
                  <type>bool</type>
                  <virtual/>
                  <override/>
                  <final/>
                  <return_description>True if the event was processed or false otherwise.</return_description>
                  <operation>Call the Qt application notify method and return its value.</operation>
                  <operation>If any exception is caught then report it to the qt debug stream and return false.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>receiver</name>
                     <description>Pointer to the object that received the event.</description>
                     <type>QObject*</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="1">
                     <name>event</name>
                     <description>Pointer to the event that has happened.</description>
                     <type>QEvent*</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>versionString</name>
                  <description>Returns this programs version as a string.</description>
                  <static/>
                  <type>QString</type>
                  <return_description>This programs version as a string.</return_description>
               </data>
            </function>
