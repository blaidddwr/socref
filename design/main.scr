          </data>
          <function>
            <data>
              <description>Recursively builds and returns a type selection menu from the given JSON object. Any children JSON objects are recursively added as sub menus.</description>
              <name>setupMenu</name>
              <operation>Create a new menu, setting its title to the given key value.</operation>
              <operation>Iterate through all children of the given JSON object.</operation>
              <operation>If the JSON value is am object  then add a sub menu built by recursively calling this method, else if it is a null value then add it as an action to this menu using its key value as the type value.</operation>
              <operation>Return the new menu.</operation>
              <return_description>Type selection menu  built from the given JSON object.</return_description>
              <type>QMenu*</type>
            </data>
