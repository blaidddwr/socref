            <data>
              <description>The custom dictionary model of this dialog that it displays and edits.</description>
              <initializer></initializer>
              <name>_model</name>
              <type>DictionaryModel*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is the scan dialog which executes a scan thread and reports on its progress, closing once the scanning is complete or fails. Progress of scanning is presented to the user using a progress bar. This dialog allows the user to cancel the scanning process with a cancel button which requests the scan thread to interrupt itself before completion.</description>
          <name>ScanDialog</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>PersistentDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new scan dialog with the given scan thread and optional parent. This does not start the scanning process but only prepares the dialog to start execution. If the given scan thread pointer is null then an exception is thrown.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the given scanner pointer is not null.</operation>
              <operation>Create the GUI for this dialog and set its title.</operation>
              <operation>Connect the given scanner signals to this new dialog.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Pointer to the scan thread this new dialog will use for execution. This dialog does not take ownership of the scan thread. The pointer cannot be null.</description>
                <initializer></initializer>
                <name>scanner</name>
                <type>ScanThread*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent for this new dialog.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Implements _QDialog_ interface. This implementation starts execution of the scan thread of this dialog and then passes execution to the dialog.</description>
              <final/>
              <name>exec</name>
              <operation>Start the scanner thread and then pass execution to the dialog.</operation>
              <override/>
              <return_description>See Qt docs.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Implements _QWidget_ interface. This implementation requests its scan thread to finish and ignores the close event so the scan thread can exit cleanly.</description>
              <final/>
              <name>closeEvent</name>
              <operation>Request the scan thread for this dialog interrupts itself and ignore the given close event.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>event</name>
                <type>QCloseEvent*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when the cancel button for this dialog is clicked, requesting the scan thread for this dialog to interrupt itself and exit.</description>
              <name>cancelClicked</name>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the scan thread's progress for this dialog has changed. This updates the progress bar for this dialog.</description>
              <name>progressChanged</name>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The current file index that is being parsed by the scan thread of this dialog.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Called when the scan thread for this dialog has finished scanning all files. This closes this dialog on accept.</description>
              <name>scanFinished</name>
              <operation>Close this dialog with accepted.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Constructs and initializes the GUI for this new dialog.</description>
              <name>setupGui</name>
              <operation>Create and initialize the progress bar for this new dialog.</operation>
              <operation>Create a new vertical layout, adding the progress bar and then the bottom layout.</operation>
              <operation>Set the layout of this new dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the bottom GUI for this new dialog, returning its layout.</description>
              <name>setupBottom</name>
              <operation>Create the push button for this dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding a stretch then the cancel button and then another stretch.</operation>
              <operation>Return the bottom layout.</operation>
              <return_description>Pointer to layout of the bottom GUI for this new element.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <variable>
            <data>
              <description>Pointer to the scan thread object for this dialog.</description>
              <initializer></initializer>
              <name>_scanner</name>
              <type>ScanThread*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the progress bar widget for this dialog.</description>
              <initializer></initializer>
              <name>_bar</name>
              <type>QProgressBar*</type>
            </data>
          </variable>
        </access>
      </class>
    </namespace>
    <namespace>
      <data>
        <description>Contains the C++/Qt project type.</description>
        <name>CppQt</name>
      </data>
      <namespace>
        <data>
          <description>Contains all C++/Qt parsing elements.</description>
          <name>Parse</name>
        </data>
        <class>
          <data>
            <description>This is the parser factory for the C++/Qt project type. This recognizes three primary file types. The naming convention for all types are the same. These types are global header files, header files, and source files.

Files are named based off their fully scoped namespace name. Each namespace is separated by underscores. If the file is for common functions, variables, and enumerations outside of a class the keyword "common" is appended its name. The root namespace has the special file named global.h for its global header.

The global header file has forward declarations of all classes within its namespace. The header file contains the header of either a class or a namespace. The source file contains the source of either a class or a namespace. The header and source of a namespace is simply all functions, variables, and enumerations scoped within its namespace.</description>
            <name>Factory</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>AbstractParserFactory</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <const/>
                <description>Implements _AbstractParserFactory_ interface.</description>
                <final/>
                <name>make</name>
                <operation>Make sure the given file name is not empty.</operation>
                <operation>Create the is header flag and set its value.</operation>
                <operation>If this is the unique root global header file then create a new global parser and return it.</operation>
                <operation>Else if this is the unique main source file then create a new main parser and return it.</operation>
                <operation>Create the list of namespace names from the given file name.</operation>
                <operation>Check to see if this is a common file.</operation>
                <operation>Remove the common name from the list and return the found common parser.</operation>
                <operation>Else this is a global or class file so return the found header/source parser.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>Soc::Ut::QPtr&lt;AbstractParser></type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>extension</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new C++/Qt parser factory with the given root block.</description>
                <explicit/>
                <name>^</name>
                <operation>Make sure the given root pointer is not null.</operation>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The root block used by this parser factory.</description>
                  <initializer></initializer>
                  <name>root</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <const/>
                <description>Attempts to find the namespace or class that matches the given file information. The appropriate parser is returned or a null pointer if no matching block is found. This recursively calls itself to resolve any scoped namespace for matching.</description>
                <name>find</name>
                <operation>Make sure the given namespace pointer and index are valid.</operation>
                <operation>Check to see if we have reached the end of the names list.</operation>
                <operation>If the current block is a namespace then return a global parser.</operation>
                <operation>Else the current block is a class so return its header or source parser.</operation>
                <operation>Else attempt to find the next child namespace and if found recursively call this method on it.</operation>
                <operation>Else namespace resolution failed so return null.</operation>
                <return_description>Pointer to the appropriate parser that matched the given file information or null if no match is found.</return_description>
                <type>AbstractParser*</type>
              </data>
              <variable>
                <data>
                  <description>The current namespace being inspected.</description>
                  <initializer></initializer>
                  <name>current</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The name fragments of the given file used for namespace resolution.</description>
                  <initializer></initializer>
                  <name>names</name>
                  <type>const QStringList&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The full name of the file being parsed.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>True if the file is a header or false if it is a source file.</description>
                  <initializer></initializer>
                  <name>isHeader</name>
                  <type>bool</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The current index matched so far in the given names variable for namespace resolution.</description>
                  <initializer>0</initializer>
                  <name>index</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <const/>
                <description>Attempts to find the namespace that matches the given file information. The appropriate common parser is returned or a null pointer if no matching block is found. This recursively calls itself to resolve any scoped namespace for matching.</description>
                <name>findCommon</name>
                <operation>Make sure the given namespace pointer and index are valid.</operation>
                <operation>Check to see if we have reached the end of the names list.</operation>
                <operation>If this last block is a namespace then return its common header or source parser.</operation>
                <operation>Else attempt to find the next child namespace and if found recursively call this method on it.</operation>
                <operation>Namespace resolution failed if this is reached so return null.</operation>
                <return_description>Pointer to the common parser that matched the given file information or null if no match is found.</return_description>
                <type>AbstractParser*</type>
              </data>
              <variable>
                <data>
                  <description>The current namespace being inspected.</description>
                  <initializer></initializer>
                  <name>current</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The name fragments of the given file used for namespace resolution.</description>
                  <initializer></initializer>
                  <name>names</name>
                  <type>const QStringList&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The full name of the file being parsed.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>True if the file is a header or false if it is a source file.</description>
                  <initializer></initializer>
                  <name>isHeader</name>
                  <type>bool</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The current index matched so far in the given names variable for namespace resolution.</description>
                  <initializer>0</initializer>
                  <name>index</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <const/>
                <description>Attempts to find a child namespace contained in the given namespace that matches the given name, returning a pointer if one if found.</description>
                <name>findNamespace</name>
                <operation>Iterate through the list of the given namespace block's real children.</operation>
                <operation>Check if the current child block is a namespace or class.</operation>
                <operation>If the namespace or class name matches the given name then return its pointer.</operation>
                <operation>No match was found so return null.</operation>
                <return_description>Pointer to matching namespace or null if no match is found.</return_description>
                <type>const CppQt::Namespace*</type>
              </data>
              <variable>
                <data>
                  <description>The current namespace being inspected.</description>
                  <initializer></initializer>
                  <name>current</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The name that is matched with child namespace blocks.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <variable>
              <data>
                <description>Pointer to the root block used by this parser factory and all parser objects it makes.</description>
                <initializer></initializer>
                <name>_root</name>
                <type>const Namespace*</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This base class represents parser objects that can belong to root parser objects for C++/Qt projects. These base objects include things such as functions or variables that are part of a root parser such as a header or source file. The root parser then uses its base parser children to deal with parsing of its individual components such as functions or variables.

This class prevents the make output interface to be used, instead defining its more specialized output interfaces that are specific to C++ and Qt. These base parser objects do not necessarily have to deal with reading any input lines and are primarily focused on adding output with the new interfaces provided.

This class also contains numerous static helper functions used throughout the C++/Qt parsing classes. Most of these helper functions deal with constructing strings or list of strings for output.</description>
            <name>Base</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>AbstractParser</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <abstract/>
                <description>This interface is called to add the comment section of this base parser object to output.</description>
                <name>outputComments</name>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <abstract/>
                <description>This interface is called to add the declaration of this base parser object to output.</description>
                <name>outputDeclaration</name>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <abstract/>
                <description>This interface is called to add the definition of this base parser object to output.</description>
                <name>outputDefinition</name>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Makes and returns a string list of output lines from the given text with the given justification. The lines are formatted as paragraphs, using double newline characters to separate the paragraphs. The justification is used to add extra space to every other line after the first one. This does not returning the opening and closing comment lines.</description>
                <name>makeComment</name>
                <operation>Make sure the given justified value is valid.</operation>
                <operation>Get the maximum columns setting and create a new string list that will be returned.</operation>
                <operation>Make sure the given text is not empty.</operation>
                <operation>Split the given text into paragraphs, using double newline characters as the separator and skipping empty paragraphs.</operation>
                <operation>Iterate through all the paragraphs.</operation>
                <operation>Split the paragraph into its individual words.</operation>
                <operation>Keep working until all words have been processed.</operation>
                <operation>Initialize the total number of columns used and the next output line.</operation>
                <operation>Check if this is the first line.</operation>
                <operation>Else this is not the first line so append the number of justification spaces to the output line and add the number of columns used to the total.</operation>
                <operation>Append the first word to the output line. The columns used was already added to the total when it was initialized.</operation>
                <operation>Keep working until there are no more words to process or the output line has reached the maximum number of columns.</operation>
                <operation>Add the number of columns the next word will use to the total and then add the next word to the output line.</operation>
                <operation>Add the finished output line to the return string list.</operation>
                <operation>If this is not the last paragraph add a separator line for the next one.</operation>
                <operation>Returned the formatted list of output lines.</operation>
                <return_description>Formatted list of output lines made from the given text with the given justification.</return_description>
                <static/>
                <type>QStringList</type>
              </data>
              <variable>
                <data>
                  <description>The text that is used to make and return the formatted output lines.</description>
                  <initializer></initializer>
                  <name>text</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The justification used for adding extra spaces before every output line after the first.</description>
                  <initializer>0</initializer>
                  <name>justified</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Makes and returns a string list of output lines that are the comments of template arguments for the given block. If the given block has no template blocks then an empty string list is returned. This does not returning the opening and closing comment lines.</description>
                <name>makeTemplateComments</name>
                <operation>Make sure the given block pointer is not null.</operation>
                <operation>Create a string list that will be returned.</operation>
                <operation>Iterate through all of the given block's template child blocks.</operation>
                <operation>Add a blank comment line to the output lines.</operation>
                <operation>Create a new comment string with the justified part of the string and then get the number of justified spaces required.</operation>
                <operation>Add the final part of the comment string and then make formatted comment output lines from the comment string with the appropriate justification.</operation>
                <operation>Return the output line list of template argument comments.</operation>
                <return_description>List of template argument comments output lines.</return_description>
                <static/>
                <type>QStringList</type>
              </data>
              <variable>
                <data>
                  <description>The block whose template children blocks is used to make and return template argument comments.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Makes and returns a string that is the scope required for the given block in its source file definition. This will either return the scope of the first namespace of the block if it is not part of a class or the full scope of all classes if it is.</description>
                <name>makePreScope</name>
                <operation>Make sure the given block pointer is not null.</operation>
                <operation>Get the parent of the given block and make sure it is not null.</operation>
                <operation>If the parent is the root block then return an empty string.</operation>
                <operation>If the parent is a namespace block then return the namespace scope.</operation>
                <operation>Else if the parent is an access block then return the class scope.</operation>
                <operation>Else the parent is an invalid type so throw an exception.</operation>
                <return_description>The scope required for the given block in its source file definition.</return_description>
                <static/>
                <type>QString</type>
              </data>
              <variable>
                <data>
                  <description>The block whose scope is returned for its source file definition.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Makes and returns a string that is the class scope required for the given block in its source file definition. If the given block is not part of a class then an empty string is returned.</description>
                <name>makePreClassScope</name>
                <operation>Make sure the given block pointer is not null.</operation>
                <operation>Create a new return string and a class pointer stack.</operation>
                <operation>Iterate through the given block's parents.</operation>
                <operation>If the parent is a namespace type then stop iterating through parents.</operation>
                <operation>Else if the parent is a class then push its pointer to the stack.</operation>
                <operation>Iterate to the next parent.</operation>
                <operation>Keep going until the stack is empty.</operation>
                <operation>Append the scope of the class to the return string, including any template arguments.</operation>
                <operation>Return the class scope string.</operation>
                <return_description>The class scope required for the given block in its source file definition or an empty string is the given block is not part of a class.</return_description>
                <static/>
                <type>QString</type>
              </data>
              <variable>
                <data>
                  <description>The block whose class scope is returned for its source file definition.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Makes and returns a string that is the template declaration for the given block. The template declaration is found by finding the first parent of the given block that contains template blocks and creating the declaration from those blocks. If no templates are found before the first namespace block is encountered then an empty string is returned.</description>
                <name>makeTemplateDeclaration</name>
                <operation>Make sure the given block pointer is not null.</operation>
                <operation>Iterate through the parents of the given block.</operation>
                <operation>If the parent is a namespace block then stop iterating through parents.</operation>
                <operation>Else if the parent block contains template child blocks then return its declarative template arguments string.</operation>
                <operation>Iterate to the next parent.</operation>
                <operation>No template arguments were found so return an empty string.</operation>
                <return_description>Template declaration for the given block or an empty string if no templates are found.</return_description>
                <static/>
                <type>QString</type>
              </data>
              <variable>
                <data>
                  <description>The block whose template declaration is returned.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Makes and returns a string that is the template arguments of the given block. The string can either be in normal form or declarative form. The normal form is meant to be appended to block's name while the declarative is meant to be added before the name. If the given block has no templates then an empty string is returned.</description>
                <name>makeTemplateArguments</name>
                <operation>Make sure the given block pointer is not null.</operation>
                <operation>Create a new return string.</operation>
                <operation>Get the given block's list of template block children and make sure it is not empty.</operation>
                <operation>Append the opening carrot, including the template declaration if this is declarative.</operation>
                <operation>Iterate through the list of template block children.</operation>
                <operation>Check to see if this is the first argument.</operation>
                <operation>Else this is not the first argument so append a separating comma.</operation>
                <operation>Append the template child block's name, including its type if this is declarative.</operation>
                <operation>Append the closing carrot.</operation>
                <operation>Return the template arguments string.</operation>
                <return_description>Template arguments of the given block in normal or declarative form. An empty string if the given block has no templates.</return_description>
                <static/>
                <type>QString</type>
              </data>
              <variable>
                <data>
                  <description>The block whose child template blocks are used to make the returned template arguments string.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>True to make the returned string in declarative form or false to make it in normal form.</description>
                  <initializer>false</initializer>
                  <name>declarative</name>
                  <type>bool</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Constructs a new base parser with the given parser as its parent. The base parser is designed so it cannot be a root parser and must have a parent.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The parent parser for this new base parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface. This implementation does nothing and overrides its interface with the final keyword because base classes should use their more specialized output interfaces.</description>
                <final/>
                <name>makeOutput</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
        </class>
        <class>
          <data>
            <description>This is the global header parser. This parses a global header file which provides a list of forward declarations for all classes in the namespace the header file represents. This parser does not actually parse its file instead simply overwriting it with the appropriate forward declarations. This is inherited by the source and header parser classes for its namespace nesting output functionality.</description>
            <name>Global</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>AbstractParser</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new global parser with the given namespace block as its root.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The namespace block used as the root of this parser representing its file.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <name>readLine</name>
                <operation>This parser only overwrites its file so do nothing and return false.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description></description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <name>makeOutput</name>
                <operation>Add a single blank line to output.</operation>
                <operation>Add the namespace declarations and open brackets to output, excluding the namespace of this parser.</operation>
                <operation>If the namespace of this parser is not the root namespace then add it's comments to output.</operation>
                <operation>If the namespace of this parser is not the root block then add it.</operation>
                <operation>Iterate through a list of all children class blocks of the namespace of this parser.</operation>
                <operation>If the class block has no templates then add its forward declaration to output.</operation>
                <operation>Add all closing brackets for all namespace declarations to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Adds namespace declarations to output with the opening bracket but NO closing bracket. This also adds indents for each new namespace declaration. This can ignore the very last namespace, not adding its declaration, if the given flag says so. The last namespace is the namespace of this parser.</description>
                <name>beginNamespaceNesting</name>
                <operation>Create a pointer stack.</operation>
                <operation>Iterate through the parents of this parser object's namespace, starting with itself.</operation>
                <operation>If the current parent is a namespace then push it onto the stack.</operation>
                <operation>Move to the next parent.</operation>
                <operation>Iterate through the stack, popping each namespace and adding its declaration to output. Only add the last namespace block's declaration if the given flag is set correctly.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>True to make the last namespace declaration, the namespace of this parser, added to output or false to ignore it.</description>
                  <initializer>true</initializer>
                  <name>outputLast</name>
                  <type>bool</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds the closing brackets for all namespace declarations to output. This also removes the indenting for each opening bracket.</description>
                <name>endNamespaceNesting</name>
                <operation>While the depth is greater than zero.</operation>
                <operation>Remove a single indent spacing from this parser.</operation>
                <operation>Output a closing bracket line and decrease the depth by one.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Adds a single namespace declaration to output using the given namespace block. This also adds indentation after the opening bracket. This does NOT add the closing bracket.</description>
                <name>outputNamespace</name>
                <operation>Add the namespace declaration line and then an opening bracket line to output.</operation>
                <operation>Add a single indent spacing to this parser and increment the depth.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description></description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
            </function>
            <variable>
              <data>
                <description>The namespace block represented by the file of this parser.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>const Namespace*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The global indent spaces setting.</description>
                <initializer></initializer>
                <name>_indentSpaces</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of namespace declarations outputted without closing brackets by this parser.</description>
                <initializer>0</initializer>
                <name>_depth</name>
                <type>int</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the source parser. This parses a source file for a class or namespace. Because header files can be as complicated as source files in C++ this class is designed to be inherited by the header class with additional interfaces to alter its functionality. The additional interfaces mainly deal with evaluating children blocks and reading the top of the file.

A source file is separated into three sections. The preprocessor, header, and definition sections in that order. The preprocessor section has all preprocessor statements most commonly being include statements. The header section has any using statements. The definition section has all variable and function definitions.

The lines of code inside any function present in the source file is saved and matched to any known function of the parser object's namespace. If the function is unknown it is also saved and marked as an unknown function after the defined ones in the definition section.</description>
            <name>Source</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Global</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new source parser with the given namespace block and file name.</description>
                <explicit/>
                <name>^</name>
                <operation>Set the include statement used for including the header file of this source file.</operation>
                <operation>Make the default using namespace declaration for the scope of this source file's variables and functions.</operation>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The namespace block that is used to generate the parsing of this parser object's file. This could also possibly be a class block.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The file name that this object parses, excluding the extension.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>initialize</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>readLine</name>
                <operation>If this line is the beginning of comments then mark it for this parser.</operation>
                <operation>Else if this line is the ending of comments then mark it for this parser.</operation>
                <operation>Else check if the given line is not currently within comments.</operation>
                <operation>If the given line is the indicator for being past the top of the file then mark it for this parser.</operation>
                <operation>If the given line is not past the top then call the read top interface.</operation>
                <operation>Check to see if the given line is the beginning of a function definition.</operation>
                <operation>Check to see if this function is defined in the namespace of this parser.</operation>
                <operation>Set the function parser cut off and then step into it for read line processing.</operation>
                <operation>Else this is an undefined function found in the source file.</operation>
                <operation>Add a new undefined function parser and then step into it for read line processing.</operation>
                <operation>Always return true so the entire file is parsed.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <name>makeOutput</name>
                <operation>Add the include statement for this source file's header to the output.</operation>
                <operation>Add any additional preprocessor lines to the output.</operation>
                <operation>Add the header section to the output.</operation>
                <operation>Add the default using namespace declaration for this object's namespace if it is not an empty string, adding blank header lines if the header section was empty.</operation>
                <operation>Add the end of top separator.</operation>
                <operation>Add all function definitions to the output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>This interface is called for each line of the preprocessor and header sections of this object's parsed file. This can be used to remember custom information for output. The default implementation remembers any custom preprocessor statements and using namespace statements.</description>
                <name>readTop</name>
                <operation>If the given line is a preprocessor statement and it is not the default include statement then add it as a custom preprocessor line.</operation>
                <operation>If the given line is a using namespace statement and it is not the default using statement then add it as a custom header line.</operation>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>The line from the preprocessor or header section of this object's file.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>This interface is called to process all real children variable blocks of this object's namespace. This processing occurs before any parsing and is meant to add them to this parser for output. All blocks for evaluate interfaces are called in the same order they appear in their real children list. The default implementation adds them if they belong in the source file.</description>
                <name>evaluateVariable</name>
                <operation>If the given variable block should have its definition in its source file then create a new parser and add it to this parser.</operation>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>The real child variable block of this object's namespace to be evaluated.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Variable*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>This interface is called to process all real children function blocks of this object's namespace. All specialized functions such as constructors or signals are included. This processing occurs before any parsing and is meant to add them to this parser for output. All blocks for evaluate interfaces are called in the same order they appear in their real children list. The default implementation adds them if they belong in the source file.</description>
                <name>evaluateFunction</name>
                <operation>If the given function block should have its definition in its source file then create a new parser and add it to this parser.</operation>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>The real child function block of this object's namespace to be evaluated.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Function*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>This interface is called to process all real children blocks that are not variables or functions of this object's namespace. This processing occurs before any parsing and is meant to add them to this parser for output. All blocks for evaluate interfaces are called in the same order they appear in their real children list. The default implementation does nothing.</description>
                <name>evaluateOther</name>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>The real child block that is not a variable or function of this object's namespace to be evaluated.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>AbstractBlock*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new source parser with the given namespace block. This constructor is only meant to be used internally by this class or the header class that inherits from this one.</description>
                <explicit/>
                <name>^</name>
                <operation>Make sure the given namespace pointer is not null.</operation>
                <operation>If the given namespace block is a class then determine if it has any templates.</operation>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The namespace or class block that is used to generate the parsing of this parser object's file.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds all preprocessor lines to output.</description>
                <name>outputPreProcessor</name>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Adds all header section lines to output. </description>
                <name>outputHeader</name>
                <operation>Make sure the header section is not empty.</operation>
                <operation>Add blank header lines and then add all header statement lines.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Adds all variable and function definitions to output.</description>
                <name>outputDefinitions</name>
                <operation>Check to see if there are any variable definitions to add.</operation>
                <operation>Add blank header lines to output.</operation>
                <operation>Iterate through all of this object's variable definitions.</operation>
                <operation>Add the comments and then the definition of the variable parser to output.</operation>
                <operation>Iterate through all defined function definitions.</operation>
                <operation>Add blank function lines, then the function's comments, and then its definition to output.</operation>
                <operation>Iterate through all undefined function definitions.</operation>
                <operation>Add blank function lines, then the function's comments, and then its definition to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Attempts to find a defined function definition of this parser with the given definition string. If a match is found its function parser pointer is returned.</description>
                <name>findDefined</name>
                <operation>Iterate through all defined function parser objects of this parser.</operation>
                <operation>If the function parser matches the given definition header then return its pointer.</operation>
                <operation>No match was found so return null.</operation>
                <return_description>Pointer of matched function parser if match is found or null if no match is found.</return_description>
                <type>Function*</type>
              </data>
              <variable>
                <data>
                  <description>The function definition header whose match is looked for in this object's list of defined function parser objects.</description>
                  <initializer></initializer>
                  <name>definition</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <const/>
                <description>Returns a constant reference to the pointer list of all real children of this object's namespace block.</description>
                <name>children</name>
                <return_description>Constant reference to this object's namespace block's real children.</return_description>
                <type>const QList&lt;AbstractBlock*>&amp;</type>
              </data>
            </function>
            <function>
              <data>
                <description>Adds a preprocessor line to the preprocessor section of this parser that will be added to that section's output.</description>
                <name>addPreProcess</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The preprocessor line that is added.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds a header line to the header section of this parser that will be added to that section's output.</description>
                <name>addHeader</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The header line that is added.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds a variable parser to this parser that will be used for the definition section output. This does not take ownership of the variable parser object.</description>
                <name>addVariable</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>Pointer to the variable parser added to this parser for its definition section output.</description>
                  <initializer></initializer>
                  <name>parser</name>
                  <type>Variable*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds a defined function parser to this parser that will be used for the definition section output. This does not take ownership of the function parser object.</description>
                <name>addDefined</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>Pointer to the defined function parser added to this parser for its definition section output.</description>
                  <initializer></initializer>
                  <name>defined</name>
                  <type>Function*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds an undefined function parser to this parser that will be used for the definition section output. This does not take ownership of the function parser object.</description>
                <name>addUndefined</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>Pointer to the undefined function parser added to this parser for its definition section output.</description>
                  <initializer></initializer>
                  <name>undefined</name>
                  <type>Function*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <const/>
                <description>Tests if the namespace of this parser has any templates in itself or any parent class blocks. If it does this obviously means it is a class.</description>
                <name>isTemplate</name>
                <return_description>True if the namespace of this parser contains any templates or false otherwise.</return_description>
                <type>bool</type>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Makes the default using namespace declaration for this source file.</description>
                <name>makeUsingName</name>
                <operation>Initialize a namespace pointer stack.</operation>
                <operation>Iterate up the parent blocks of this object's namespace block, starting with its parent.</operation>
                <operation>If the current parent is a namespace block then push its pointer to the stack.</operation>
                <operation>Iterate up to the next parent.</operation>
                <operation>Make sure the stack has more than one pointer. If it only has one pointer that means the namespace of this parser is in the global namespace and no default using statement is required.</operation>
                <operation>Pop the root namespace pointer from the stack.</operation>
                <operation>Append the beginning of the using declaration, then all found namespaces in the stack, and then this object's namespace.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Evaluates all real children of this object's namespace, calling the appropriate evaluate interface on each one.</description>
                <name>evaluateAll</name>
                <operation>Iterate through all real children of this object's namespace.</operation>
                <operation>If the child is a variable block then call its evaluate interface.</operation>
                <operation>Else if the child is any type of function block then call its evaluate interface.</operation>
                <operation>Else this is another type of block so call its evaluate interface.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <variable>
              <data>
                <description>The namespace or class block used as a root for the file this object parses.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>const Namespace*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of blank lines before each header setting.</description>
                <initializer></initializer>
                <name>_headerLines</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of blank lines before function definitions setting.</description>
                <initializer></initializer>
                <name>_functionLines</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Pointer list of all real children of this object's namespace block.</description>
                <initializer></initializer>
                <name>_children</name>
                <type>QList&lt;AbstractBlock*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of preprocessor lines that is added to the preprocessor section of output.</description>
                <initializer></initializer>
                <name>_preProcess</name>
                <type>QStringList</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of header lines that is added to the header section of output.</description>
                <initializer></initializer>
                <name>_header</name>
                <type>QStringList</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Pointer list of variable parser objects that is used to create their definitions for output.</description>
                <initializer></initializer>
                <name>_variables</name>
                <type>QList&lt;Variable*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Pointer list of defined function parser objects that is used to create their definitions for output. Defined here means that a match was found in a real child function block of this object's namespace.</description>
                <initializer></initializer>
                <name>_defined</name>
                <type>QList&lt;Function*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Pointer list of undefined function parser objects that is used to create their definitions for output. Undefined here means that a match was not found in the real child function blocks of this object's namespace.</description>
                <initializer></initializer>
                <name>_undefined</name>
                <type>QList&lt;Function*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if this parser is finished reading in lines for the preprocessor and header sections of its file or false if it is past those sections.</description>
                <initializer>false</initializer>
                <name>_pastTop</name>
                <type>bool</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if this object's namespace or any of its parent classes contain a template or false otherwise. By simple logic this being true also means this object's namespace is a class.</description>
                <initializer>false</initializer>
                <name>_isTemplate</name>
                <type>bool</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if the lines being read in are inside a comment or false otherwise. This is used to safely ignore function signatures in comments.</description>
                <initializer>false</initializer>
                <name>_inComments</name>
                <type>bool</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The default using namespace declaration for this object's source file. If this source file is in global scope then this is empty.</description>
                <initializer></initializer>
                <name>_usingName</name>
                <type>QString</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The default include statement used to include the header file of this object's source file.</description>
                <initializer></initializer>
                <name>_include</name>
                <type>QString</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the header parser. This parses a header file for a class or namespace. Because header files can be as complicated as source files in C++ this inherits the source parser class.

A header file is separated into four sections. The preprocessor, header, declaration, and definition sections in that order. The preprocessor section has the header guard and any other preprocessor statements. The header section has any custom forward class declarations. The declaration section contains the actual declarations of the class or namespace. The definition section contains any template definitions for variables and functions. The declaration and definition sections are nested inside their respective namespace scope.

Lines of code inside functions are parsed and remembered just like it is in the inherited source parser class.</description>
            <name>Header</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Source</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new header parser with the given namespace block as its root and the name of the header file is parses.</description>
                <explicit/>
                <name>^</name>
                <operation>Create the two preprocessor lines that guard this header file from being included more than once.</operation>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The namespace block this parser uses as its root.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The name, excluding the extension, of the header file this object parses.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>makeOutput</name>
                <operation>Add the preprocessor header guard lines to output.</operation>
                <operation>Add the preprocessor section to output.</operation>
                <operation>Add the header section and then the end of top marker to output.</operation>
                <operation>Add blank header lines and then the opening bracket namespace nesting to output.</operation>
                <operation>Add the declaration and then the definition sections to output.</operation>
                <operation>Add the closing bracket namespace and then the final preprocessor header guard line to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface.</description>
                <final/>
                <name>readTop</name>
                <operation>If this is a custom preprocessor line that is not a header guard line then add it as a custom preprocessor line.</operation>
                <operation>Else if this is a custom forward class declaration then add it as a custom header line.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface.</description>
                <final/>
                <name>evaluateVariable</name>
                <operation>Create a new variable parser from the given variable block and append it to this object's declarations.</operation>
                <operation>If the given variable block should have its definition in its header file then add its parser to this parser.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Variable*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface.</description>
                <final/>
                <name>evaluateFunction</name>
                <operation>Create a new function parser from the given function block and append it to this object's declarations.</operation>
                <operation>If the given block has the correct attributes to be defined in the header file then add its parser to the definitions section.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Function*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface.</description>
                <final/>
                <name>evaluateOther</name>
                <operation>If the given block is an enumeration then create an enumeration parser and append it to this object's declarations.</operation>
                <operation>Check to see if this object's namespace is a class.</operation>
                <operation>If the given block is an access type then create an access parser and append it to this object's declarations.</operation>
                <operation>Else if the given block is a class then create a forward parser and append it to this object's declarations.</operation>
                <operation>Else if the given block is a using or friend block then create a declarative parser and append it to this object's declarations.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>AbstractBlock*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Adds the preprocessor header guard lines to output. This does not include the ending statement to finish the guard which is done later.</description>
                <name>outputGuard</name>
                <operation>Add the first and then second preprocessor guard lines.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Adds the declaration section of this parser to output.</description>
                <name>outputDeclarations</name>
                <operation>Make sure the declaration list is not empty.</operation>
                <operation>Get a pointer to this object's namespace as a class if it is a class, else this will be null.</operation>
                <operation>Check to see if this object's namespace is a class.</operation>
                <operation>Add the comments and declaration header of this object's class to output.</operation>
                <operation>Add the opening class bracket to output and increase the indent spaces.</operation>
                <operation>If this object's class is a qt object then add the appropriate macro to output.</operation>
                <operation>Iterate through the list of all base declaration parser object's for this parser and add their output.</operation>
                <operation>Check to see if this object's namespace is a class again.</operation>
                <operation>Decrease the indent spaces and then add the closing class bracket to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Adds the comments of the given class block to output. The given class is assumed to be this object's namespace which is a class.</description>
                <name>outputClassComments</name>
                <operation>Add the beginning comment line to output.</operation>
                <operation>Add the description comment to output, including template argument comments if the given class has any.</operation>
                <operation>Add the ending comment line to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description></description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Class*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds the class declaration header line to output using the given class block.</description>
                <name>outputClassDeclaration</name>
                <operation>Create the line starting with any possible template declaration, adding a space if there is one.</operation>
                <operation>Append the class keyword and then the scoped class name to the line.</operation>
                <operation>Iterate through all children of the given class block.</operation>
                <operation>Make sure the child is a parent block type.</operation>
                <operation>Check to see if this is the first parent being added to the line.</operation>
                <operation>Append the beginning of parents marker to the line.</operation>
                <operation>Else this is not the first to append a comma to the line.</operation>
                <operation>Append the full inheritance declaration for the child parent block to the line.</operation>
                <operation>Add the class declaration header line to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description></description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Class*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds the closing preprocessor statement for the header guard.</description>
                <name>outputFooter</name>
                <operation>Add blank header lines and then the closing header guard preprocessor line to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <variable>
              <data>
                <description>The namespace or class block used as a root for the file this object parses.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>const Namespace*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of spaces used for each indent setting.</description>
                <initializer></initializer>
                <name>_indentSpaces</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of blank lines before each header setting.</description>
                <initializer></initializer>
                <name>_headerLines</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Pointer list of base parser objects used to generate the output of this object's declaration section.</description>
                <initializer></initializer>
                <name>_declarations</name>
                <type>QList&lt;Base*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The first preprocessor header guard line for this object's header file.</description>
                <initializer></initializer>
                <name>_guard1</name>
                <type>QString</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The second preprocessor header guard line for this object's header file.</description>
                <initializer></initializer>
                <name>_guard2</name>
                <type>QString</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the main parser. This parses the special main source file that only contains the main function. Because this is a special source file this inherits from the source class. Because this parser is only responsible for the single main function the namespace block it is given must be the root block of its project.</description>
            <name>Main</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Source</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new main parser with the given root namespace block.</description>
                <explicit/>
                <name>^</name>
                <operation>Make sure the given namespace block is the root block for its project.</operation>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The root namespace block of the project used to find the special main function. This must be the root namespace as the main function is global.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>makeOutput</name>
                <operation>Add any additional preprocessor lines to the output.</operation>
                <operation>Add the header section to the output.</operation>
                <operation>Add the end of top separator.</operation>
                <operation>Add all function definitions to the output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface. This implementation does nothing because it is only interested in finding one special function block.</description>
                <final/>
                <name>evaluateVariable</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Variable*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface.</description>
                <final/>
                <name>evaluateFunction</name>
                <operation>Make sure the main function has not already been found.</operation>
                <operation>Check to see if the given function block's name matches main.</operation>
                <operation>Check to see if the arguments for the given block matches the signature of main.</operation>
                <operation>This is the main function block so add it to this object's definitions and mark that the main function has been found.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Function*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Source_ interface. This implementation does nothing because it is only interested in finding one special function block.</description>
                <final/>
                <name>evaluateOther</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>AbstractBlock*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <variable>
              <data>
                <description>True if this parser found the main function block and added it to its definitions or false otherwise. This is used so only a single main function is added to its definitions.</description>
                <initializer>false</initializer>
                <name>_found</name>
                <type>bool</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the base variable parser. This base parser is responsible for parsing variables within source and header files. This only adds output without reading in any lines because variables do not require any input parsing.</description>
            <name>Variable</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Base</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Base_ interface.</description>
                <final/>
                <name>outputComments</name>
                <operation>Add a beginning comment line, then the description of this object's variable, and then an end comment line to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Base_ interface.</description>
                <final/>
                <name>outputDeclaration</name>
                <operation>Add the comment lines to output.</operation>
                <operation>Create a new line string.</operation>
                <operation>Add any set or required flags of this object's variable.</operation>
                <operation>Add this object's variable type and and then its name separated by a space.</operation>
                <operation>Finish the declaration line and add it to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Base_ interface.</description>
                <final/>
                <name>outputDefinition</name>
                <operation>Make sure this object's variable is static or not a class member.</operation>
                <operation>Create a new line with the template declaration for this object's variable.</operation>
                <operation>Add the thread local flag if this object's variable has it set.</operation>
                <operation>Add this object's variable type and then its scoped name separated by a space.</operation>
                <operation>Finish the definition line and add it to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new variable parser with the given variable block and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The variable block that defines this new variable parser.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Variable*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser for this new variable parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface. This interface does nothing because variables save nothing unique in their parsed files.</description>
                <final/>
                <name>readLine</name>
                <operation>Do nothing and return false.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Finishes the given declaration or definition line for this object's variable, adding the initializer to the line if the given flag is set and this object's variable has an initializer value, and then adding it to output.</description>
                <name>finishOutput</name>
                <operation>Check to see if the with initializer flag is set to true and this object's variable has an initializer value.</operation>
                <operation>Get the initializer value of this object's variable and check to see if the total column size of the line would be greater than the max columns setting.</operation>
                <operation>Add the given line and then an open bracket to output, adding to the indent afterwords.</operation>
                <operation>Split the initializer value by the comma character and iterate through each part.</operation>
                <operation>Add the initializer part to output with a comma added to the beginning if this is not the first part.</operation>
                <operation>Decrease the indent size and add a closing bracket with a semicolon to output.</operation>
                <operation>Else the total column size is not greater than the max columns setting so append the initializer value and then a semicolon, and then add the given line to output.</operation>
                <operation>Else the initializer flag is false or there is no initializer value so append a closing semicolon to the given line and then add it to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>Pointer to the declaration or definition line that is finished and added to output.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>QString*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>True to add this object's variable initializer to the given line if it has one or false to ignore any initializer value.</description>
                  <initializer></initializer>
                  <name>withInitializer</name>
                  <type>bool</type>
                </data>
              </variable>
            </function>
            <variable>
              <data>
                <description>The variable block that defines this variable parser.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>CppQt::Variable*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The max columns per line setting.</description>
                <initializer></initializer>
                <name>_maxColumns</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of spaces used for each indent setting.</description>
                <initializer></initializer>
                <name>_indentSpaces</name>
                <type>int</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the base function parser. This base parser is responsible for parsing functions within source and header files. This also reads in the lines of code for any function found in source or header files. Function definitions can exist in either source or header files in C++ because of templates.

This parser can be defined or undefined. A defined function parser means it is linked with an actual function block. An undefined function parser means it is an unknown function definition found in a source or header file with no associated function block.

This parser also has the concept of a cut off. The cut off is an integer that defines the number of additional spaces the function itself is indented in its file that can be ignored and effectively cut off when parsing the lines of code.</description>
            <name>Function</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Base</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Base_ interface.</description>
                <final/>
                <name>outputComments</name>
                <operation>Check to see if this is a defined function.</operation>
                <operation>Add a comment section to output with the function block's description, then template arguments, then regular arguments, and then return argument.</operation>
                <operation>Else this is not a defined function so add a special comment header highlighting that fact to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Base_ interface. This implementation will also add comments to functions that only appear in the header file, such as abstract or signals. This will output nothing if this is not a defined function.</description>
                <final/>
                <name>outputDeclaration</name>
                <operation>Make sure this is a defined function.</operation>
                <operation>If this object's function is abstract, a signal, or is default then add its comments to output.</operation>
                <operation>Create a new string line with this object's function's template arguments in declarative form, if any.</operation>
                <operation>Add any set flags of this object's function that come before the name.</operation>
                <operation>Add the return type, then name, and then arguments of this object's function to the line.</operation>
                <operation>Add any proceeding flags this object's function has set to the line.</operation>
                <operation>Add the closing semicolon to the line.</operation>
                <operation>Add the declaration line to output.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _CppQt::Parse::Base_ interface.</description>
                <final/>
                <name>outputDefinition</name>
                <operation>Check to see if this is a defined function.</operation>
                <operation>Create a new line with the template declaration for this object's function, if any.</operation>
                <operation>Add the return type, then scoped name, and then arguments of this object's function to the line.</operation>
                <operation>Add any set flags of this object's function that belong in the definition to the line.</operation>
                <operation>If this object has any initializer lines then add the special colon character to the line.</operation>
                <operation>Add the definition line to output.</operation>
                <operation>Else this is not a defined function so add the static string definition to output.</operation>
                <operation>Add all of this object's initializer lines to output.</operation>
                <operation>If this object has no code lines then add an opening and closing bracket to output.</operation>
                <operation>Else this object does have code lines so add them to output with an opening and closing bracket.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new defined function parser with the given function block and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The function block that defines this base function parser.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>CppQt::Function*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser for this new function parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Constructs a new undefined function parser with the given static definition header and parent parser.</description>
                <explicit/>
                <name>^</name>
                <operation>Determine the number of cut off spaces from the given definition header line and then set this object's static definition string.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The static definition header for this new undefined function parser. This should include the entire line so the number of cut off spaces can be calculated.</description>
                  <initializer></initializer>
                  <name>definition</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser for this new function parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Determines if the given line matches the definition header for this function parser, returning true if it is a match. If the function parser already has code or initializer lines, or is not a defined parser then false is always returned.</description>
                <name>isMatch</name>
                <operation>Make sure this object does not have code and is defined.</operation>
                <operation>Create a new regular expression line with this object's function's name.</operation>
                <operation>Add any arguments of this object's function to the regular expression line.</operation>
                <operation>Add any set flags of this object's function that belong in the definition to the regular expression line.</operation>
                <operation>Add the closing syntax to the regular expression line.</operation>
                <operation>Evaluate the line with the constructed regular expression line to determine a match, returning its result.</operation>
                <return_description>True if the given line matches the definition header for this parser or false if it does not, it has code or initializer lines, or is undefined.</return_description>
                <type>bool</type>
              </data>
              <variable>
                <data>
                  <description>The line presumed to be another function definition header that is matched with this function parser.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <const/>
                <description>Tests if this function parser has any code or initializer lines.</description>
                <name>hasCode</name>
                <return_description>True if this function parser has any code or initializer lines or false otherwise.</return_description>
                <type>bool</type>
              </data>
            </function>
            <function>
              <data>
                <description>Sets the number of cut off spaces for this function parser to the given value. The value must be zero or positive.</description>
                <name>setCutOff</name>
                <operation>Make sure the new value is valid.</operation>
                <operation>Set the new value.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The new cut off value for this function parser.</description>
                  <initializer></initializer>
                  <name>value</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>readLine</name>
                <operation>If the given line is a opening and closing bracket that means this function has no code lines so return false.</operation>
                <operation>Check to see if the given line is an opening bracket.</operation>
                <operation>Increment the bracket level by one, returning true if this is the very first opening bracket.</operation>
                <operation>Check to see if the given line is a closing bracket.</operation>
                <operation>Decease the bracket level by one, returning false if this is the final closing bracket.</operation>
                <operation>If this object is outside of any bracket level then add the given line to the object's initializer line list.</operation>
                <operation>Else the given line is inside the main opening and closing brackets.</operation>
                <operation>Check to see if the given line is an inline comment.</operation>
                <operation>If the given inline comment line is the first for its grouping then set this object's edge past to true and process the inline comment. If this is proceeding inline comment lines after the first then just ignore it.</operation>
                <operation>Else the given line is regular code so set this object's edge past to false and add the given line to this object's code line list.</operation>
                <operation>The given line is not the last line of code for this function so return true.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Processes the given inline comment line, adding the next step of operations of this object's function as an inline comment to this object's code line list or a blank inline comment if there are no more steps of operation to use.</description>
                <name>processInlineComment</name>
                <operation>Calculate the number of spaces that should be used for this inline comment grouping.</operation>
                <operation>If the next operation iterator of this object is not past the end of this object's function's steps of operation then insert an inline comment with the next operation.</operation>
                <operation>Else there are no more steps of operation to add as inline comments so add a blank inline comment to this object's code line list.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The inline comment given as an input line from the read line interface. The line must not be modified so the number of spaces can be calculated.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Inserts a new inline comment grouping of lines to this object's code line list with the given steps of operation index and spacing.</description>
                <name>insertInlineComment</name>
                <operation>Split operation from this object's function's steps of operation with the given index into a list of words.</operation>
                <operation>Keep going until the list of words is empty.</operation>
                <operation>Create a total columns used variable with the first word's size plus one space.</operation>
                <operation>Create a new line string, adding spaces then comment characters then the first word from the list and then a space.</operation>
                <operation>Keep going until the word list is empty or the line has reached the maximum number of columns.</operation>
                <operation>Take and add the next word from the list to the line and an additional space, adding the number of columns the addition used.</operation>
                <operation>Add the inline comment line to this object's code line list.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The index of the operation in this object's function's steps of operation to use to generate the inline comment.</description>
                  <initializer></initializer>
                  <name>index</name>
                  <type>int</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The number of spaces added before every inline comment line generated.</description>
                  <initializer></initializer>
                  <name>spacing</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Adds argument comment lines of this object's function to output. This does not add opening or closing comment lines and assumes the output is already in the process of added comments. If this object's function has not arguments then nothing is added to output.</description>
                <name>outputArgumentComments</name>
                <operation>Iterate through all variable block children of this object's function block.</operation>
                <operation>Add an empty comment line to output.</operation>
                <operation>Create a base string that starts with the variable name and a space, getting the justified length from the base string length.</operation>
                <operation>Add the variable block's description to the base string.</operation>
                <operation>Make comments from the base string and the calculated justification and add its lines to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Adds return comment lines of this object's function to output. This does not add opening or closing comment lines and assumes the output is already in the process of added comments. If this object's function has no return description then nothing is added to output.</description>
                <name>outputReturnDescriptionComment</name>
                <operation>Get the return description of this object's function and make sure it is not empty.</operation>
                <operation>Add an empty comment line to output.</operation>
                <operation>Create a base string with the return keyword in it, getting the justified length from the base string length.</operation>
                <operation>Add the return description to the base string.</operation>
                <operation>Make comments from the base string and calculated justification and add its lines to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Makes and returns a string that is the return type for this object's function. The returned string also includes a space after the return type.</description>
                <name>makeReturnValue</name>
                <operation>If this view's function block is a constructor or destructor then return an empty string.</operation>
                <operation>Else this is a function type with a return value so return it with a space appending it.</operation>
                <return_description>Return type for this object's function along with an extra space.</return_description>
                <type>QString</type>
              </data>
            </function>
            <function>
              <data>
                <description>Makes and returns a string that is the function name for this object's function. This is just the name of the function, not including the return type or arguments. This can return a string intended for regular expression matching if the given flag is set to do so.</description>
                <name>makeName</name>
                <operation>Create a new return string that contains the base name of this view's function block.</operation>
                <operation>If the regular expression flag is set then escape the return string in case it has any special characters.</operation>
                <operation>Return the function name string.</operation>
                <return_description>The function name for this object's function, padded with regular expression syntax is set to do so.</return_description>
                <type>QString</type>
              </data>
              <variable>
                <data>
                  <description>True to return the name string with regular expression syntax or false to return a regular string.</description>
                  <initializer>false</initializer>
                  <name>isRegExp</name>
                  <type>bool</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Makes and returns the argument list for this object's function. The returned arguments string includes the opening and closing parenthesis. If the given flag is set to include any initializers of arguments then they are included in the return string.</description>
                <name>makeArguments</name>
                <operation>Create a new return string with the opening parenthesis.</operation>
                <operation>Iterate through all arguments of this object's function block.</operation>
                <operation>If this is not the first argument then add a separating comma and space.</operation>
                <operation>Append the argument type, a space, and its name.</operation>
                <operation>If the with initializers flag is set and this argument has one then add it.</operation>
                <operation>Add the closing parenthesis.</operation>
                <operation>Return the arguments string.</operation>
                <return_description>Argument list for this object's function, including the opening and closing parenthesis and optional initializers if set to do so.</return_description>
                <type>QString</type>
              </data>
              <variable>
                <data>
                  <description>True to include the initializers of any arguments that have then in the returned arguments string or false to ignore them.</description>
                  <initializer></initializer>
                  <name>withInitializers</name>
                  <type>bool</type>
                </data>
              </variable>
            </function>
            <variable>
              <data>
                <description>Pointer to this object's function block if it is defined or null if it is undefined.</description>
                <initializer>nullptr</initializer>
                <name>_block</name>
                <type>CppQt::Function*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The max columns per line setting.</description>
                <initializer></initializer>
                <name>_maxColumns</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Static definition string that contains the definition header for this parser if it is undefined or an empty string if it is defined.</description>
                <initializer></initializer>
                <name>_definition</name>
                <type>QString</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The current number of bracket levels this parser is in while reading in lines. Used for processing input. Each opening bracket is one level up and closing bracket is one level down.</description>
                <initializer>0</initializer>
                <name>_level</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of additional spaces the definition of this object's function has in its file. This is used for processing input.</description>
                <initializer>0</initializer>
                <name>_cutOff</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if an inline comment is currently being read in and the first line of it has already been read or false otherwise.</description>
                <initializer>false</initializer>
                <name>_edgePast</name>
                <type>bool</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The next index to be used in this object's function's steps of operation for inserting inline comments.</description>
                <initializer>0</initializer>
                <name>_nextOperation</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of code lines for this object's function's definition.</description>
                <initializer></initializer>
                <name>_code</name>
                <type>QStringList</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of initializer lines for this object's function's definition. This is exclusively used for constructors.</description>
                <initializer></initializer>
                <name>_initializers</name>
                <type>QStringList</type>
              </data>
            </variable>
          </access>
        </class>
