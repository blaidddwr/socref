      </access>
    </class>
    <class>
      <data>
        <description>This is the abstract item model for the entire block tree of a project, using the Qt abstract item model class. It only implements the interfaces necessary for read only functionality through Qt view classes. However the writable functionality exists with custom functions outside the Qt framework. The custom write operations supported are inserting blocks, moving blocks up and down, removing blocks, copying blocks, and cutting blocks.</description>
        <name>BlockModel</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QAbstractItemModel</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface.</description>
            <final/>
            <name>index</name>
            <operation>If the given row or column is not valid then return an invalid index.</operation>
            <operation>Get the block pointer for the given parent index and make sure the row is within range of its child size.</operation>
            <operation>Return a new index with its internal pointer set to the block pointer.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>QModelIndex</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>row</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>column</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>parent</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface.</description>
            <final/>
            <name>parent</name>
            <operation>Get the block pointer of the given child index, making sure it is not null.</operation>
            <operation>Get the parent of the child block, making sure it is not null and its parent is not null.</operation>
            <operation>Return the given index's parent index using the grandparent to get the parent's row.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>QModelIndex</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>child</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface. This returns the number of children the block with the given index contains.</description>
            <final/>
            <name>rowCount</name>
            <operation>Check if this model has no root block.</operation>
            <operation>Get the block pointer for the given index, returning 0 if it is null or its children size if it is not.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>int</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface. This model always has 1 column.</description>
            <final/>
            <name>columnCount</name>
            <operation>Return 1.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>int</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>parent</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface. This model only implements the display and decoration roles.</description>
            <final/>
            <name>data</name>
            <operation>Get the block pointer for the given index, returning a null qt variant if it is null.</operation>
            <operation>Based off the role return either the block's display name for display role or the block's icon for decoration role. The icon is transformed to a pixel map with specific dimensions.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>QVariant</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>role</name>
              <type>int</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>Constructs a new block model with the  optional parent.</description>
            <explicit/>
            <name>^</name>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The parent for this model.</description>
              <initializer>nullptr</initializer>
              <name>parent</name>
              <type>QObject*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the block pointer the given index represents in this model. If the given index is invalid this model's root block pointer is returned.</description>
            <name>pointer</name>
            <operation>If the given index is valid then return its internal pointer else return this model's root block pointer.</operation>
            <return_description>Block pointer of the given index or the root block pointer if the index is invalid.</return_description>
            <type>Abstract::Block*</type>
          </data>
          <variable>
            <data>
              <description>The index whose block pointer is returned.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Inserts a new block into this model at the beginning of the given index's list of children.</description>
            <name>insert</name>
            <operation>Make sure the given pointer is not null.</operation>
            <operation>Get the parent block pointer to the given index and make sure it is not null.</operation>
            <operation>Insert the given child block at the beginning of the given parent's block's child list, notifying the model of a row insertion and returning success.</operation>
            <return_description>True on success or false on failure.</return_description>
            <type>bool</type>
          </data>
          <variable>
            <data>
              <description>The index where the given block is inserted.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the block that is inserted into this model.</description>
              <initializer></initializer>
              <name>block</name>
              <type>Soc::Ut::QPtr&lt;Abstract::Block>&amp;&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Moves the given index up by one in the list of siblings it is part of. If the given index is already at row 0 then this does nothing. Returns the new index for the given index that was or was not moved.</description>
            <name>moveUp</name>
            <operation>Make sure the given index is valid and is not in the first row.</operation>
            <operation>Get the block pointer from the given index and make sure it is not null.</operation>
            <operation>Get the parent block pointer and make sure it is not null.</operation>
            <operation>Move the block with the given index up by one in it's parent's child list, notifying the model that the row has moved. SPECIAL NOTE: the given index is destroyed when the begin move rows qt function is called.</operation>
            <operation>Return a new index where the given index's block moved.</operation>
            <return_description>New index for the given index that was possibly moved.</return_description>
            <type>QModelIndex</type>
          </data>
          <variable>
            <data>
              <description>The index that will possibly be moved up by 1.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Moves the given index down by one in the list of siblings it is part of. If the given index is already at the end of its list of siblings then this does nothing. Returns the new index for the given index that was or was not moved.</description>
            <name>moveDown</name>
            <operation>Make sure the given index is valid and is not in the last row.</operation>
            <operation>Get the block pointer from the given index and make sure it is not null.</operation>
            <operation>Get the parent block pointer and make sure it is not null.</operation>
            <operation>Move the block with the given index down by one in it's parent's child list, notifying the model that the row has moved. SPECIAL NOTE: the given index is destroyed when the begin move rows qt function is called.</operation>
            <operation>Return a new index where the given index's block moved.</operation>
            <return_description>New index for the given index that was possibly moved.</return_description>
            <type>QModelIndex</type>
          </data>
          <variable>
            <data>
              <description>The index that will possibly be moved up by 1.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Removes the given index and its block for this model. If the index is not given this does nothing and returns false.</description>
            <name>remove</name>
            <operation>Make sure the given index is valid.</operation>
            <operation>Get the block pointer from the given index and make sure it is not null.</operation>
            <operation>Get the parent block pointer and make sure it is not null.</operation>
            <operation>Remove the block with the given index from its parent block, notifying the model that a row was removed and returning success. SPECIAL NOTE: the given index is destroyed when the begin remove rows qt function is called.</operation>
            <return_description>True on success or false on failure.</return_description>
            <type>bool</type>
          </data>
          <variable>
            <data>
              <description>The index that is removed from this model.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns a pointer to a copy of the block at the given index. If the given index is not valid then a null pointer is returned.</description>
            <name>copy</name>
            <operation>If the given index is not valid then return null.</operation>
            <operation>Get the block pointer from the given index and make sure it is not null.</operation>
            <operation>Make a copy of the block with the given index and return its pointer.</operation>
            <return_description>Pointer to a copy of the given index or a null pointer if the given index is invalid.</return_description>
            <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
          </data>
          <variable>
            <data>
              <description>The given index whose block is copied and returned.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Returns a pointer to the block at the given index, removing that index from the model but not deleting its block. Instead the ownership of the block is returned. If the given index is not valid then a null pointer is returned.</description>
            <name>cut</name>
            <operation>Make sure the given index is valid.</operation>
            <operation>Get the block pointer from the given index and make sure it is not null.</operation>
            <operation>Get the parent block pointer and make sure it is not null.</operation>
            <operation>Take the child block with the given index from its parent block, notifying the model that a row was removed and returning the taken block's pointer. SPECIAL NOTE: the given index is destroyed when the begin remove rows qt function is called.</operation>
            <return_description>Pointer to the block at the given index now removed or null pointer if the given index is not valid.</return_description>
            <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
          </data>
          <variable>
            <data>
              <description>The index that is removed from this model and its block returned.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns a read only pointer to the block factory of the project type for this model's blocks. If the model is not set to any block data then a null pointer is returned.</description>
            <name>factory</name>
            <return_description>Read only pointer to black factory for this model's block type or null pointer if this model is empty.</return_description>
            <type>const Abstract::BlockFactory*</type>
          </data>
        </function>
        <function>
          <data>
            <description>Sets a new root block for this model's data. If the given pointer is null then this model is set to be empty with no data to represent.</description>
            <name>setRoot</name>
            <operation>Notify the model that a reset has begun.</operation>
            <operation>Disconnect any previous root block of this model.</operation>
            <operation>Set the new root for this model and its factory to null just in case the new root is null.</operation>
            <operation>Check if the new root is not null.</operation>
            <operation>Set this model's block factory to the one from this model's new root block.</operation>
            <operation>Connect the child updated signal of the new root block to this model.</operation>
            <operation>Notify the model that the reset has ended.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to root block that this model will use or null to set this model as empty.</description>
              <initializer></initializer>
              <name>root</name>
              <type>Abstract::Block*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>private slots:</type>
        </data>
        <function>
          <data>
            <description>Called when the root block contained within this model emits a child updated signal indicating a block with the given pointer within this model has updated itself.</description>
            <name>blockUpdated</name>
            <operation>Get the parent block pointer of the given block, returning immediately if it is the root block.</operation>
            <operation>Determine the index for the given block and signal the data changed for that index and given roles.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to the block whose name has changed.</description>
              <initializer></initializer>
              <name>block</name>
              <type>Abstract::Block*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <variable>
          <data>
            <description>A pointer to the root block for this model's data. If this model is empty then this is null.</description>
            <initializer>nullptr</initializer>
            <name>_root</name>
            <type>Abstract::Block*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>A read only pointer to this model block type's block factory. If this model is empty then this is null.</description>
            <initializer>nullptr</initializer>
            <name>_factory</name>
            <type>const Abstract::BlockFactory*</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This is a scanner that is responsible for parsing an entire source file using a list of parser elements added to it. The parser elements must be added before parsing a source file. A scanner can parse as many times as needed but it should only be used once on the specific file it is meant to be parsing.</description>
        <name>Scanner</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QObject</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>Parses the source file with the given path using this scanner's parser elements, overwriting any contents the file may contain if it is different from the output of the parser elements. If this scanner has no parser elements then this does nothing.</description>
            <name>parse</name>
            <operation>Make sure this scanner has parser elements.</operation>
            <operation>Open the source file with the given path and make sure it works.</operation>
            <operation>Read the entire contents of the opened source file and make sure it worked.</operation>
            <operation>Parse the input for any input parser elements and then create the output using all parser elements.</operation>
            <operation>Check to see if the output is different from the original contents of the open source file.</operation>
            <operation>Truncate the open source file to zero and make sure it worked.</operation>
            <operation>Write the output to the open source file and make sure all bytes were written.</operation>
            <operation>Reset all parser elements of this scanner in case this parses another source file.</operation>
            <operation>Catch any exception thrown to reset all parser elements of this scanner in case it is used again and throw the exception again.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Path of the source file that is parsed and possibly overwritten.</description>
              <initializer></initializer>
              <name>path</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Adds a new parser element to this scanner, taking ownership of it. Parser element output is added in the same order the parser element's are added using this method.</description>
            <name>addParser</name>
            <operation>Take ownership of the given parser and add it to this scanner's list.</operation>
            <operation>If the given parser requires input then add it to this scanner's list for input.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Parser element added to this scanner which also takes ownership of it.</description>
              <initializer></initializer>
              <name>parser</name>
              <type>Soc::Ut::QPtr&lt;Abstract::Parser>&amp;&amp;</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>Parses the input of the original contents of the source file this scanner is parsing, finding any input parser that still requires input by matching its given header expression.</description>
            <name>parseInput</name>
            <operation>Make sure this scanner has parser elements requiring input.</operation>
            <operation>Initialize the current parser pointer taking input to null and create the input lines for parsing from the source file being parsed.</operation>
            <operation>Iterate through all input lines.</operation>
            <operation>Check to see if there is an active parser element parsing the input lines.</operation>
            <operation>Parse the line with the current parser element taking input, resetting the active parser pointer to null if it returns false.</operation>
            <operation>Else there is no active parser element taking input.</operation>
            <operation>Try to find a parser element of this scanner whose header expression matches the line.</operation>
            <operation>Provide the matched header expression line as the first line of input to the parser element that was found.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Creates and returns the output for the source file this scanner is parsing.</description>
            <name>createOutput</name>
            <operation>Construct all lines of output using this scanner's list of parser elements, adding them in order that the parser elements were added.</operation>
            <operation>Combine and return all output lines of output.</operation>
            <return_description>The output for the source file this scanner is parsing.</return_description>
            <type>QString</type>
          </data>
        </function>
        <function>
          <data>
            <description>Attempts to find an parser element of this scanner that requires input and whose header expression matches the given line, returning its pointer if one is found.</description>
            <name>findParser</name>
            <operation>Iterate through all parser elements of this scanner requiring input.</operation>
            <operation>Make sure the parser still requires input.</operation>
            <operation>If the parser element's header expression matches the given line then return its pointer.</operation>
            <operation>No match was found to return null.</operation>
            <return_description>Pointer to matched parser element requiring input or null if no match is found.</return_description>
            <type>Abstract::Parser*</type>
          </data>
          <variable>
            <data>
              <description>The line used to find a match with any parser element's header expression that still requires input.</description>
              <initializer></initializer>
              <name>line</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <variable>
          <data>
            <description>List of parser elements this scanner uses for parsing any source file it is given to parse.</description>
            <initializer></initializer>
            <name>_parsers</name>
            <type>QList&lt;Abstract::Parser*></type>
          </data>
        </variable>
        <variable>
          <data>
            <description>List of parser elements that require reading input lines this scanner uses for parsing any source file it is given to parse.</description>
            <initializer></initializer>
            <name>_inputParsers</name>
            <type>QList&lt;Abstract::Parser*></type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Contains the entire contents of the source file this scanner is parsing before it is overwritten. This is used to process any input lines required by parser elements that need input.</description>
            <initializer></initializer>
            <name>_input</name>
            <type>QString</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This implements the qt thread class and is used to scan and parse an entire directory of source files with the given file filters and mapping of scanner objects. This executes the scanning of files on the separate thread started by the qt thread class. Signals are emitted for the progress of the scanning and if an exception is thrown from within the thread.

Because execution of parsing is done on a separate thread if an exception is thrown within that thread it is caught and emitted as a signal that can be used on the main GUI thread.

The mapping of scanner objects are used to determine which scanner object to use on any matched files found. The key of the mapping is used as the file name to be matched. This thread takes ownership of all scanner objects passed to it in the given map and is destroyed when this thread object is destroyed.</description>
        <name>ScanThread</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QThread</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>Constructs a new scan thread with the given mapping of scanner objects, directory to scan, file filters, and possible parent.</description>
            <explicit/>
            <name>^</name>
            <operation>Set the parent of all scanner objects in the given map to this object.</operation>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The mapping of scanner objects this scan thread uses for parsing all source files it finds.</description>
              <initializer></initializer>
              <name>scanMap</name>
              <type>const QMap&lt;QString,Scanner*>&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The directory that this scan thread will scan for source files.</description>
              <initializer></initializer>
              <name>scanDirectory</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The file filters this scan thread will use for filtering the files in the given scan directory. Only files that match any of these filters will be scanned.</description>
              <initializer></initializer>
              <name>filters</name>
              <type>const QStringList&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The parent of this object if any.</description>
              <initializer>nullptr</initializer>
              <name>parent</name>
              <type>QObject*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>signals:</type>
        </data>
        <function>
          <data>
            <description>Signals that the progress of this scan thread has changed to the percentage given.</description>
            <name>progressChanged</name>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The percent complete of this scan thread out of one hundred.</description>
              <initializer></initializer>
              <name>index</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Signals that an exception was thrown and caught in this thread, prematurely ending the scanning of source files in this thread.</description>
            <name>exceptionThrown</name>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The exception that was thrown and caught in this thread.</description>
              <initializer></initializer>
              <name>e</name>
              <type>const Exception&amp;</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>protected:</type>
        </data>
        <function>
          <data>
            <description>Implements _QThread_ interface. This iterates through all files to be parsed and parses them, constantly checking for any requested interruption.</description>
            <final/>
            <name>run</name>
            <operation>Initialize the percent complete to zero and create the list of files to be matched with scanners.</operation>
            <operation>Iterate through the list of files to possibly be scanned.</operation>
            <operation>Check to see if interruption of this thread is requested.</operation>
            <operation>Attempt to find a scanner object on this thread's mapping that matches the file name.</operation>
            <operation>If a scanner object was found then scan the current file with it.</operation>
            <operation>Calculate percent complete and check to see if it has changed since last time.</operation>
            <operation>Update the percent complete and emit the progress changed signal.</operation>
            <operation>Catch any exception thrown within this thread and emit it as a signal.</operation>
            <override/>
            <return_description></return_description>
            <type>void</type>
            <virtual/>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>creates and returns a list of files that match the given given scan directory and file filters. A file must match only one file filter to be added to the list of matched files.</description>
            <name>createList</name>
            <operation>Initialize the return list.</operation>
            <operation>Get the scan directory from the given path and make sure it exists.</operation>
            <operation>Make a list of files in the scan directory with the given filters and iterate through them all.</operation>
            <operation>If the file is a directory then recursively call this method on that directory else add the file to this object's list of files to be parsed.</operation>
            <operation>Return the list of matched files.</operation>
            <return_description>List of files that match the given scan directory and filters.</return_description>
            <static/>
            <type>QFileInfoList</type>
          </data>
          <variable>
            <data>
              <description>The directory where files will be matched and added to the returned list.</description>
              <initializer></initializer>
              <name>scanDirectory</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The filters that are used to match files. Each string in this list must be a single filter.</description>
              <initializer></initializer>
              <name>filters</name>
              <type>const QStringList&amp;</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <variable>
          <data>
            <description>The mapping of scanner objects this scan thread uses for parsing all source files it finds.</description>
            <initializer></initializer>
            <name>_scanMap</name>
            <type>const QMap&lt;QString,Scanner*></type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The directory that this scan thread will scan for source files.</description>
            <initializer></initializer>
            <name>_scanDirectory</name>
            <type>const QString</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The file filters this scan thread will use for filtering the files in the given scan directory. Only files that match any of these filters will be scanned.</description>
            <initializer></initializer>
            <name>_filters</name>
            <type>const QStringList</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This is a dictionary list model. This stores a list of unique words sorted alphabetically and provides a method for testing if it contains a given word. This is intended to be used to store a custom set of spell checker words on a per project bases. Copies of words cannot be stored in this model. The data of this model can be written or saved using XML elements.</description>
        <name>DictionaryModel</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QAbstractListModel</class>
        </data>
      </parent>
      <access>
