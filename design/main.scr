               <variable type="1">
                  <data version="1">
                     <name>_moveDownAction</name>
                     <description>Pointer to this object's move down action.</description>
                     <type>QAction*</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="1">
                     <name>_addMenu</name>
                     <description>Pointer to this object's add menu used as a sub menu within the context menu for listing add actions.</description>
                     <type>QMenu*</type>
                  </data>
               </variable>
