              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>This casts this block to a specific block type. If the given type does not match this block's type then a null pointer is returned. If this object fails to cast as the requested type an exception is thrown.</description>
              <name>cast</name>
              <operation>Make sure the given type matches this block's type.</operation>
              <operation>Cast this block to the given type and make sure it works.</operation>
              <operation>Return the type casted  pointer.</operation>
              <return_description>If successful then a read only pointer of requested cast type, else a null pointer.</return_description>
              <type>const T*</type>
            </data>
            <template>
              <data>
                <description>The class type that is cast.</description>
                <name>T</name>
                <type>class</type>
              </data>
            </template>
            <variable>
              <data>
                <description>The block type that this block is cast to.</description>
                <initializer></initializer>
                <name>toType</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Writes out this block's data as an XML element. This includes all children as child XML elements which have their write functions called recursively.</description>
              <name>write</name>
              <operation>Create the data element for this bock's data.</operation>
              <operation>Create a new element that will contain this block's data and all children.</operation>
              <operation>Add the data element for the return element.</operation>
              <operation>Add all of this block's children elements.</operation>
              <operation>Return the element containing all data and children of this block.</operation>
              <return_description>XML element that stores this block's data and all children underneath it.</return_description>
              <type>QDomElement</type>
            </data>
            <variable>
              <data>
                <description></description>
                <initializer></initializer>
                <name>document</name>
                <type>QDomDocument&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This returns the root block in this block's tree structure. The root block is the common parent of all other blocks that has no parent itself.</description>
              <name>root</name>
              <operation>Iterate up the tree of parents until the root pointer is found.</operation>
              <operation>Return the root pointer.</operation>
              <return_description>Pointer to the root block.</return_description>
              <type>Abstract::Block*</type>
            </data>
          </function>
          <function>
            <data>
              <description>This casts this block to a specific block type. If the given type does not match this block's type then a null pointer is returned. If this object fails to cast as the requested type an exception is thrown.</description>
              <name>cast</name>
              <operation>Make sure the given type matches this block's type.</operation>
              <operation>Cast this block to the given type and make sure it works.</operation>
              <operation>Return the type casted pointer.</operation>
              <return_description>If successful then a pointer of requested cast type, else a null pointer.</return_description>
              <type>T*</type>
            </data>
            <template>
              <data>
                <description>The class type that is cast.</description>
                <name>T</name>
                <type>class</type>
              </data>
            </template>
            <variable>
              <data>
                <description>The block type that this block is cast to.</description>
                <initializer></initializer>
                <name>toType</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Moves the child block with the given index up the list by one where the very top of the list is index 0. If the given index is already at the top of the list or out of range then this does nothing.</description>
              <name>moveUp</name>
              <operation>Make sure the given index is within range and not already at the top of the list.</operation>
              <operation>Swap the child pointer at the given index with the pointer directly above it in this block's child list and notify of modification.</operation>
              <operation>Starting with this block iterate up the tree of parents, calling their child moved interface, until the root block is reached or the child moved interface returns false.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The index of the child block moved up by one.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Moves the child block with the given index down the list by one where the very top of the list is index 0. If the given index is already at the bottom of the list or out of range then this does nothing.</description>
              <name>moveDown</name>
              <operation>Make sure the given index is within range and not already at the bottom of the list.</operation>
              <operation>Swap the child pointer at the given index with the pointer directly below it in this block's child list and notify of modification.</operation>
              <operation>Starting with this block iterate up the tree of parents, calling their child moved interface, until the root block is reached or the child moved interface returns false.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The index of the child block moved down by one.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Inserts a new child block into this block's list of children at the given index. If the given index is less than 0 it is prepended to this block's list, else if the given index is greater than this block's list size then it is appended. If the given pointer to the new block is null or it is a type this block cannot contain then an exception is thrown.</description>
              <name>insert</name>
              <operation>Make sure the given pointer is not null.</operation>
              <operation>Make sure the given block's type can be a child of this block.</operation>
              <operation>Insert the given block as a child of this block at the given index and notify of modification.</operation>
              <operation>Starting with this block iterate up the tree of parents, calling their child added interface, until the root block is reached or the child added interface returns false.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The index where the new block is inserted.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Pointer to the new block that is inserted as this block's child.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Soc::Ut::QPtr&lt;Block>&amp;&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Takes the child block at the given index this block contains. The child block returned no longer has a parent. If the index is out of range then an exception is thrown.</description>
              <name>take</name>
              <operation>Make sure the given index is within range.</operation>
              <operation>Remove the child from this block's child list at the given index, saving the pointer and notifying of modification.</operation>
              <operation>Starting with this block iterate up the tree of parents, calling their child removed interface, until the root block is reached or the child removed interface returns false.</operation>
              <operation>Return the removed child pointer.</operation>
              <return_description>Pointer to child that was taken from this block.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
            </data>
            <variable>
              <data>
                <description>The index of the child that is taken.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Removes the child block at the given index, deleting it and any children it may contain. If the given index is out of range then an exception is thrown.</description>
              <name>remove</name>
              <operation>Take this block's child from the given index and delete it.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The index of the child that is removed and deleted.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Reads in block data from an XML element. This clears any existing data this block contains, including the removal and deletion of all existing children. This recursively adds any children contained in the XML reading in their data from child XML elements.</description>
              <name>read</name>
              <operation>Delete and clear any existing children this block may contain.</operation>
              <operation>Iterate through all children nodes of the given element.</operation>
              <operation>Check if the node is an element.</operation>
              <operation>If the tag name is the data tag then read in this block's data else read in the element as a new child for this block.</operation>
              <operation>Move to the next node sibling.</operation>
              <operation>Make sure all children of this block is allowed to this block's child list.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The XML element that stores block data this block reads as input.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>signals:</type>
          </data>
          <function>
            <data>
              <description>Signals that this block has been updated and any view attached to it must update this block's display.</description>
              <name>updated</name>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Signals that a child block of this block has been updated. The given child block could be any depth below this block. Only the root block emits this signal.</description>
              <name>childUpdated</name>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The child block which has been updated.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <abstract/>
              <description>This interface reads in the data for this block from the given XML element, overwriting any data this block currently holds.</description>
              <name>readData</name>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>The XML element used to read in this blocks data.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns a XML element containing the data for this block using the current version number. Attributes should never be used with this element because of their indeterminate nature.</description>
              <name>writeData</name>
              <return_description>XML element containing the data of this block.</return_description>
              <type>QDomElement</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>XML document to use for creating new elements.</description>
                <initializer></initializer>
                <name>document</name>
                <type>QDomDocument&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface creates and returns a new block object of this block's type with no data and returns a pointer to the new block.</description>
              <name>createBlank</name>
              <return_description>The newly created blank block.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <description>This interface copies all data from the given block to this block, overwriting any data this block may already contain. This does not copy any children.</description>
              <name>copyDataFrom</name>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>The other block whose data will be copied.</description>
                <initializer></initializer>
                <name>other</name>
                <type>const Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This interface is called whenever a child below this block has updated itself. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
              <name>childIsUpdated</name>
              <operation>Return false.</operation>
              <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Pointer to the child block that has modified its name.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This interface is called whenever a new child below this block has been added. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
              <name>childAdded</name>
              <operation>Return false.</operation>
              <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Pointer to the child block that been added to its new parent block.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This interface is called whenever an existing child below this block has been removed. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
              <name>childRemoved</name>
              <operation>Return false.</operation>
              <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Pointer to the child block that has been removed from its former parent block. This object can be deleted right after this call.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This interface is called whenever an existing child below this block has been moved. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
              <name>childMoved</name>
              <operation>Return false.</operation>
              <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Pointer to the child block that has been moved in its parent's list of children.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Notifies that this block's data has been updated and any view attached to this block must update itself.</description>
              <name>update</name>
              <operation>Emit this blocks updated signal.</operation>
              <operation>Get a pointer to this block's parent block.</operation>
              <operation>Starting with this block's parent iterate up the tree of parents, calling their child is updated interface, until the root block is reached or the interface returns false.</operation>
              <operation>Find the root block of this block and emit its child updated signal.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Copies all children from the given block and appends the copies to the list of this block's children. This does not remove any previous children already part of this block.</description>
              <name>copyChildren</name>
              <operation>Iterate through all the children of the given block.</operation>
              <operation>Make a copy of the child and append it to this block.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>Pointer to block whose children are copied.</description>
                <initializer></initializer>
                <name>parent</name>
                <type>const Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Creates a new child reading it in from the given XML element. The new child is then appended to this block's list of children.</description>
              <name>readChild</name>
              <operation>Read in the type attribute from the given child element.</operation>
              <operation>Make sure reading in the type did not fail.</operation>
              <operation>Make sure the read in type is within range of this block's factory.</operation>
              <operation>Create a new block with the read in type and make sure it worked.</operation>
              <operation>Take ownership of the new child block and append it to this block's child list.</operation>
              <operation>Have the new block read in its data and children from the given element.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>XML element used to read in the new child.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The name for version attributes.</description>
              <initializer>"version"</initializer>
              <name>_versionTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for data elements.</description>
              <initializer>"data"</initializer>
              <name>_dataTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The name for type attributes.</description>
              <initializer>"type"</initializer>
              <name>_typeTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer list of this block's children.</description>
              <initializer></initializer>
              <name>_children</name>
              <type>QList&lt;Block*></type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This represents a label that displays the data of a block. This connects to the block it represents and updates its label whenever its block updates itself. This provides a single virtual method that should render the text of its label, displaying all data of its connected block. The block is read only because this is only meant for displaying its data.</description>
          <name>BlockView</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>QLabel</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new block view with the given block.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the block pointer is valid and connect the updated signal.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The block that this view displays.</description>
                <initializer></initializer>
                <name>block</name>
                <type>const Block*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>public slots:</type>
          </data>
          <function>
            <data>
              <description>Called when this view's block's data has changed. This clears this view's text and calls the interface to render it again with the updated block.</description>
              <name>blockUpdated</name>
              <operation>Clear this view's text and render it again.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <abstract/>
              <description>This interface renders the text onto this label displaying all data of the block this view displays.</description>
              <name>renderText</name>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Returns a reference to the block this view displays, type casted to the specific block type of this view. It is assumed the type given can be type cast successfully.</description>
              <name>block</name>
              <operation>Type cast this view's block to the given block type and make sure it worked.</operation>
              <operation>Return a reference to this view's type casted block.</operation>
              <return_description>Reference to the block this view displays.</return_description>
              <type>const T&amp;</type>
            </data>
            <template>
              <data>
                <description>Block type to return as a reference.</description>
                <name>T</name>
                <type>class</type>
              </data>
            </template>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <variable>
            <data>
              <description>The block that this view displays.</description>
              <initializer></initializer>
              <name>_block</name>
              <type>const Block*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This represents a dialog for editing the data of a block. This class provides partial construction of the dialog GUI and handling the events associated with what it creates. An implementation of this class is responsible for handling apply actions and constructing the rest of the GUI. This is a persistent dialog. The GUI of this object is not constructed in this object's constructor since it relies on an interface call as part of its construction process. Instead an initialization method must be called before this object can be used as a dialog.

This class constructs OK, apply, and cancel buttons and handles their clicked events. An interface for applying changes to the block being edited is provided. Any exceptions thrown inside the apply interface are caught by this class and reported to the user, not closing its dialog if the OK button was clicked. Because this is a persistent dialog an implementation of this class must define its own unique key using the save settings method of the persistent dialog class.

An implementation of this class must construct the form portion of this dialog giving user access to the data of the block being edited. This is accomplished through another interface that returns a layout of the form portion. The form portion is positioned at the top of the dialog while the buttons this class creates is at the bottom.
</description>
          <name>BlockEdit</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Gui::PersistentDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new abstract edit object with the given block and an optional parent. The new abstract edit is not initialized and not ready to be used as a dialog until the initialize method is called.</description>
              <explicit/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The block that this widget edits.</description>
                <initializer></initializer>
                <name>block</name>
                <type>Block*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent for this new abstract edit dialog.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the GUI for this abstract edit dialog, making it ready to be used as a GUI dialog window.</description>
              <name>initialize</name>
              <operation>Setup this object's buttons. This must be done before the layout interface is called because its buttons may be accessed in that interface.</operation>
              <operation>Create a vertical layout, adding the abstract layout and then the buttons.</operation>
              <operation>Set the main layout of this dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <abstract/>
              <description>This interface is called to return the layout of all GUI elements used by this dialog object's form layout. All GUI objects are added to this dialog and set as their parent.</description>
              <name>layout</name>
              <return_description>Pointer to the layout containing all GUI elements for this dialog.</return_description>
              <type>QLayout*</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <description>This interface is called when the user has clicked the apply or OK button and is expected to update the block it is editing with the editor dialog values. If an exception is thrown from this interface then the user is informed and the dialog is not closed.</description>
              <name>apply</name>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Sets the state of the apply and OK buttons of this dialog to being disabled or enabled.</description>
              <name>setDisabled</name>
              <operation>Set the disabled state of this object's apply and OK buttons based off the given state.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>True to disable apply and OK buttons or false to enable them.</description>
                <initializer></initializer>
                <name>disabled</name>
                <type>bool</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Returns a reference to the block this widget edits, type casted to the specific block type of this widget. It is assumed the type given can be type cast successfully.</description>
              <name>block</name>
              <operation>Type cast this object's block to the given block type and make sure it worked.</operation>
              <operation>Return a reference to this object's type casted block.</operation>
              <return_description>Reference to the block this widget edits.</return_description>
              <type>T&amp;</type>
            </data>
            <template>
              <data>
                <description>Block type to return as a reference.</description>
                <name>T</name>
                <type>class</type>
              </data>
            </template>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when this object's OK button is clicked. This tries to apply changes to the implementation's block and if successful closes this dialog.</description>
              <name>okClicked</name>
              <operation>Try to apply changes and if it works close this dialog with accept.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when this object's apply button is clicked. This tries to apply changes to the implementation's block and if successful updates the block's view.</description>
              <name>applyClicked</name>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Calls this object's apply interface, returning true if it was successful or false if it caught an exception.</description>
              <name>tryApply</name>
              <operation>Call this object's apply interface and return true on success.</operation>
              <operation>Catch any exception thrown from the apply interface, returning false on failure.</operation>
              <return_description>True is the implementation applied changes successfully or false if an exception was thrown.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs the three buttons this abstract edit object provides to its implementation, returning the horizontal layout containing the setup buttons.</description>
              <name>setupButtons</name>
              <operation>Create the OK button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the apply button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the cancel button for this dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the OK button then the apply button then a stretch and then the cancel button.</operation>
              <operation>Return the buttons layout.</operation>
              <return_description>Horizontal layout containing this object's three buttons.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <variable>
            <data>
              <description>Pointer to this object's OK button.</description>
              <initializer></initializer>
              <name>_ok</name>
              <type>QPushButton*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to this object's apply button.</description>
              <initializer></initializer>
              <name>_apply</name>
              <type>QPushButton*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The block that this widget edits.</description>
              <initializer></initializer>
              <name>_block</name>
              <type>Block*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This represents the factory that can produce blocks for a specific project type. There should only be one instance of this class for each project type. Along with making new blocks this factory also gives basic information about each block type such as its display and element names. The two element name functions must mirror one another in an implementation or undefined behavior will occur.</description>
          <name>BlockFactory</name>
        </data>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <default/>
              <description>Virtual destructor so implemented classes have their destructor called correctly.</description>
              <name>~^</name>
              <return_description></return_description>
              <type></type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the project type of this block factory.</description>
              <name>type</name>
              <return_description>Project type.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the number of block types that exist for this factory. Block types must be defined for all integers from 0 to one less than the number of block types returned by this interface.</description>
              <name>size</name>
              <return_description>Number of block types that exist for this factory.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the display name for the given block type.</description>
              <name>name</name>
              <return_description>Display name for the given block type.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Block type whose display name is returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the integer type of the block with the given element name. If no block type exists with the given name then -1 is returned.</description>
              <name>typeByElementName</name>
              <return_description>The integer type of the block with the given element name if found or -1 if no block type is found with that element name.</return_description>
              <type>int</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>The given element name whose integer type is returned if found.</description>
                <initializer></initializer>
                <name>elementName</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the element name for the given block type. The element name is used as the tag name in XML elements for reading/writing of blocks.</description>
              <name>elementName</name>
              <return_description>Element name for the given block type.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Block type whose element name is returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface creates and returns a new block of the given type. The new block is expected to have either a null data or new default state, depending on the given flag.</description>
              <name>createBlock</name>
              <return_description>New block with given type.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Block type which is made and returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if the new block is initialized to a default state or false if it is uninitialized in a null state.</description>
                <initializer></initializer>
                <name>isDefault</name>
                <type>bool</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface creates and returns a new root block. The root block is used as the root block for all projects of this project type. The new root block is expected to have a null data state.</description>
              <name>createRootBlock</name>
              <return_description>New root block for this project type.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
              <virtual/>
            </data>
          </function>
        </access>
      </class>
      <class>
        <data>
          <description>This represents the factory that provides all other factories and information to define a project type. A project type is defined as a specific programming language that a project references. This is a global singleton class so only one instance of this factory is available for the entire application. A new factory instance must be set at initialization of the program and should not be set again after that. To maintain backwards compatibility all previously defined project type element names must never change and the two element methods must mirror one another.</description>
          <name>ProjectFactory</name>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Soc::Ut::SingletonFactory&lt;ProjectFactory></class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <default/>
              <description>Virtual destructor so implemented classes have their destructor called correctly.</description>
              <name>~^</name>
              <return_description></return_description>
              <type></type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the number of project types that exist. Project types must be defined for all integers from 0 to one less than the number of project types returned by this interface.</description>
              <name>size</name>
              <return_description>Number of project types that exist.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the display name for the given project type.</description>
              <name>name</name>
              <return_description>Display name for the given project type.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Project type whose display name is returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the project type with the given element name. If no project type exists with the given name then -1 is returned.</description>
              <name>typeByElementName</name>
              <return_description>The integer value of the project type with the given element name if found or -1 if no project type is found with the given element name.</return_description>
              <type>int</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>The given element name of the project type that is returned if found.</description>
                <initializer></initializer>
                <name>elementName</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the element name for the given project type. The element name is used as the tag name in the XML project file to determine what project type it is.</description>
              <name>elementName</name>
              <return_description>Element name for the given project type.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Project type whose element name is returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the default filters for the scanning of source files the given project type possesses.</description>
              <name>defaultFilters</name>
              <return_description>Default file filters for the given project type.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Project type whose default file filters are returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface makes a new settings dialog for the given project type. The settings dialog for a project type should contain all general settings for that project type, saving the settings in the qt settings class.</description>
              <name>makeSettings</name>
              <return_description>Pointer to the new settings dialog for the given project type.</return_description>
              <type>Soc::Ut::QPtr&lt;QDialog></type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Project type whose settings dialog is returned.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns a read only reference to the block factory for the given project type.</description>
              <name>blockFactory</name>
              <return_description>Read only reference to block factory for the given project type.</return_description>
              <type>const Abstract::BlockFactory&amp;</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Project type whose block factory is returned as a reference.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface creates and returns a mapping of scanner objects for the given root block that will be used for scanning all source files that match any of the mapped scanner objects returned. The key for the returned mapping are file names that are matched with any source files found in the scanning directory. Ownership of all returned scanner objects are released once returned.</description>
              <name>createScannerMap</name>
              <return_description>Mapping of scanner objects used for scanning source files of the given root block's project.</return_description>
              <type>QMap&lt;QString,Scanner*></type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>Root block of existing project that will be parsed with the returned mapping of scanner objects.</description>
                <initializer></initializer>
                <name>root</name>
                <type>const Block*</type>
              </data>
            </variable>
          </function>
        </access>
      </class>
      <class>
        <data>
          <description>This represents parser elements that are used in a scanner to parse a source file. A parser element can read the input of the source file based off a header that must be matched. A parser element also provides output lines that are used to write output to the scanner source file along with all other parser elements part of a scanner. An indent can also be provided for prepending a certain number of spaces to each output line. This provided indent is optional for an implementation and can be ignored.

A scanner queries all of its parser elements that take input for a regular expression header that is matched with each input line read from the source file. If the regular expression matches the line then each following line, including the header line matched, is provided to the element parser until it is finished.

It is important to minimize the work in creating and initializing a parser element and maximizing the work done in all interface methods. This is because the GUI thread is blocked while creating and initializing parser elements. However all interface methods are called within a scanning thread. WARNING: Because of this any execution code within those interface methods should not access anything from the GUI thread. It is only safe for the interface methods to access its own parser object because they are moved to the scan thread after creation and initialization.</description>
          <name>Parser</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>QObject</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <abstract/>
              <const/>
              <description>This interface returns the output lines for this parser element used by its parent scanner to write output to its source file.</description>
              <name>output</name>
              <return_description>Output lines for this parser element.</return_description>
              <type>QStringList</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>This interface returns true if this parser element requires input from the source file of its parent scanner. This can be updated to false if this no longer needs input but cannot be changed from false to true. The default implementation returns false.</description>
              <name>needsInput</name>
              <return_description>True if this parser element requires input from its parent scanner source file or false otherwise.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>This interface returns a regular expression that its parent scanner uses to match input lines of its source file. Once this object's parent scanner finds a match with the returned regular expression it is fed input lines until this object is finished. The default implementation returns an empty string.</description>
              <name>headerExpression</name>
              <return_description>Regular expression that its parent scanner uses to match input lines of its source file.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>This interface sets the indent, in spaces, that is prepended to each line of the parser element's output to its parent scanner. The default implementation does nothing.</description>
              <name>setIndent</name>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>The new indent value in spaces.</description>
                <initializer></initializer>
                <name>value</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This interface reads in one line of input given from its parent scanner, returning true if this parser element wants to read the next line after the one given. The default implementation returns false.</description>
              <name>input</name>
              <return_description>True to signal this parser will continue reading input lines or false to signal it is finished.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>One line of input given from this parser element's parent scanner.</description>
                <initializer></initializer>
                <name>line</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>This interface clears any saved information this parser element contains and resets it to its initial state. The default implementation does nothing.</description>
              <name>reset</name>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
          </function>
        </access>
      </class>
    </namespace>
    <namespace>
      <data>
        <description>Contains all GUI elements for this application.</description>
        <name>Gui</name>
      </data>
      <class>
        <data>
          <description>This is a base dialog class that allows any dialog class inheriting it to keep a persistent geometry whenever the dialog is closed and opened again. This is done by using Qt settings, saving the dialog geometry upon destruction and restoring it upon construction or calling a method. A unique key must be given to this class for each dialog inheriting it to avoid Qt setting collisions of saved geometry. If a key is never given to this class then it will not save any geometry.</description>
          <name>PersistentDialog</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>QDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new persistent dialog with an optional parent. This new dialog will effectively do nothing unless the save settings method is called before its destruction.</description>
              <explicit/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Optional parent for this new persistent dialog.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Constructs a new persistent dialog with the given geometry key and an optional parent.</description>
              <explicit/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The optional geometry key used as the Qt settings key to store the geometry of a unique dialog class. If this string is empty it is ignored and no geometry is set.</description>
                <initializer></initializer>
                <name>geometryKey</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent for this new persistent dialog.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>public slots:</type>
          </data>
          <function>
            <data>
              <description>Implements _QDialog_ interface. This is implemented so when done is called it closes this dialog.</description>
              <final/>
              <name>done</name>
              <operation>Call the qt dialog interface and then close this dialog.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>r</name>
                <type>int</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Implements _QWidget::closeEvent_. This saves the geometry of this persistent dialog and calls the inherited interface.</description>
              <name>closeEvent</name>
              <operation>Check to see if this dialog has a geometry key.</operation>
              <operation>Save the geometry for this dialog.</operation>
              <operation>Call the parent interface.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>event</name>
                <type>QCloseEvent*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Sets the geometry key for this persistent dialog and then restores the geometry of this dialog using the given geometry key. If the geometry key for this dialog has already been set then an exception is thrown.</description>
              <name>saveSettings</name>
              <operation>Make sure the given geometry key is not empty.</operation>
              <operation>Make sure the geometry key for this dialog is not already set.</operation>
              <operation>Set the geometry key for this dialog and restore its geometry using the same key.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description></description>
                <initializer></initializer>
                <name>geometryKey</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <variable>
            <data>
              <description>The geometry key for this persistent dialog that must be unique for the class inheriting this one. If no key has been set this is empty.</description>
              <initializer></initializer>
              <name>_geometryKey</name>
              <type>QString</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is a spell checking syntax highlighter for its given qt text document. This highlights any misspelled words in its given qt text document by changing its text format so it is visible to the user.</description>
          <name>SpellerHighlighter</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>QSyntaxHighlighter</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new spell checking highlighter with the given text document parent.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the given dictionary, language, and document pointers are valid.</operation>
              <operation>Initialize the highlight format for misspelled words.</operation>
              <operation>Setup this highlighter's spell checking library.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The custom dictionary model this new highlighter uses to check for custom spell checking words.</description>
                <initializer></initializer>
                <name>dictionary</name>
                <type>DictionaryModel*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The language used with this highlighter's spell checking engine.</description>
                <initializer></initializer>
                <name>language</name>
                <type>const char*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The text document of the text editor that is the parent for this new highlighter.</description>
                <initializer></initializer>
                <name>document</name>
                <type>QTextDocument*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Delete this highlighter's spell checking library resources.</description>
              <final/>
              <name>~^</name>
              <operation>Free this highlighter's Aspell resources.</operation>
              <override/>
              <return_description></return_description>
              <type></type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Implements _QSyntaxHighlighter_ interface. This implementation searches for misspelled words, highlighting any that are found.</description>
              <final/>
              <name>highlightBlock</name>
              <operation>Use a Qt regular expression to match all words in the given text block.</operation>
              <operation>Iterate through all matched words.</operation>
              <operation>Extract the matched word.</operation>
              <operation>Check to see if the word is misspelled by checking the custom dictionary and then the Aspell spell checker.</operation>
              <operation>Highlight the misspelled word.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>text</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Constructs and initializes all Aspell library resources for this new highlighter using the given language.</description>
              <name>setupSpeller</name>
              <operation>Create and set this highlighter's Aspell configuration.</operation>
              <operation>Create this highlighter's Aspell speller using the configuration and make sure it worked.</operation>
              <operation>Set this highlighter's speller by extracting it from the temporary holder.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The language used with this highlighter's spell checking engine.</description>
                <initializer></initializer>
                <name>language</name>
                <type>const char*</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The text format used by this highlighter for any misspelled words in its parent editor.</description>
              <initializer></initializer>
              <name>_format</name>
              <type>QTextCharFormat</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to this highlighter's Aspell configuration resource.</description>
              <initializer></initializer>
              <name>_spellConfig</name>
              <type>AspellConfig*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to this highlighter's Aspell speller resource.</description>
              <initializer></initializer>
              <name>_spell</name>
              <type>AspellSpeller*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the custom dictionary model used for custom spell checking words.</description>
              <initializer></initializer>
              <name>_dictionary</name>
              <type>DictionaryModel*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is a spell checking dialog for the given qt text document. This dialog scans the text of the given qt text document and presents a dialog for each misspelled word it finds. This dialog provides the user options to change, ignore once, or ignore all for each misspelled word it finds. It also provides suggestions for changing the misspelled words it finds. Lastly it provides a snippet of the text around the misspelled word to provide context to the user. This is a persistent dialog and remembers its geometry.

Once the entire text of the parent editor of this dialog has been scanned, it will ask the user if they wish to scan the entire text again. A cancel button is also provided for the user to cancel the spell checking at anytime.</description>
          <name>SpellerDialog</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>PersistentDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new spell checker dialog with the given dictionary, language, and qt text document. An optional parent can also be given.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the given dictionary, language, and document pointers are valid.</operation>
              <operation>Setup the speller, GUI, and window title for this new dialog.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The custom dictionary model this spell checker uses to check for custom words.</description>
                <initializer></initializer>
                <name>dictionary</name>
                <type>DictionaryModel*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The language used with this spell checker's engine.</description>
                <initializer></initializer>
                <name>language</name>
                <type>const char*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The text document that this spell checker scans for misspelled words.</description>
                <initializer></initializer>
                <name>document</name>
                <type>QTextDocument*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent that this dialog will block if it is executed in modal mode.</description>
                <initializer></initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Delete this object's spell checking library resources.</description>
              <final/>
              <name>~^</name>
              <operation>Free the speller resources of this dialog.</operation>
              <override/>
              <return_description></return_description>
              <type></type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>Begins spell checking on the parent text editor of this dialog by finding the first misspelled word. If no misspelled word are found this returns.</description>
              <final/>
              <name>exec</name>
              <operation>Show this dialog so it is not invisible.</operation>
              <operation>Find the first misspelled word, executing this dialog if one is found or returning right away if no misspelled word is found.</operation>
              <override/>
              <return_description>Always returns Qt dialog accept.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when the change button is clicked. This changes the current misspelled word in the parent editor's text of this dialog and then finds the next misspelled word.</description>
              <name>changeClicked</name>
              <operation>Replace the currently misspelled word with the text from the word edit widget of this dialog.</operation>
              <operation>Find the next misspelled word.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the ignore once button is clicked. This skips the current misspelled word and finds the next one.</description>
              <name>ignoreOnceClicked</name>
              <operation>Skip the current misspelled word and find the next one.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the ignore all button is clicked. This adds this object's current misspelled word to the list of words to ignore and finds the next misspelled word.</description>
              <name>ignoreAllClicked</name>
              <operation>Add the current misspelled word to the list of ignored words for this dialog and then find the next misspelled word.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the add button is clicked. This adds this object's current misspelled word to this object's text edit's custom dictionary.</description>
              <name>addClicked</name>
              <operation>Add the current misspelled word to this object's text edit's custom dictionary and then find the next misspelled word.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the text in the word edit widget of this dialog changes. This updates the enabled state of the change button of this dialog depending on if the new text is a misspelled word or not, disabling it if it is misspelled.</description>
              <name>wordTextChanged</name>
              <operation>Change the enabled state of the word edit widget of this dialog based off it being misspelled or not.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>New text in the word edit widget of this dialog.</description>
                <initializer></initializer>
                <name>text</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <variable>
            <data>
              <constexpr/>
              <description>The amount of characters displayed before and after the misspelled word in the snippet view of spell checkers.</description>
              <initializer>256</initializer>
              <name>_snippetRadius</name>
              <static/>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The text added before and after a snippet view representing dots to communicate there is more text on either side.</description>
              <initializer>"..."</initializer>
              <name>_snippetDots</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Finds the next misspelled word in the parent editor of this dialog, returning true if a misspelled word is found or false if there is nothing else to find.</description>
              <name>findNextWord</name>
              <operation>Find the first word of the parent editor's text at or after the offset of this dialog.</operation>
              <operation>While a word is found at or after the offset of this dialog then continue.</operation>
              <operation>Update the offset and length parameters of this dialog with the current word match.</operation>
              <operation>Check to see if the current word is misspelled.</operation>
              <operation>Update the current misspelled word of this dialog to the new one found and return true.</operation>
              <operation>Update the offset for this dialog to find the next word in the parent editor's text.</operation>
              <operation>End of text is reached so query the user if they want to start over from the beginning.</operation>
              <return_description>True if a misspelled word is found or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <description>Tests if the given word is spelled correctly or not.</description>
              <name>isCorrectWord</name>
              <operation>Check to see if the given word is in the ignore list of this dialog.</operation>
              <operation>Check to see if the given word is in the custom dictionary.</operation>
              <operation>Use the spell checker of this dialog to see and return if the given word is spelled correctly.</operation>
              <return_description>True if the given word is spelled correctly or false otherwise.</return_description>
              <type>bool</type>
            </data>
            <variable>
              <data>
                <description>The word that is checked for spelling.</description>
                <initializer></initializer>
                <name>word</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Queries the user with a dialog if they want to run spell checking again on the parent editor of this dialog.</description>
              <name>queryEndOfText</name>
              <operation>Create a message box to query the user if they want to spell check again from the beginning.</operation>
              <operation>Execute the message box and check to see if the user choose yes.</operation>
              <operation>Reset the offset and length of this dialog and find the next misspelled word.</operation>
              <operation>Else the user responded with no.</operation>
              <operation>Close the dialog with accept and return false.</operation>
              <return_description>True if the user wants to run spell checking again and a misspelled word was found or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <description>Sets the current misspelled word for this dialog.</description>
              <name>setWord</name>
              <operation>Set the misspelled word for this dialog.</operation>
              <operation>Set the snippet and suggested word replacements for this dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The Qt regular expression match within the given complete text that is a misspelled word.</description>
                <initializer></initializer>
                <name>match</name>
                <type>const QRegularExpressionMatch&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Set the snippet text for this dialog with the given text and offset positions for the misspelled word.</description>
              <name>setSnippet</name>
              <operation>Get the text of the parent editor for this dialog.</operation>
              <operation>Figure out the beginning offset and length for the left half of the new snippet.</operation>
              <operation>Figure out the offset for the right half of the new snippet.</operation>
              <operation>Add snippet dots to the new snippet if it is not at the beginning of the parent editor's text.</operation>
              <operation>Append the left side, misspelled word, and then right side to the new snippet.</operation>
              <operation>Add snippets dots to the new snippet if it is not at the end of the parent editor's text.</operation>
              <operation>Set the snippet view of this dialog to the new snippet.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The offset where the misspelled word begins in the given complete text.</description>
                <initializer></initializer>
                <name>begin</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The length of the misspelled word in the given complete text.</description>
                <initializer></initializer>
                <name>length</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Update the word change suggestions displayed to the user for the current misspelled word of this dialog.</description>
              <name>updateSuggested</name>
              <operation>Get a list of word change suggestions from the current misspelled word of this dialog.</operation>
              <operation>Initialize for iterating through suggestions and add the title.</operation>
              <operation>Iterate through all word change suggestions.</operation>
              <operation>If this is not the first word change suggestion then append a space.</operation>
              <operation>Append the word change suggestion.</operation>
              <operation>Set the suggestion view of this dialog with the new suggestion list and delete temporary Aspell resources.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes all GUI elements for this new dialog.</description>
              <name>setupGui</name>
              <operation>Create a new vertical layout, adding the top layout and then adding the buttons.</operation>
              <operation>Set the layout of this dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the top part of the GUI for this new dialog, returning its layout.</description>
              <name>setupTop</name>
              <operation>Create and initialize the suggestions view label of this dialog.</operation>
              <operation>Create a new horizontal layout, adding the word edit layout and then the suggestions view label.</operation>
              <operation>Return the top layout.</operation>
              <return_description>Pointer to the layout of the top part of the GUI for this dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the word edit portion of the GUI for this new dialog, returning its layout.</description>
              <name>setupWordEdit</name>
              <operation>Create the word line edit widget for this new dialog, connecting its text changed signal.</operation>
              <operation>Create and initialize the snippet view label for this new dialog.</operation>
              <operation>Create a vertical layout, adding the word edit widget then the snippet view label.</operation>
              <operation>Return the word edit layout.</operation>
              <return_description>Pointer to the layout of the word edit portion of the GUI for this dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes all buttons for this new dialog, returning the layout containing all the buttons.</description>
              <name>setupButtons</name>
              <operation>Create the change button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the ignore once button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the ignore all button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the add button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the cancel button for this dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the change button then the ignore once button then the ignore button then the add button then a stretch and then the cancel button.</operation>
              <operation>Return the buttons layout.</operation>
              <return_description>Pointer to layout of all buttons for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes all Aspell library resources for this new dialog.</description>
              <name>setupSpeller</name>
              <operation>Create and set the Aspell configuration of this dialog.</operation>
              <operation>Create the Aspell speller for this dialog using the configuration and make sure it worked.</operation>
              <operation>Set the speller of this dialog by extracting it from the temporary holder.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The language used with this highlighter's spell checking engine.</description>
                <initializer></initializer>
                <name>language</name>
                <type>const char*</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The qt text document this dialog is spell checking.</description>
              <initializer></initializer>
              <name>_document</name>
              <type>QTextDocument*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The custom dictionary model used by this spell checker for custom words.</description>
              <initializer></initializer>
              <name>_dictionary</name>
              <type>DictionaryModel*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The current misspelled word for this dialog.</description>
              <initializer></initializer>
              <name>_currentWord</name>
              <type>QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>List of words that are ignored and not flagged as misspelled even if the spell checker says so.</description>
              <initializer></initializer>
              <name>_ignored</name>
              <type>QStringList</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Current position in the parent text editor text where this dialog is checking for misspelled words.</description>
              <initializer>0</initializer>
              <name>_offset</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Length of the current misspelled word for this dialog.</description>
              <initializer>0</initializer>
              <name>_length</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The word edit widget of this dialog where the user can edit and fix misspelled words.</description>
              <initializer></initializer>
              <name>_wordEdit</name>
              <type>QLineEdit*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The snippet view label of this dialog which displays a portion of the text around the current misspelled.</description>
              <initializer></initializer>
              <name>_snippetView</name>
              <type>QLabel*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The suggestions view label of this dialog that displays possible corrections to the current misspelled word.</description>
              <initializer></initializer>
              <name>_suggestionsView</name>
              <type>QLabel*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The change button of this dialog.</description>
              <initializer></initializer>
              <name>_changeButton</name>
              <type>QPushButton*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The Aspell configuration resource of this dialog.</description>
              <initializer></initializer>
              <name>_spellConfig</name>
              <type>AspellConfig*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The Aspell speller resource of this dialog.</description>
              <initializer></initializer>
              <name>_spell</name>
              <type>AspellSpeller*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is a plain text editor widget that has additional features to the Qt version. This editor has spellchecking support and the ability to open a new text editor dialog with the same text. The spellchecking support comes in two ways. The first way is highlighting any misspelled words in the editor. The second way is a spell checker dialog that scans all words of the text allowing for corrections to any misspelled words. A special shortcut is used to activate the spell checker dialog or open the editor into its own dialog.

Custom spell checking words is also required for this class to add the ability to have custom words added for spell checking on a per project basis. This functionality requires passing either a block pointer or a pointer to the custom dictionary itself. If a block pointer is given its project's custom dictionary is found.</description>
          <name>TextEdit</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>QPlainTextEdit</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new text editor with the given block and an optional parent. Spell checking and the dialog popup shortcut are enabled by default.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the given block pointer is not null.</operation>
              <operation>Get the project pointer from the given block making sure it is not null.</operation>
              <operation>Set the custom dictionary to the project's dictionary.</operation>
              <operation>Create this text editor's highlighter and setup its shortcut actions.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Pointer to the block that is contextually being used. This usually means the block that is being edited. This is used to get the custom dictionary model of the block's project.</description>
                <initializer></initializer>
                <name>block</name>
                <type>Abstract::Block*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent for this new text editor.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Constructs a new text editor with the given custom dictionary and an optional parent. Spell checking and the dialog popup shortcut are enabled by default.</description>
              <explicit/>
