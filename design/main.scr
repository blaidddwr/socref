            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name of the element used to define the name option that specifies which string field is used for this block's name.</description>
              <initializer>"name"</initializer>
              <name>_nameTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name of the element used to define the path for this basic block type's icon.</description>
              <initializer>"icon"</initializer>
              <name>_iconTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name of the element that hold the configuration for this basic block type's edit class.</description>
              <initializer>"edit"</initializer>
              <name>_editTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name of the element that hold the configuration for this basic block type's view class.</description>
              <initializer>"view"</initializer>
              <name>_viewTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the id of data field element definitions.</description>
              <initializer>"id"</initializer>
              <name>_idKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for default values of data field element definitions.</description>
              <initializer>"default"</initializer>
              <name>_defaultKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Appends a new data field to this basic block. This is only used when initializing a basic block to its type and adding the data field definitions.</description>
              <name>addField</name>
              <operation>Get the id the new data field of this basic block will use, making sure the id attribute exists in the given element.</operation>
              <operation>Make sure this basic block does not already have a field with the given id.</operation>
              <operation>Add the new field of the given type, setting its default value if the given state indicates to do so or leaving it to its null value if not. Note for string list types there is no default value possible.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The type of the data field  that is appended to this basic block.</description>
                <initializer></initializer>
                <name>type</name>
                <type>Field</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The data field element defining the data field that is added to this basic block.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if the newly appended data field should be set to its default value or false if it is set to its null value.</description>
                <initializer></initializer>
                <name>isDefault</name>
                <type>bool</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Return the data field of this basic block with the given id. If no field exists with the given id then an exception is thrown.</description>
              <name>get</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Find this basic block's data field with the given id, making sure it exists.</operation>
              <operation>Return the found data field.</operation>
              <return_description>Data field of this data block with the given id.</return_description>
              <type>QVariant</type>
            </data>
            <variable>
              <data>
                <description>The id of this basic block's data field which is returned.</description>
                <initializer></initializer>
                <name>id</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>XML element that defines this basic block type. Used to make copies of this basic block.</description>
              <initializer></initializer>
              <name>_definition</name>
              <type>QDomElement</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>XML element that defines the editor of this basic block type.</description>
              <initializer></initializer>
              <name>_editDefinition</name>
              <type>QDomElement</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>XML element that defines the viewer of this basic block type.</description>
              <initializer></initializer>
              <name>_viewDefinition</name>
              <type>QDomElement</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The block type of this basic block. Also used to keep track of this basic block being initialized or not. If it is not initialized it is -1 else it is its block type.</description>
              <initializer>-1</initializer>
              <name>_type</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The basic block factory that made this basic block.</description>
              <initializer></initializer>
              <name>_factory</name>
              <type>const Abstract::BlockFactory*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Data fields of this basic block mapped with their string ids.</description>
              <initializer></initializer>
              <name>_fields</name>
              <type>QMap&lt;QString,QVariant></type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The build list for this basic block type.</description>
              <initializer></initializer>
              <name>_buildList</name>
              <type>QList&lt;int></type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The data field id that this basic block uses for a display name. If this is empty this basic block's display name is also empty.</description>
              <initializer></initializer>
              <name>_nameFieldId</name>
              <type>QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The path to the icon for this basic block type.</description>
              <initializer></initializer>
              <name>_iconPath</name>
              <type>QString</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This implements the abstract basic block view that displays an associated basic block. Like the basic block it views, this class reads in its configuration from an XML element supplied to it from its basic block. The XML definition provides all information about the layout of display elements this view displays. This class can be implemented by another more specialized class and is necessary to do so if the custom viewing element is used.</description>
          <name>BlockView</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Abstract::BlockView</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new view with the given basic block which is displays.</description>
              <explicit/>
              <name>^</name>
              <operation>Format this new view's label.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The basic block this new view is displaying.</description>
                <initializer></initializer>
                <name>block</name>
                <type>const Block*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Implements _Abstract::BlockView_ interface.</description>
              <final/>
              <name>renderText</name>
              <operation>Create a new string that will hold the new rich text of this view.</operation>
              <operation>Prepare an enumeration and matching string list for recognizing element tag names.</operation>
              <operation>Iterate through all child nodes of this view's basic block's view definition element.</operation>
              <operation>Check to see if the node is an element.</operation>
              <operation>Figure out which display element this is, if any, and add its string to the new updated rich text.</operation>
              <operation>Move to the next node sibling.</operation>
              <operation>Set the text of this view's label to the updated rich text.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Parses all underline characters from the given list of strings, replacing them with HTML bold tags. The parsed list of strings is returned.</description>
              <name>parseBoldMarkers</name>
              <operation>Create an empty string list that will be returned.</operation>
              <operation>Iterate through all strings of the given string list.</operation>
              <operation>Create an empty parsed string and initialize the ingress state.</operation>
              <operation>Iterate through every character of the text.</operation>
              <operation>Check if the current character is an underline.</operation>
              <operation>Append an opening or closing HTML old tag to the parsed string depending on the ingress state.</operation>
              <operation>Invert the ingress state.</operation>
              <operation>Else the current character is not an underline so simply append it to the parsed string.</operation>
              <operation>Add the parsed string to the list of parsed strings returned.</operation>
              <operation>Return the parsed string list.</operation>
              <return_description>Parsed list of strings, replacing underlines with HTML bold tags.</return_description>
              <static/>
              <type>QStringList</type>
            </data>
            <variable>
              <data>
                <description>List of strings that is parsed to replace underline characters with HTML bold tags.</description>
                <initializer></initializer>
                <name>list</name>
                <type>const QStringList&amp;</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The tag name for a header 1 display element, 1 being the largest.</description>
              <initializer>"h1"</initializer>
              <name>_header1Tag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a header 2 display element, 1 being the largest.</description>
              <initializer>"h2"</initializer>
              <name>_header2Tag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a header 3 display element, 1 being the largest.</description>
              <initializer>"h3"</initializer>
              <name>_header3Tag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a paragraphs display element that displays a basic block field as multiple paragraphs separated by double newline characters.</description>
              <initializer>"ps"</initializer>
              <name>_paragraphsTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a custom display element specifying a custom method to call that returned a custom string.</description>
              <initializer>"custom"</initializer>
              <name>_customTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the custom method name of a custom display element.</description>
              <initializer>"name"</initializer>
              <name>_nameKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Adds paragraphs to the given rich text based off the given XML display element definition. If the basic block field referenced by the given display element then nothing will be added. The basic block field referenced must be a string or an exception is thrown.</description>
              <name>addParagraphs</name>
              <operation>Make sure the given display element has the id attribute.</operation>
              <operation>Get the basic block field that the given display element references and make sure it is a string.</operation>
              <operation>Split the basic block field into a string list of paragraphs based off double newline characters being the separator, parsing each string for bold underline markers.</operation>
              <operation>Make sure the list of paragraphs is not empty.</operation>
              <operation>Add the string list to the given rich text as paragraphs.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>Pointer to the rich text that paragraphs are added to if the given display element's basic block field is not empty.</description>
                <initializer></initializer>
                <name>text</name>
                <type>QString*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>XML display element definition that references the basic block field to add as paragraphs to the given rich text.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds custom content to the given rich text based off the given XML custom display element. If the provided method name does not exist for this object then an exception is thrown.</description>
              <name>addCustom</name>
              <operation>Lookup the custom method referenced by the name attribute of the given custom display element definition, making sure the method exists.</operation>
              <operation>Invoke the custom method of this object and add the content it returns to the given rich text.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The rich text that custom content is added to.</description>
                <initializer></initializer>
                <name>text</name>
                <type>QString*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>XML custom display element definition that provides the custom method name to call and is expected to return a string of custom content.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
        </access>
      </class>
      <class>
        <data>
          <description>This is the basic block editor that implements the abstract edit GUI class. Like the basic block it edits this class reads in its configuration from an XML element supplied to it from its basic block. The XML definition provides all information about the layout of the form and what fields edit widgets control. This class cannot be implemented by another more specialized class because all data is designed to be on the basic block layer and this editor must be aware of all data in the basic block it edits.

The layout of this editor is defined by the XML element between different layout widgets contained within a qt splitter. Each layout added to the splitter can either be a form layout or a vertical layout. The state of the splitter is persistent along with the editor's dialog geometry.</description>
          <name>BlockEdit</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Abstract::BlockEdit</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new editor with the given basic block which it edits.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the given block pointer is not null.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The basic block this new editor is editing.</description>
                <initializer></initializer>
                <name>block</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <description>Implements _Gui::AbstractEdit_ interface.</description>
              <final/>
              <name>layout</name>
              <operation>Create this editor's splitter widget.</operation>
              <operation>Prepare an enumeration and matching string list that matches any recognized element tag names.</operation>
              <operation>Iterate through all children nodes of this editor's basic block's edit definition XML element.</operation>
              <operation>Check to see if this node is an element.</operation>
              <operation>Determine if this element is a form or a layout, calling the appropriate method for building the sub layout and adding it to this editor's splitter as a widget.</operation>
              <operation>Move to the next sibling node.</operation>
              <operation>Save the geometry settings of this persistent dialog and the state of this editor's splitter widget using a base key generated from this basic block's project type name and its element name.</operation>
              <operation>Create a return layout, add this editor's splitter widget to it, and return the layout.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QLayout*</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>Implements _Gui::AbstractEdit_ interface.</description>
              <final/>
              <name>apply</name>
              <operation>Iterate through all widgets of this editor.</operation>
              <operation>Get the matching basic block field of the edit widget, making sure the field exists.</operation>
              <operation>Figure out what type the edit widget is and set the value of the basic block field to the value of the edit widget, making sure the basic block field is of the correct type.</operation>
              <operation>Else the edit widget is of an unknown type so throw an exception.</operation>
              <operation>Notify the block system that this editor's basic block has been modified.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>Implements _QWidget_ interface. This implementation uses this interface to save the state of its splitter widget and then calls its parent interface.</description>
              <final/>
              <name>closeEvent</name>
              <operation>Save the state of this editor's splitter with its state key.</operation>
              <operation>Call this object's parent interface.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>event</name>
                <type>QCloseEvent*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Returns the value of the id attribute from the given XML element. If the id attribute does not exist or is empty then an exception is thrown.</description>
              <name>extractId</name>
              <operation>Get the id attribute value from the given XML element and make sure it is not empty or not set.</operation>
              <operation>Return the id attribute value.</operation>
              <return_description>Value of the id attribute of the given XML element.</return_description>
              <static/>
              <type>QString</type>
            </data>
            <variable>
              <data>
                <description>XML element whose id attribute value is extracted and return.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The tag name for a form element used to define a column of this editor using a form layout.</description>
              <initializer>"form"</initializer>
              <name>_formTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a layout element used to define a column of this editor using a vertical layout.</description>
              <initializer>"layout"</initializer>
              <name>_layoutTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the display string used as the title of an edit element.</description>
              <initializer>"display"</initializer>
              <name>_displayKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a check boxes element used to define a check boxes edit widget.</description>
              <initializer>"checkboxes"</initializer>
              <name>_checkboxesTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a checkbox element used to define a single checkbox within a check boxes element.</description>
              <initializer>"checkbox"</initializer>
              <name>_checkboxTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a combo box element used to define a combo box widget.</description>
              <initializer>"combo"</initializer>
              <name>_comboTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for an option element nested within combo elements used to define a value of a combo box widget.</description>
              <initializer>"option"</initializer>
              <name>_optionTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a line edit element used to define a line edit widget.</description>
              <initializer>"line"</initializer>
              <name>_lineTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name for a text edit element used to define a text edit widget.</description>
              <initializer>"text"</initializer>
              <name>_textTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name of a list edit element used to define a list edit widget.</description>
              <initializer>"list"</initializer>
              <name>_listTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the row size of a check boxes edit element.</description>
              <initializer>"rowsize"</initializer>
              <name>_rowSizeKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the value of an option element nested within a combo element.</description>
              <initializer>"value"</initializer>
              <name>_valueKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the option of disabling spell checking on a text edit widget if the attribute is set to no.</description>
              <initializer>"spell"</initializer>
              <name>_spellKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The attribute name for the option of disabling the popup dialog on a text edit widget if the attribute is set to no.</description>
              <initializer>"dialog"</initializer>
              <name>_dialogKey</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Sets the base key used by this dialog to save its geometry and state and restores its geometry and state. Additional strings are appended to this base string to the geometry and state.</description>
              <name>saveSettings</name>
              <operation>Set the geometry and state keys for this dialog using the given base key.</operation>
              <operation>Restore the state of this object's splitter using the state key.</operation>
              <operation>Call the abstract edit save settings method using the geometry key.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The base key which is copied to generate this object's geometry and state keys.</description>
                <initializer></initializer>
                <name>baseKey</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Creates and initializes a form layout row of this new editor's form using the given XML element to define all edit widgets it contains.</description>
              <name>setupForm</name>
              <operation>Create a new form layout and add all widgets defined by the given XML element.</operation>
              <operation>Create a return widget, set its layout to the new form layout, and return it.</operation>
              <return_description>A widget whose layout is set to a form layout row created with the provided XML element definition.</return_description>
              <type>QWidget*</type>
            </data>
            <variable>
              <data>
                <description>The XML element that defines the newly created form layout.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Creates and initializes a vertical layout row of this new editor's form using the given XML element to define all edit widgets it contains.</description>
              <name>setupLayout</name>
              <operation>Create a new vertical layout and add all widgets defined by the given XML element.</operation>
              <operation>Create a return widget, set its layout to the new form layout, and return it.</operation>
              <return_description>A widget whose layout is set to a vertical layout row created with the provided XML element definition.</return_description>
              <type>QWidget*</type>
            </data>
            <variable>
              <data>
                <description>The XML element that defines the newly created vertical layout.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds all edit widgets to the given layout using the given XML element which defines all edit widgets to add. The given layout can be a form or vertical layout.</description>
              <name>addWidgets</name>
              <operation>Prepare an enumeration and matching string list that matches any recognized edit element tag names.</operation>
              <operation>Iterate through all children nodes of the given element.</operation>
              <operation>Check to see if the node is an element.</operation>
              <operation>Determine which edit element this is by its tag name and call the appropriate method for adding a new edit widget.</operation>
              <operation>Move to the next sibling node.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>A form or vertical layout that has all created edit widgets added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML element that defines all edit widgets to create and add to the given layout.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds a new check boxes layout of check box edit widgets to the given layout using the given XML element to define the new check box edit widgets. This also adds the new edit widget to this editor's list of edit widgets.</description>
              <name>addCheckBoxes</name>
              <operation>Get the row size attribute from the given XML element, or its default if it does not exist, and make sure reading it as an integer worked.</operation>
              <operation>Make sure the row size is not a negative integer.</operation>
              <operation>Create the grid layout for the new check boxes edit widget and initialize the row and column indexes.</operation>
              <operation>Iterate through all child nodes of the given element.</operation>
              <operation>Check to see if the node is an element.</operation>
              <operation>Check to see if the element's tag name matches the check box tag.</operation>
              <operation>Setup a new check box edit widget and then add it to the grid layout using the current row and column indexes.</operation>
              <operation>If the row index is above the row size then reset it and increment the column index.</operation>
              <operation>Add the new grid layout with all the check box edit widgets to the given layout.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the new layout of edit widgets added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML edit element that defines the new layout of edit widgets and children elements that define each check box edit widget that is created.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds a new line combo widget to the given layout using the given XML element to define the new edit widget. This also adds the new edit widget to this editor's list of edit widgets.</description>
              <name>addComboBox</name>
              <operation>Get the id attribute from the given XML element and then get the basic block field value with the id.</operation>
              <operation>Create and initialize the new combo box widget.</operation>
              <operation>Iterate through all child nodes of the given element.</operation>
              <operation>If the node is an element and its tag name matches an option then add it as a possible value to select in the new combo box, making sure the option element has the value attribute.</operation>
              <operation>Move to the next sibling node.</operation>
              <operation>Set the currently selected option in the new combo box to the value of the basic block field being edited by it.</operation>
              <operation>Add the new widget to this editor's list of edit widgets and to the given layout.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the new edit widget added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML edit element that defines the new edit widget that is created.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds a new line edit widget to the given layout using the given XML element to define the new edit widget. This also adds the new edit widget to this editor's list of edit widgets.</description>
              <name>addLineEdit</name>
              <operation>Get the id attribute from the given XML element and then get the basic block field value with the id.</operation>
              <operation>Create and initialize the new line edit widget.</operation>
              <operation>Add the new widget to this editor's list of edit widgets and to the given layout.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the new edit widget added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML edit element that defines the new edit widget that is created.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds a new text edit widget to the given layout using the given XML element to define the new edit widget. This also adds the new edit widget to this editor's list of edit widgets.</description>
              <name>addTextEdit</name>
              <operation>Get the id attribute from the given XML element and then get the basic block field value with the id.</operation>
              <operation>Create and initialize the new text edit widget.</operation>
              <operation>If the spell check attribute option is set to no then disable spell checking.</operation>
              <operation>If the dialog popup attribute option is set to no then disable the dialog popup.</operation>
              <operation>Add the new widget to this editor's list of edit widgets and to the given layout.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the new edit widget added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML edit element that defines the new edit widget that is created.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds a new list edit widget to the given layout using the given XML element to define the new edit widget. This also adds the new edit widget to this editor's list of edit widgets.</description>
              <name>addListEdit</name>
              <operation>Get the id attribute from the given XML element and then get the basic block field value with the id.</operation>
              <operation>Create and initialize the new list edit widget.</operation>
              <operation>Add the new widget to this editor's list of edit widgets and to the given layout.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the new edit widget added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML edit element that defines the new edit widget that is created.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Creates and initializes a new check box widget with the given id and title, returning its pointer. This also adds it to this editor's list of edit widgets.</description>
              <name>setupCheckBox</name>
              <operation>Get the basic block field value with the given id.</operation>
              <operation>Create and initialize the new check box edit widget.</operation>
              <operation>Add the new check box to this editor's list of edit widgets and then return its pointer.</operation>
              <return_description>Pointer to the new check box edit widget.</return_description>
              <type>QCheckBox*</type>
            </data>
            <variable>
              <data>
                <description>The basic block field id the new check box edit widget is attached to.</description>
                <initializer></initializer>
                <name>id</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The display title of the new check box edit widget.</description>
                <initializer></initializer>
                <name>title</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds the given widget to the given layout using the given XML element to derive its display title. The given layout must be a vertical or form layout.</description>
              <name>add</name>
              <operation>If the given layout is a form then use its methods to add the given item to it with a title derived from the given XML element.</operation>
              <operation>Else if the given layout is a vertical box then use its methods to add the given item to it with a title derived from the given XML element.</operation>
              <operation>Else this is an unsupported layout type so throw an exception.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the given widget added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML element whose display attribute is used as the display title.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The widget that is added to the given with a display title extracted from the given XML element.</description>
                <initializer></initializer>
                <name>item</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Adds the given item to the given layout using the given XML element to derive its display title. The given layout must be a vertical or form layout.</description>
              <name>add</name>
              <operation>If the given layout is a form then use its methods to add the given item to it with a title derived from the given XML element.</operation>
              <operation>Else if the given layout is a vertical box then use its methods to add the given item to it with a title derived from the given XML element.</operation>
              <operation>Else this is an unsupported layout type so throw an exception.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The layout that has the given item added to it.</description>
                <initializer></initializer>
                <name>layout</name>
                <type>QLayout*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML element whose display attribute is used as the display title.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The item that is added to the given with a display title extracted from the given XML element.</description>
                <initializer></initializer>
                <name>item</name>
                <type>QLayout*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Return the value of this editor's basic block's field with the given id, checking its type matches with the given type. This assumes this is being called to add a new edit widget so additional checks are done. If this editor already has an edit widget with the given id, no field exists with the given id, or the field type does not match the given type then an exception is thrown.</description>
              <name>fieldValue</name>
              <operation>Make sure this editor's list of edit widgets does not already contain the given id.</operation>
              <operation>Get this editor's basic block's field with the given id, making sure it exists.</operation>
              <operation>Make sure the field type matches the given type.</operation>
              <operation>Return the basic block field value.</operation>
              <return_description>Basic block field value with the given id.</return_description>
              <type>QVariant</type>
            </data>
            <variable>
              <data>
                <description>The basic block field id whose value is returned.</description>
                <initializer></initializer>
                <name>id</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The basic block field type that is checked with the field type matched with the given id.</description>
                <initializer></initializer>
                <name>type</name>
                <type>quint32</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The qt splitter of this edit dialog that splits each single layout column between one another.</description>
              <initializer></initializer>
              <name>_splitter</name>
              <type>QSplitter*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The list of edit widgets this editor contains.</description>
              <initializer></initializer>
              <name>_widgets</name>
              <type>QMap&lt;QString,QWidget*></type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The state key for this edit dialog used to keep its qt splitter persistent.</description>
              <initializer></initializer>
              <name>_stateKey</name>
              <type>QString</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This mostly implements the abstract block factory. This facilitates reading in a XML configuration file that defines all basic blocks types this factory can produce. The definition of each basic block type is provided as a root level XML element.

All interfaces from the abstract block factory are implemented except for the element name interface. This must be implemented by the actual project type and is used by this interface to make sure any enumeration it contains matches the XML file. The order of block types within any enumeration must match the order in the XML configuration file this basic block factory loads.

A new interface is also provided for creating implementation classes of the basic block class. Basic blocks do no require to implemented and can simply be generic basic blocks. To do this simply return a null pointer with this class's interface.</description>
          <name>BlockFactory</name>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Abstract::BlockFactory</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::BlockFactory_ interface.</description>
              <final/>
              <name>size</name>
              <operation>If this factory has not been checked for consistency then do so.</operation>
              <operation>Return the number of basic block definitions.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::BlockFactory_ interface.</description>
              <final/>
              <name>name</name>
              <operation>If this factory has not been checked for consistency then do so.</operation>
              <operation>Make sure the given type is not out of range.</operation>
              <operation>Return the display name of the given block type.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::BlockFactory_ interface.</description>
              <final/>
              <name>typeByElementName</name>
              <operation>If this factory has not been checked for consistency then do so.</operation>
              <operation>Return the index of the given element name or -1 if it is not found.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>int</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>elementName</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::BlockFactory_ interface.</description>
              <final/>
              <name>createBlock</name>
              <operation>If this factory has not been checked for consistency then do so.</operation>
              <operation>Make sure the given type is not out of range.</operation>
              <operation>Create a new basic block, implemented or generic.</operation>
              <operation>Initialize the new basic block with its XML definition and default state.</operation>
              <operation>Return the new basic block.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>isDefault</name>
                <type>bool</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::BlockFactory_ interface.</description>
              <final/>
              <name>createRootBlock</name>
              <operation>If this factory has not been checked for consistency then do so.</operation>
              <operation>Make a new root block without default values and return it.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new basic block factory, reading in the XML configuration file at the given path.</description>
              <name>^</name>
              <operation>Read in the XML, then add all type definitions, and then build all build lists for each type defined.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The path of the XML configuration file defining all basic block types this new factory can produce.</description>
                <initializer></initializer>
                <name>xmlPath</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>This interface creates and returns the class that implements the given basic block type, if any. If this is a generic basic block type that does not require a specialized class then a null pointer is returned. The default implementation always returns a null pointer.</description>
              <name>createBasicBlock</name>
              <operation>Return a null pointer.</operation>
              <return_description>New instance of class implementation of the given basic block type or a null pointer if this basic block type is generic.</return_description>
              <type>Soc::Ut::QPtr&lt;Block></type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>The block type of the basic block that is made if not generic.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <variable>
            <data>
              <description>The name of the display attribute for XML basic block definitions.</description>
              <initializer>"display"</initializer>
              <name>_displayTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The name of the root attribute for XML basic block definitions.</description>
              <initializer>"root"</initializer>
              <name>_rootTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The tag name of the build list element for XML basic block definitions.</description>
              <initializer>"buildlist"</initializer>
              <name>_buildTag</name>
              <static/>
              <type>const char*</type>
            </data>
          </variable>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Reads in the XML configuration file at the given path.</description>
              <name>read</name>
              <operation>Open the XML file from the given path, making sure it worked.</operation>
              <operation>Create a new XML document and set its contents to the opened XML file.</operation>
              <operation>Iterate through all children of the XML document.</operation>
              <operation>If the current node is an element then read it in as a definition.</operation>
              <operation>Move to the next sibling node.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The path of the XML configuration file defining all basic block types this new factory can produce.</description>
                <initializer></initializer>
                <name>path</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Reads in a single basic block type definition from the given root XML element, appending it to this factory's list of basic block type definitions.</description>
              <name>readDefinition</name>
              <operation>Make sure the given element has the display attribute.</operation>
              <operation>Check to see if the given element has the root element.</operation>
              <operation>Make sure the root block type has not already been set.</operation>
              <operation>Set the root block type to the basic block type definition about to be added.</operation>
              <operation>Add the new basic block type definition of this factory's list.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The XML element that defines a basic block type.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Builds the build lists for all basic block types that his basic block factory defines.</description>
              <name>buildLists</name>
              <operation>Iterate through all type definitions of this factory.</operation>
              <operation>Initialize the next build list.</operation>
              <operation>Iterate through all nodes of the type definition.</operation>
              <operation>If the node is an element and matches the build list tag name then build a build list using the found build list XML element.</operation>
              <operation>Move to the next sibling.</operation>
              <operation>Add the next build list to the list of type definitions for this factory.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Builds the next build list for this factory's basic block type definitions using the given XML element as the build list element and returning the built build list.</description>
              <name>buildList</name>
              <operation>Initialize the return build list that will be returned.</operation>
              <operation>Iterate through all children nodes of the given element.</operation>
              <operation>Check to see if this node is an element.</operation>
              <operation>Find the index of the block type the element is referencing, checking to make sure it is valid.</operation>
              <operation>Append the block type to the build list.</operation>
              <operation>Move to the next sibling.</operation>
              <operation>Return the built build list.</operation>
              <return_description>Build list for the next block type definition using the given build list element.</return_description>
              <type>QList&lt;int></type>
            </data>
            <variable>
              <data>
                <description>Build list XML element used to build the build list.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Makes sure this factory's list of basic block definitions match with this factory's implementation's element name interface. If a mismatch is detected then an exception is thrown.</description>
              <name>check</name>
              <operation>If consistency has already been checked then return true immediately.</operation>
              <operation>Iterate through all basic block type definitions of this factory.</operation>
              <operation>Make sure the element name matches between this factory's list and the element name interface, returning false if there is a mismatch.</operation>
              <operation>Mark this factory as having its consistency checked and return true.</operation>
              <return_description></return_description>
              <type>bool</type>
            </data>
          </function>
          <variable>
            <data>
              <description>List of display names for this factory's basic block type definitions.</description>
              <initializer></initializer>
              <name>_typeDisplayNames</name>
              <type>QStringList</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>List of element names for this factory's list of basic block type definitions.</description>
              <initializer></initializer>
              <name>_typeElementNames</name>
              <type>QStringList</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>List of XML elements for this factory's list of basic block type definitions.</description>
              <initializer></initializer>
              <name>_typeDefinitions</name>
              <type>QList&lt;QDomElement></type>
            </data>
          </variable>
          <variable>
            <data>
              <description>List of build lists for this factory's list of basic block type definitions.</description>
              <initializer></initializer>
              <name>_buildLists</name>
              <type>QList&lt;QList&lt;int>></type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Index to the basic block type definition that is considered the root block type for this factory's implementation's project type.</description>
              <initializer>-1</initializer>
              <name>_rootType</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>True if this factory has been checked for consistency with its implementation or false otherwise.</description>
              <initializer>false</initializer>
              <mutable/>
              <name>_isChecked</name>
              <type>bool</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This implements the abstract parser class. This is a very simple parser that requires no input and simply provides the lines of text given to it along with an indent of spaces prepended to each line provided to its parent scanner.</description>
          <name>LineParser</name>
          <qtobject/>
