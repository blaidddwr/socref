                </variable>
              </function>
            </access>
            <access>
              <data>
                <type>private slots:</type>
              </data>
              <function>
                <data>
                  <description>Returns rich text that displays any arguments this view's function block contains. If this view's function block has no arguments then this returns an empty string.</description>
                  <name>displayArguments</name>
                  <operation>Create an empty return string.</operation>
                  <operation>Make a pointer list of all children variables of this view's function block and make sure it is not empty.</operation>
                  <operation>Append a title.</operation>
                  <operation>Iterate through all child variable blocks.</operation>
                  <operation>If the child block has an initial value then add its rich text.</operation>
                  <operation>Append the child variable information as rich text including the possible initial value.</operation>
                  <operation>Return the arguments rich text.</operation>
                  <return_description>Rich text that displays any arguments this view's function block contains or an empty string if there are no arguments.</return_description>
                  <type>QString</type>
                </data>
              </function>
