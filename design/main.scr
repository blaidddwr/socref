                <data>
                  <description>Constructs a new view widget with the given access block.</description>
                  <explicit/>
                  <name>^</name>
                  <return_description></return_description>
                  <type></type>
                </data>
                <variable>
                  <data>
                    <description>Access block this new view displays.</description>
                    <initializer></initializer>
                    <name>block</name>
                    <type>const Access*</type>
                  </data>
                </variable>
              </function>
            </access>
            <access>
              <data>
                <type>private slots:</type>
              </data>
              <function>
                <data>
                  <description>Returns rich text that displays the body of this view's access block. The rich text returned reports the number of enumerations, variables, functions, and classes this view's access block contains. If the count is zero this does not display that block type.</description>
                  <name>displayInfo</name>
                  <operation>Initialize all counters.</operation>
                  <operation>Iterate through all block children of this view's access block.</operation>
                  <operation>Increment the appropriate counter based off the child block's type.</operation>
                  <operation>Figure out if this function block is abstract, virtual, or regular, incrementing the correct counter based off that information.</operation>
                  <operation>Create an empty return string.</operation>
                  <operation>Append rich text info about each block type if their count is above zero.</operation>
                  <operation>Return the rich text.</operation>
                  <return_description>Rich text that displays the body of this view's access block.</return_description>
                  <type>QString</type>
                </data>
              </function>
            </access>
            <access>
              <data>
                <type>private:</type>
              </data>
              <variable>
                <data>
                  <description>The access block that this view is displaying.</description>
                  <initializer></initializer>
                  <name>_block</name>
                  <type>const Access*</type>
                </data>
              </variable>
            </access>
          </class>
