            <data>
              <description>Implements _QWidget_ interface. This implementation simply auto fits all its text after calling its parent's resize event interface.</description>
              <final/>
              <name>resizeEvent</name>
              <operation>Call parent interface and then auto fit all text rows.</operation>
              <override/>
              <return_description></return_description>
