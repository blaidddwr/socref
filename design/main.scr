              <type>QStringList</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this function block is a method of a class, returning true if it is.</description>
              <name>isMethod</name>
              <operation>Get this block's parent pointer and make sure it is not null.</operation>
              <operation>Determine if this function block is a method by seeing if its parent is an access block.</operation>
              <return_description>True if this function block is a method of a class or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this function block is a private method of a class, returning true if it is.</description>
              <name>isPrivateMethod</name>
              <operation>Make sure this function block is a method.</operation>
              <operation>Determine if this function block is a private method by seeing if its parent access block's type is private.</operation>
              <return_description>True if this function block is a private method of a class or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this function block or any class it inherits from has any templates, returning true if so.</description>
              <name>hasAnyTemplates</name>
              <operation>Check to see if this function block has any templates.</operation>
              <operation>If this function block is a method then call on its class to determine if it or any parent classes contain templates.</operation>
              <operation>If this is reached then there are no templates so return false.</operation>
              <return_description>True if this function block or any of its inherited classes contain templates or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this function block has templates arguments, returning true if it does. This does not test if any parent classes contain templates.</description>
              <name>hasTemplates</name>
              <operation>See if any direct children blocks of this block are templates.</operation>
              <return_description>True if this function block has template arguments or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
