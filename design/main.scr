            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The tag name of the element that hold the configuration for this basic block type's edit class.</description>
            <initializer>"edit"</initializer>
            <name>_editTag</name>
            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The tag name of the element that hold the configuration for this basic block type's view class.</description>
            <initializer>"view"</initializer>
            <name>_viewTag</name>
            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The attribute name for the id of data field element definitions.</description>
            <initializer>"id"</initializer>
            <name>_idKey</name>
            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The attribute name for default values of data field element definitions.</description>
            <initializer>"default"</initializer>
            <name>_defaultKey</name>
