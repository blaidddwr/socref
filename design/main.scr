              <name>name</name>
              <operation>Return the display name of this access block using its access type and the number of children it contains.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>icon</name>
              <operation>Initialize all static icons for this block type.</operation>
              <operation>Based off this access block's type return the appropriate icon.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QIcon</type>
              <virtual/>
            </data>
          </function>
        </access>
