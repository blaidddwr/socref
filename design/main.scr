            <data>
              <description>Set the current variable type selected by this widget to the new value given.</description>
              <name>setValue</name>
              <operation>Set the current type value of this widget to the new one given and update the text on the button of this widget.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The new type value for this type selection.</description>
