          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>This returns the root block in this block's tree structure. The root block is the common parent of all other blocks that has no parent itself.</description>
              <name>root</name>
              <operation>Iterate up the tree of parents until the root pointer is found.</operation>
              <operation>Return the root pointer.</operation>
              <return_description>Read only pointer to the root block.</return_description>
              <type>const Abstract::Block*</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>This returns a pointer to the parent of this block. If this block is the root block then null is returned.</description>
              <name>parent</name>
              <operation>Return the qt object of this object cast as an abstract block.</operation>
              <return_description>If this block is the root then a null pointer, else a pointer to this block's parent.</return_description>
              <type>Abstract::Block*</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>This returns the number of children this block contains.</description>
              <name>size</name>
              <operation>Return this block's child list size.</operation>
              <return_description>Number of children this block contains.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>This returns a read only reference to this block's list of children blocks. The list is a list of pointers to all child blocks.</description>
              <name>list</name>
              <operation>Return a constant reference to this block's internal children list.</operation>
              <return_description>Reference to this block's list of children.</return_description>
              <type>const QList&lt;Abstract::Block*>&amp;</type>
            </data>
          </function>
