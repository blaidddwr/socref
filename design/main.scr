                  <name>_snippetRadius</name>
                  <static/>
                  <type>int</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The text added before and after a snippet view representing dots to communicate there is more text on either side.</description>
                  <initializer>"..."</initializer>
                  <name>_snippetDots</name>
                  <static/>
                  <type>const char*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The current misspelled word for this dialog.</description>
                  <initializer></initializer>
                  <name>_currentWord</name>
                  <type>QString</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>List of words that are ignored and not flagged as misspelled even if the spell checker says so.</description>
