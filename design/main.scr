              <data>
                <description>The special header text added to the beginning of the new comment.</description>
                <initializer></initializer>
                <name>header</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The main body text comment added to this parser element's list of comments as a new block.</description>
