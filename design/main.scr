              <operation>Notify that this block requires updating.</operation>
              <operation>Return false to end propagation.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Abstract::Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>childRemoved</name>
              <operation>Notify that this block requires updating.</operation>
              <operation>Return false to end propagation.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>child</name>
                <type>Abstract::Block*</type>
              </data>
            </variable>
          </function>
        </access>
      </class>
      <class>
        <data>
          <description>This is the view class for the function block. This provides custom displays for this function's arguments, its return value, and it number of operations.</description>
          <name>FunctionView</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Basic::BlockView</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new view with the given function block.</description>
              <explicit/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The function block that this new view displays.</description>
                <initializer></initializer>
                <name>block</name>
                <type>const Function*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Returns rich text that displays all variable arguments for this view's function block. If there are no arguments an empty string is returned.</description>
              <name>displayArguments</name>
              <operation>Create an empty return string.</operation>
              <operation>Make a pointer list of all children variables of this view's function block and make sure it is not empty.</operation>
              <operation>Append a title.</operation>
              <operation>Iterate through all child variable blocks, appending a description of each variable into the returned rich text.</operation>
              <operation>Return the arguments rich text.</operation>
              <return_description>Rich text that displays all variable arguments for this view's function block or an empty string if there are no arguments to display.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <description>Returns rich text that displays the return type and description for this view's function block. If the return type is void then an empty string is returned.</description>
              <name>displayReturn</name>
              <operation>Get the return type of this view's function block.</operation>
              <operation>If the return type is empty or is equal to void then return an empty string.</operation>
              <operation>Else this view's function block has a return type so return rich text displaying that return type and its description.</operation>
              <return_description>Rich text that displays the return type and description for this view's function block or an empty string if the return type is void.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <description>Returns rich text that displays the number of operations for this view's function block.</description>
              <name>displayOperations</name>
              <return_description>Rich text that displays the number of operations for this view's function block.</return_description>
              <type>QString</type>
            </data>
          </function>
        </access>
      </class>
    </namespace>
    <class>
      <data>
        <description>This contains a simple message that can be used for throwing messages as an exception to communicate why something failed.</description>
        <name>Exception</name>
      </data>
      <access>
