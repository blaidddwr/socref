          </data>
          <function>
            <data>
              <description>Called when the add action is triggered, adding a new string to this edit widget after the current index.</description>
              <name>addTriggered</name>
              <operation>Add a new string after this object's current model index and then auto fit the text of all rows.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
