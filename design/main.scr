    <function>
      <data>
        <description>Implements the main function.</description>
        <name>main</name>
        <operation>Create a new application.</operation>
        <operation>Create a new global project factory and set it to this programs global project factory instance.</operation>
        <operation>Create a new blank main window and show it.</operation>
        <operation>Execute the application.</operation>
        <operation>Catch any thrown exception, reporting it and exiting this program with a failure code.</operation>
        <return_description>See GCC docs.</return_description>
        <type>int</type>
      </data>
      <variable>
        <data>
          <description>See GCC docs.</description>
          <initializer></initializer>
          <name>argc</name>
          <type>int</type>
        </data>
      </variable>
      <variable>
        <data>
          <description>See GCC docs.</description>
          <initializer></initializer>
          <name>argv</name>
          <type>char**</type>
        </data>
      </variable>
    </function>
