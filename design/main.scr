              <operation>Create an empty return string.</operation>
              <operation>If this class has templates then append an indicator.</operation>
              <operation>Append the base name of this class.</operation>
              <operation>If this class inherits from any other classes append an indicator.</operation>
              <operation>Return the display name string.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
