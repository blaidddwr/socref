      <class type="4">
         <data version="1">
            <name>Application</name>
            <description>This is the main application class for this program. It implements the notify interface to be able to handle exceptions and holds the keys for qt settings.</description>
            <type>QEvent*</type>
            <qtobject/>
         </data>
         <parent type="13">
            <data version="1">
               <name>QApplication</name>
               <access>public</access>
            </data>
         </parent>
         <access type="5">
            <data version="1">
               <type>public:</type>
            </data>
            <constructor type="9">
               <data version="1">
                  <description>Constructs a new application instance.</description>
                  <type></type>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>argc</name>
                     <description>The argument count from main.</description>
                     <type>int&amp;</type>
                  </data>
