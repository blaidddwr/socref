      <class>
        <data>
          <description>This implements the abstract parser class. This is a basic input parser that grabs input from its parent scanner's source file based off a begin begin expression and end expression. Each line in the source file that matches the begin regular expression is added to this parser element's output lines and stops once it encounters a line that matches the end regular expression. The begin and end lines matched are not added as output lines.</description>
          <name>InputParser</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Abstract::Parser</class>
          </data>
