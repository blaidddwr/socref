            <data>
              <const/>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>output</name>
              <operation>Create the return list of comment lines, appending the begin line if it is not empty.</operation>
              <operation>Add empty comment lines equal to this parser element's header lines.</operation>
              <operation>Iterate through all comment blocks of this parser element.</operation>
              <operation>Add the comment block and then its number of blank footer comment lines.</operation>
              <operation>Add the end line if it is not empty and then return the generated comment block lines prepended with indent spaces.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QStringList</type>
              <virtual/>
            </data>
