              <name>_aboutQtAction</name>
              <type>QAction*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is the project properties dialog. This dialog allows the user to view and edit the basic properties of a project. This is a persistent dialog and remembers its geometry.</description>
          <name>ProjectDialog</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>PersistentDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new project dialog with the given project and optional parent. If the given project pointer is null then an exception is thrown.</description>
              <explicit/>
              <name>^</name>
              <operation>Make sure the given project pointer is not null.</operation>
              <operation>Create the GUI of this new dialog and set its window title.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Pointer to the project that this new dialog presents to the user for viewing and editing.</description>
                <initializer></initializer>
                <name>project</name>
                <type>Project*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent for this new dialog.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when this object's OK button is clicked. This applies its project property settings and closes this dialog window.</description>
              <name>okClicked</name>
              <operation>Apply project property settings and close the dialog with accept.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when this object's apply button is clicked. This applies its property settings to its underlying project.</description>
              <name>applyClicked</name>
              <operation>Apply all properties this object's project.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when this object's browse button is clicked. This is used with the scan directory property of a project. This opens a file dialog to find a new directory.</description>
              <name>browseClicked</name>
              <operation>Create a new file dialog to query the user for a new scan directory location.</operation>
              <operation>Execute the file dialog and make sure it returned accepted.</operation>
              <operation>Get the first directory path the user selected from the file dialog.</operation>
              <operation>If the path exists and it is a directory then set the text of this object's scan directory edit widget to it's value.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Constructs and initializes all GUI elements for this new dialog.</description>
              <name>setupGui</name>
              <operation>Create a new vertical layout, adding the form layout then a stretch and then the button layout.</operation>
              <operation>Set the layout of this new dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the form GUI for this new dialog, returning its layout.</description>
              <name>setupForm</name>
              <operation>Create and initialize the name edit widget for this dialog.</operation>
              <operation>Create and initialize the filters edit widget for this dialog.</operation>
              <operation>Create a new form layout, adding the name edit widget then scan directory layout and then the filters edit widget.</operation>
              <operation>Return the form layout.</operation>
              <return_description>Pointer to layout for the form GUI of this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the scan directory form element for this new dialog, returning its layout.</description>
              <name>setupDirectory</name>
              <operation>Create and initialize the scan directory edit widget for this new dialog.</operation>
              <operation>Create the scan directory browse button for this new dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the scan directory edit widget and then the scan directory browse button. </operation>
              <operation>Return the scan directory layout.</operation>
              <return_description>Pointer to layout of the scan directory form element for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes the buttons for this new dialog, return the layout for the new buttons.</description>
              <name>setupButtons</name>
              <operation>Create the OK button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the apply button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the cancel button for this dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the OK button then the apply button then a stretch and then the cancel button.</operation>
              <operation>Return the buttons layout.</operation>
              <return_description>Pointer to the layout of buttons for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <variable>
            <data>
              <description>Pointer to the project this properties dialog is presenting to the user.</description>
              <initializer></initializer>
              <name>_project</name>
              <type>Project*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the name edit widget for this dialog that represents the project's name.</description>
              <initializer></initializer>
              <name>_nameEdit</name>
              <type>QLineEdit*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the scan directory edit widget for this dialog that represents the project's scan directory.</description>
              <initializer></initializer>
              <name>_scanDirectoryEdit</name>
              <type>QLineEdit*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the filters edit widget for this dialog that represents the project's scan filters.</description>
              <initializer></initializer>
              <name>_filtersEdit</name>
              <type>QLineEdit*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is the project dictionary dialog. This displays the list of all custom dictionary words contained in the project it is given. This also allows the user to remove words in the list, but does not allow the user to add new words. Adding new words is done through the spell checking dialog interface.</description>
          <name>DictionaryDialog</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>PersistentDialog</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new dictionary dialog with the given project.</description>
              <name>^</name>
              <operation>Make sure the given project pointer is not null.</operation>
              <operation>Get the dictionary model of the given project.</operation>
              <operation>Create and initialize the GUI of this new dialog and set its window title.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Pointer to the project whose dictionary model is used for this new dictionary dialog.</description>
                <initializer></initializer>
                <name>project</name>
                <type>Project*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when the remove button or shortcut is triggered, removing the currently selected dictionary model index if any is selected.</description>
              <name>removeTriggered</name>
              <operation>Make sure this object's view has an index selected.</operation>
              <operation>Remove the word at the currently selected index from this object's model.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Creates and initializes the GUI for this new dialog.</description>
              <name>setupGui</name>
              <operation>Create the list view for this dialog and set its model to the dictionary.</operation>
              <operation>Create and initialize the remove shortcut action, adding it to this object's list view and connecting its triggered signal.</operation>
              <operation>Create a new vertical layout, adding this object's list view and then its buttons.</operation>
              <operation>Set the layout for this new dialog.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Creates and initializes the buttons for this new dialog, returning the button layout.</description>
              <name>setupButtons</name>
              <operation>Create the remove button, connecting its clicked signal.</operation>
              <operation>Create the close button, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the remove button and then the close button.</operation>
              <operation>Return the button layout.</operation>
              <return_description>Layout of the buttons for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
          <variable>
            <data>
              <description>The List view widget of this dictionary dialog that displays the list of custom dictionary words.</description>
              <initializer></initializer>
              <name>_view</name>
              <type>QListView*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The custom dictionary model of this dialog that it displays and edits.</description>
              <initializer></initializer>
              <name>_model</name>
              <type>DictionaryModel*</type>
            </data>
          </variable>
        </access>
      </class>
    </namespace>
    <namespace>
      <data>
        <description>This contains all classes that implement the block and parsing system with a basic foundation that can be used by specific project types.</description>
        <name>Basic</name>
      </data>
      <class>
        <data>
          <description>This implements the abstract block class. This is designed as a basic block that reads in its type configuration from an XML element supplied to it from its corresponding factory class. The XML definition provides the basic block type information about all data fields it stores, all basic information, the build list for its block type, and definitions for its basic editor and viewer. Instances of this class must be initialized before they can be used. Two additional interfaces are defined in this class for implementations to help in creating copies of itself and defining possible variable types if its project type uses hardly typed variables.

This class can be inherited and most abstract block functionality can be overridden except for any interface related to the block's data, basic interfaces for getting the block's type and factory, and making the editor for basic blocks. Any block class inheriting from this basic block class cannot add additional data, all of which must be defined within the basic block type.

This class provides protected helper methods for getting the values of its data fields. These are intended to be used with specialized implementations of the basic block class that require to know the value of certain data fields. Access to the data fields are read only using these methods.</description>
          <name>Block</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Abstract::Block</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <declaration>
            <data>
              <line>friend class BlockView</line>
            </data>
          </declaration>
          <declaration>
            <data>
              <line>friend class BlockEdit</line>
            </data>
          </declaration>
        </access>
        <access>
          <data>
            <type>public:</type>
          </data>
          <enumeration>
            <data>
              <class/>
              <description>Defines all possible field types for basic block data.</description>
              <name>Field</name>
            </data>
            <enumvalue>
              <data>
                <description>Defines the boolean field type.</description>
                <name>Bool</name>
                <value></value>
              </data>
            </enumvalue>
            <enumvalue>
              <data>
                <description>Defines the string field type.</description>
                <name>String</name>
                <value></value>
              </data>
            </enumvalue>
            <enumvalue>
              <data>
                <description>Defines the string list field type.</description>
                <name>StringList</name>
                <value></value>
              </data>
            </enumvalue>
          </enumeration>
        </access>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>type</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Return the block type of this basic block.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>int</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>factory</name>
