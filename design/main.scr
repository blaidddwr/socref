            <function type="2">
               <data version="0">
                  <name>notify</name>
                  <description>This implements the interface for handling events in the main event loop. The only thing this does is add a catch section so exceptions are handled.</description>
                  <virtual/>
                  <override/>
                  <final/>
                  <type>bool</type>
                  <return_description>True if the event was processed or false otherwise.</return_description>
                  <operation>Call the Qt application notify method and return its value.</operation>
                  <operation>If any exception is caught then report it to the qt debug stream and return false.</operation>
               </data>
               <variable type="1">
                  <data version="0">
                     <name>receiver</name>
                     <description>Pointer to the object that received the event.</description>
                     <type>QObject*</type>
                  </data>
               </variable>
