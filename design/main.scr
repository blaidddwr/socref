              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the description for the return type of this function block.</description>
              <name>returnDescription</name>
              <return_description>The description for the return type of this function block.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this function block's return block is void and therefore has no return, returning true if it is.</description>
              <name>isVoidReturn</name>
              <operation>Test to see if this function block's return type is void.</operation>
              <return_description>True if this function block's return type is void or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the steps of operations for this function block, whose list of strings is used for inline comments.</description>
              <name>operations</name>
