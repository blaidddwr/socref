            <data>
              <description>Called when the add action is triggered, adding a new string to this edit widget after the current index.</description>
              <name>addTriggered</name>
              <operation>If the current index is valid then add a new string after it.</operation>
              <operation>Else add a new string at the beginning of the model.</operation>
