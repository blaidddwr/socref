                  </data>
               </function>
               <function type="2">
                  <data version="0">
                     <name>autoFitText</name>
                     <description>Updates the row height of all text cells for this list edit widget so all the text fits within the current width of this widget.</description>
                     <type>void</type>
                  </data>
               </function>
               <function type="2">
                  <data version="0">
                     <name>autoFitText</name>
                     <description>Updates the height of a given row of this list edit widget so all the text fits within the current width of its cell.</description>
                     <type>void</type>
                     <operation>Create font metrics, get the cell width _width_, and get the text of the string at the given row _text_.</operation>
                     <operation>Create and initialize _lines_, _start_, and _lastSpace_, all used for determining the number of lines _text_ requires to fit within the _width_ constraint.</operation>
                     <operation>Iterate through _text_ to determine the number of lines needed to constrain the text within the constraint _width_. Save the number of lines needed to _lines_.</operation>
                     <operation>Set the row height of the cell at the given row based off the calculated lines needed to git within the cell's width.</operation>
                  </data>
                  <variable type="1">
                     <data version="0">
                        <name>row</name>
                        <description>The row whose height is updated so all text fits with the current width of this list edit widget.</description>
                        <type>int</type>
                     </data>
                  </variable>
               </function>
               <variable type="1">
                  <data version="0">
                     <name>_listItemTitle</name>
                     <description>The title text used for the title of each text row in this list edit widget. This title is appended with the row number.</description>
                     <type>QString</type>
                     <initializer>"Step"</initializer>
                  </data>
               </variable>
               <variable type="1">
                  <data version="0">
                     <name>_model</name>
                     <description>Pointer to the string list model for this list edit widget.</description>
                     <type>Model*</type>
                  </data>
               </variable>
