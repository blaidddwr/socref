    </namespace>
    <namespace>
      <data>
        <description>Contains the GLSL project type.</description>
        <name>GLSL</name>
      </data>
      <namespace>
        <data>
          <description>Contains all GLSL parsing elements.</description>
          <name>Parse</name>
        </data>
        <class>
          <data>
            <description>This is the parser factory for the GLSL project type. This recognizes only one type of source file, that being a shader source file that defines a single GLSL shader. Sub extensions are also used to identify the shader type. All shader types defined as of OpenGL version 4.3 are recognized.</description>
            <name>Factory</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>AbstractParserFactory</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <const/>
                <description>Implements _AbstractParserFactory_ interface.</description>
                <final/>
                <name>make</name>
                <operation>Initialize a static list of all possible sub extensions for the different shader types.</operation>
                <operation>Split the given name into its actual name and the sub extension, making sure there is only one period separating the two.</operation>
                <operation>Figure out the shader type of this file based off of its sub extension, making sure the sub extension string is recognized.</operation>
                <operation>Separate the list of namespace names and shader name in the files given name.</operation>
                <operation>Create a reverse stack of pointers to the namespace name strings that will be worked on by the recursive find function.</operation>
                <operation>Call the recursive find method that attempts to find a matching shader, returning its result.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>Soc::Ut::QPtr&lt;AbstractParser></type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>extension</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new GLSL parser factory with the given root block.</description>
                <explicit/>
                <name>^</name>
                <operation>Make sure the given root pointer is not null.</operation>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The root block used by this parser factory.</description>
                  <initializer></initializer>
                  <name>root</name>
                  <type>const AbstractBlock*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Recursively attempts to find a matching namespace that is a child of the given namespace and matches the top string pointed to on the given stack. This continues recursively calls itself until a shader that matches is found and a parser returned or no match is found and a null pointer is returned.</description>
                <name>find</name>
                <operation>If there is only one name left in the given stack then call the find shader function.</operation>
                <operation>Else there is more namespace names to resolve.</operation>
                <operation>Get the next name from the given stack.</operation>
                <operation>Search the given base namespace block's children, recursively calling this function if a namespace that matches the next name is found.</operation>
                <operation>No namespace name match is found so return a null pointer.</operation>
                <return_description>Pointer to new shader parser if a match is found or a null pointer if no match is found.</return_description>
                <static/>
                <type>AbstractParser*</type>
              </data>
              <variable>
                <data>
                  <description>The current namespace that is being searched for a child namespace or shader.</description>
                  <initializer></initializer>
                  <name>base</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The stack of names still to be resolved. The very last name being the name of the shader that is being searched. These are pointers to strings so the strings must not be destroyed while this function is being called.</description>
                  <initializer></initializer>
                  <name>names</name>
                  <type>QStack&lt;const QString*>*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The shader type that should be matched with its name.</description>
                  <initializer></initializer>
                  <name>type</name>
                  <type>GLSL::Shader::Type</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Attempts to find a matching shader with the given name and type as a child in the given namespace. This returns a pointer to a new shader parser if a match is found or a null pointer if no match is found.</description>
                <name>findShader</name>
                <operation>Search the given base namespace block's children, returning a new shader parser of a matched shader if it is found.</operation>
                <operation>No shader match is found so return a null pointer.</operation>
                <return_description>Pointer to new shader parser if a match is found or a null pointer if no match is found.</return_description>
                <static/>
                <type>AbstractParser*</type>
              </data>
              <variable>
                <data>
                  <description>The namespace whose children are searched for a matching shader block.</description>
                  <initializer></initializer>
                  <name>base</name>
                  <type>const Namespace*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The base name of the shader that should be matched.</description>
                  <initializer></initializer>
                  <name>name</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The type of the shader that should be matched.</description>
                  <initializer></initializer>
                  <name>type</name>
                  <type>GLSL::Shader::Type</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <variable>
              <data>
                <description>Pointer to the root block used by this parser factory and all parser objects it makes.</description>
                <initializer></initializer>
                <name>_root</name>
                <type>const Namespace*</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the base parser that all other GLSL parser classes use for common functionality. Currently the only common functionality is adding comments.</description>
            <name>Base</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>AbstractParser</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <declaration>
              <data>
                <line>using AbstractParser::AbstractParser</line>
              </data>
            </declaration>
            <function>
              <data>
                <description>This interface outputs the number of blank lines that precedes this parser object's definition. The default implementation does nothing.</description>
                <name>outputLines</name>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>This interface outputs the comments and definition of this parser. In the case of the special main function of a shader program the comment header is not added to output in this interface. The default implementation does nothing.</description>
                <name>outputDefinition</name>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface. This implementation does nothing and is defined because some GLSL parser classes do not need to implement this.</description>
                <name>makeOutput</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Wrapper for the _AbstractParser_ method.</description>
                <name>addComment</name>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The text that is used to make and added and formatted output lines.</description>
                  <initializer></initializer>
                  <name>text</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The justification used for adding extra spaces before every output line after the first.</description>
                  <initializer>0</initializer>
                  <name>justified</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
          </access>
        </class>
        <class>
          <data>
            <description>This is the shader root parser. This parser is responsible for parsing a shader program file. It collects all defined variables, structures, and functions and outputs them to the source file. It also reads in any undefined functions found in the source file and outputs them again as an unknown function.</description>
            <name>Shader</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Base</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new shader root parser with the given shader block.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The shader block that defines this new root parser.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const GLSL::Shader*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>initialize</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>readLine</name>
                <operation>If this is a preprocessor line then add it to this parser object's list of preprocessor lines.</operation>
                <operation>Else check to see if the given line is a header of a function.</operation>
                <operation>If this function is defined in this shader parser then step into it for read line processing.</operation>
                <operation>Else check if this is an undefined function found in the shader source file.</operation>
                <operation>Add a new undefined function parser and then step into it for read line processing.</operation>
                <operation>Always return true because this root shader parser reads the entire source file.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>makeOutput</name>
                <operation>Add any preprocessor lines to output.</operation>
                <operation>Iterate through all parser children of this root parser.</operation>
                <operation>Add the blank lines and then the definition of the child parser to output.</operation>
                <operation>Add the blank lines, comment header, definition header, and then definition of the special main function for the shader program file.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Evaluates all children of this object's shader block, adding new child parser objects for each variable, struct, and function block it finds.</description>
                <name>evaluate</name>
                <operation>Iterate through all children of this shader parser object's shader block.</operation>
                <operation>If the child is a variable block then make a new child parser and add it to this object's list of parser children.</operation>
                <operation>If the child is a struct block then make a new child parser and add it to this object's list of parser children.</operation>
                <operation>If the child is a function block then make a new child parser and add it to this object's list of parser children and its list of defined functions.</operation>
                <operation>Lastly create a function parser for the special main function of this parser object's shader block.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Attempts to find a defined function definition of this parser with the given definition string. If a match is found its function parser pointer is returned.</description>
                <name>findDefined</name>
                <operation>If the given definition matches the special main function then return its pointer.</operation>
                <operation>Iterate through all defined function parser objects of this parser.</operation>
                <operation>If the function parser matches the given definition header then return its pointer.</operation>
                <operation>No match was found so return null.</operation>
                <return_description>Pointer of matched function parser if match is found or null if no match is found.</return_description>
                <type>Function*</type>
              </data>
              <variable>
                <data>
                  <description>The function definition header whose match is looked for in this object's list of defined function parser objects.</description>
                  <initializer></initializer>
                  <name>definition</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <variable>
              <data>
                <description>Pointer to the shader block that defines this parser.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>const GLSL::Shader*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of parser children that is part of this shader object's shader program.</description>
                <initializer></initializer>
                <name>_children</name>
                <type>QList&lt;Base*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of defined function parser children that is part of this shader object's shader program.</description>
                <initializer></initializer>
                <name>_defined</name>
                <type>QList&lt;Function*></type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The special main function parser that is part of this shader object's shader program.</description>
                <initializer></initializer>
                <name>_main</name>
                <type>Function*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List preprocessor lines for the shader program source file of this parser.</description>
                <initializer></initializer>
                <name>_preProcess</name>
                <type>QStringList</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the variable parser. This outputs all variable definitions for a shader source file. This parser does not require reading in any lines of code.</description>
            <name>Variable</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Base</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Implements _GLSL::Parse::Base_ interface.</description>
                <name>outputLines</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _GLSL::Parse::Base_ interface.</description>
                <name>outputDefinition</name>
                <operation>Output the description of this parser object's variable block.</operation>
                <operation>Output the definition.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new variable parser with the given variable block and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>Variable block that defines this new parser.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const GLSL::Variable*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser object for this new variable parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface. This parser does not read in any input so this does nothing.</description>
                <final/>
                <name>readLine</name>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Returns the layout part of this parser object's variable definition.</description>
                <name>makeLayout</name>
                <operation>Create a new string that will be returned and get all layout qualifiers of this parser object's variable block.</operation>
                <operation>If there are no qualifiers then return an empty string.</operation>
                <operation>Add the beginning of the layout definition.</operation>
                <operation>Iterate through all qualifiers and add them to the layout definition.</operation>
                <operation>Add the end of the layout definition and return it.</operation>
                <return_description>Layout part of this parser object's variable definition.</return_description>
                <type>QString</type>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Returns the name of this parser object's variable definition, prepending a space if it is not empty.</description>
                <name>makeName</name>
                <operation>Return the base name of this object's variable block, prepending a space if it is not empty.</operation>
                <return_description>Name of this parser object's variable definition.</return_description>
                <type>QString</type>
              </data>
            </function>
            <variable>
              <data>
                <description>Pointer to the variable block that defines this parser.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>const GLSL::Variable*</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the struct parser. This outputs all struct definitions, including the variable definitions contained within the struct, for a shader source file. This parser does not require reading in any lines of code.</description>
            <name>Struct</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Variable</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Implements _GLSL::Parse::Base_ interface.</description>
                <final/>
                <name>outputLines</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _GLSL::Parse::Base_ interface.</description>
                <final/>
                <name>outputDefinition</name>
                <operation>Output the description of this parser object's struct block.</operation>
                <operation>Output the definition and opening bracket.</operation>
                <operation>Increment the indent, output all variable comments and definitions, and then decrement the indent.</operation>
                <operation>Output the closing bracket, name, and closing semicolon for this struct definition.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new struct parser with the given struct block and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>Struct block that defines this new parser.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const GLSL::Struct*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser object for this new variable parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Adds the definitions of all variables this parser object's struct block contains along with their description comment before every definition.</description>
                <name>makeVariables</name>
                <operation>Get the list of all child variable blocks of this parser object's struct block.</operation>
                <operation>Iterate through the list of variable blocks.</operation>
                <operation>If this is not the first variable definition then add one blank line.</operation>
                <operation>Add the description of the variable block to output.</operation>
                <operation>Add the definition of the variable block to output.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <variable>
              <data>
                <description>Pointer to the struct block that defines this parser.</description>
                <initializer></initializer>
                <name>_block</name>
                <type>const GLSL::Struct*</type>
              </data>
            </variable>
          </access>
        </class>
        <class>
          <data>
            <description>This is the function parser. This is responsible for parsing all function definitions inside a shader program, including the special main function. This reads in all code lines defined within any function present in a shader source file.

This parser can be defined, undefined, or the special main function. A defined function means it is linked with an actual function block. An undefined function parser means it is an unknown function definition found in the shader source file. The special main function is the main function of the shader program.

Because this function parser is responsible for the special main function it must copy a reference of the operations for its function instead of simply using the function block interface.</description>
            <name>Function</name>
            <qtobject/>
          </data>
          <parent>
            <data>
              <access>public</access>
              <class>Base</class>
            </data>
          </parent>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Implements _GLSL::Parse::Base_ interface.</description>
                <final/>
                <name>outputLines</name>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
            <function>
              <data>
                <description>Implements _GLSL::Parse::Base_ interface.</description>
                <final/>
                <name>outputDefinition</name>
                <operation>Check if this is a defined function.</operation>
                <operation>Make comment header output and then add the definition line to output.</operation>
                <operation>Else check if this is an undefined function.</operation>
                <operation>Add a comment highlighting this is an unknown function and the static string definition to output.</operation>
                <operation>If this object has no code lines then add an opening and closing bracket to output.</operation>
                <operation>Else this object does have code lines so add them to output with an opening and closing bracket.</operation>
                <override/>
                <return_description></return_description>
                <type>void</type>
                <virtual/>
              </data>
            </function>
          </access>
          <access>
            <data>
              <type>public:</type>
            </data>
            <function>
              <data>
                <description>Constructs a new function parser as undefined with the given static definition header and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>Static definition header for this new undefined function parser.</description>
                  <initializer></initializer>
                  <name>definition</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser object for this new function parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Constructs a new function parser as defined with the given function block and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The function block that defines this new function parser.</description>
                  <initializer></initializer>
                  <name>block</name>
                  <type>const GLSL::Function*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser object for this new function parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Constructs a new function parser as the special main function of a shader program file with the given steps of operation and parent parser.</description>
                <explicit/>
                <name>^</name>
                <return_description></return_description>
                <type></type>
              </data>
              <variable>
                <data>
                  <description>The steps of operation for the special main function of this parser object's shader source file.</description>
                  <initializer></initializer>
                  <name>operations</name>
                  <type>const QStringList&amp;</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The parent parser object for this new function parser.</description>
                  <initializer></initializer>
                  <name>parent</name>
                  <type>AbstractParser*</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Determines if the given line matches the definition header for this function parser, returning true if it is a match. If the function parser already has code or is not a defined parser then false is always returned.</description>
                <name>isMatch</name>
                <operation>Make sure this object does not have code.</operation>
                <operation>Check to see if this parser object does not have a valid function block pointer.</operation>
                <operation>If this parser is undefined then return false else this is the special main function so match the given line against that definition.</operation>
                <operation>Create a new regular expression line with this object's function's name.</operation>
                <operation>Add any arguments of this object's function to the regular expression line.</operation>
                <operation>Add the closing syntax to the regular expression line.</operation>
                <operation>Evaluate the line with the constructed regular expression line to determine a match, returning its result.</operation>
                <return_description>True if the given line matches the definition header for this parser or false if it does not, it has code, or is undefined.</return_description>
                <type>bool</type>
              </data>
              <variable>
                <data>
                  <description>The line presumed to be another function definition header that is matched with this function parser.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>protected:</type>
            </data>
            <function>
              <data>
                <description>Implements _AbstractParser_ interface.</description>
                <final/>
                <name>readLine</name>
                <operation>If the given line is a opening and closing bracket that means this function has no code lines so return false.</operation>
                <operation>Check to see if the given line is an opening bracket.</operation>
                <operation>Increment the bracket level by one, returning true if this is the very first opening bracket.</operation>
                <operation>Check to see if the given line is a closing bracket.</operation>
                <operation>Decease the bracket level by one, returning false if this is the final closing bracket.</operation>
                <operation>Check to see if the given line is inside the main opening and closing brackets.</operation>
                <operation>Check to see if the given line is an inline comment, making sure this is not an undefined function.</operation>
                <operation>If the given inline comment line is the first for its grouping then set this object's edge past to true and process the inline comment, if this is a proceeding inline comment line after the first then just ignore it.</operation>
                <operation>Else the given line is regular code so set this object's edge past to false and add the given line to this object's code line list.</operation>
                <operation>The given line is not the last line of code for this function so return true.</operation>
                <override/>
                <return_description>See interface docs.</return_description>
                <type>bool</type>
                <virtual/>
              </data>
              <variable>
                <data>
                  <description>See interface docs.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
          </access>
          <access>
            <data>
              <type>private:</type>
            </data>
            <function>
              <data>
                <description>Processes the given inline comment line, adding the next step of operations of this object's function as an inline comment to this object's code line list or a blank inline comment if there are no more steps of operation to use.</description>
                <name>processInlineComment</name>
                <operation>Calculate the number of spaces that should be used for this inline comment grouping.</operation>
                <operation>If the next operation iterator of this object is not past the end of this object's function's steps of operation then insert an inline comment with the next operation.</operation>
                <operation>Else there are no more steps of operation to add as inline comments so add a blank inline comment to this object's code line list.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The inline comment given as an input line from the read line interface. The line must not be modified so the number of spaces can be calculated.</description>
                  <initializer></initializer>
                  <name>line</name>
                  <type>const QString&amp;</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>Inserts a new inline comment to this object's code line list with the given steps of operation index and spacing, separating the comment into as many number of lines as needed.</description>
                <name>insertInlineComment</name>
                <operation>Split operation from this object's function's steps of operation with the given index into a list of words.</operation>
                <operation>Keep going until the list of words is empty.</operation>
                <operation>Create a total columns used variable with the first word's size plus one space.</operation>
                <operation>Create a new line string, adding spaces then comment characters then the first word from the list and then a space.</operation>
                <operation>Keep going until the word list is empty or the line has reached the maximum number of columns.</operation>
                <operation>Take and add the next word from the list to the line and an additional space, adding the number of columns the addition used.</operation>
                <operation>Add the inline comment line to this object's code line list.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
              <variable>
                <data>
                  <description>The index of the operation in this object's function's steps of operation to use to generate the inline comment.</description>
                  <initializer></initializer>
                  <name>index</name>
                  <type>int</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The number of spaces added before every inline comment line generated.</description>
                  <initializer></initializer>
                  <name>spacing</name>
                  <type>int</type>
                </data>
              </variable>
            </function>
            <function>
              <data>
                <description>This adds the comment header of a defined function to this parser object's output lines. This parser must contain a valid pointer to a valid function block or its behavior is undefined.</description>
                <name>makeCommentOutput</name>
                <operation>Add an empty comment line and then the function's description.</operation>
                <operation>Iterate through all variable blocks of this parser object's function block.</operation>
                <operation>Add an empty comment line to output.</operation>
                <operation>Create a base string that starts with the variable name and a space, getting the justified length from the base string length.</operation>
                <operation>Add comments from the base string and the variable's description.</operation>
                <operation>If this parser object's function block does not have a void return then add the description for the return variable.</operation>
                <operation>Finish by adding an empty comment line.</operation>
                <return_description></return_description>
                <type>void</type>
              </data>
            </function>
            <function>
              <data>
                <description>Makes and returns the argument list for this object's function. The returned arguments string includes the opening and closing parenthesis. This parser must contain a valid pointer to a valid function block or its behavior is undefined.</description>
                <name>makeArguments</name>
                <operation>Create a new return string with the opening parenthesis.</operation>
                <operation>Iterate through all arguments of this object's function block.</operation>
                <operation>If this is not the first argument then add a separating comma and space.</operation>
                <operation>Append the argument type, a space, and its name.</operation>
                <operation>Add the closing parenthesis.</operation>
                <operation>Return the arguments string.</operation>
                <return_description>Argument list for this object's function, including the opening and closing parenthesis.</return_description>
                <type>QString</type>
              </data>
            </function>
            <variable>
              <data>
                <description>Pointer to this object's function block if it is defined and not the main function. If it is undefined for the main function this is null.</description>
                <initializer>nullptr</initializer>
                <name>_block</name>
                <type>const GLSL::Function*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Static definition string that contains the definition header for this parser if it is undefined, otherwise this remains empty.</description>
                <initializer></initializer>
                <name>_definition</name>
                <type>QString</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The steps of operation for this function parser if it is defined or the special main function. If this is an undefined function parser this remains empty.</description>
                <initializer></initializer>
                <name>_operations</name>
                <type>const QStringList</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>List of code lines for this parser object's function definition.</description>
                <initializer></initializer>
                <name>_code</name>
                <type>QStringList</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The current number of bracket levels this parser is in while reading in lines. Used for processing input. Each opening bracket is one level up and closing bracket is one level down.</description>
                <initializer>0</initializer>
                <name>_level</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if an inline comment is currently being read in and the first line of it has already been read or false otherwise.</description>
                <initializer>false</initializer>
                <name>_edgePast</name>
                <type>bool</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The next index to be used in this object's steps of operation for inserting inline comments.</description>
                <initializer>0</initializer>
                <name>_nextOperation</name>
                <type>int</type>
              </data>
            </variable>
          </access>
        </class>
      </namespace>
      <class>
        <data>
          <description>This is the singleton settings class that holds all global settings for GLSL projects. This class uses qt settings behind the scenes to make its setting persistent. As mentioned, it is also a single global class since it holds global settings.</description>
          <name>Settings</name>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Soc::Ut::Singleton&lt;Settings></class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <class>
            <data>
              <description>This is the settings dialog. This allows the user to edit all global settings for the GLSL project type.</description>
              <name>Dialog</name>
              <qtobject/>
            </data>
            <parent>
              <data>
                <access>public</access>
                <class>Gui::PersistentDialog</class>
              </data>
            </parent>
            <access>
              <data>
                <type>public:</type>
              </data>
              <function>
                <data>
                  <description>Constructs a new settings dialog.</description>
                  <explicit/>
                  <name>^</name>
                  <operation>Create the GUI for this new dialog and set its window title.</operation>
                  <return_description></return_description>
                  <type></type>
                </data>
              </function>
            </access>
            <access>
              <data>
                <type>private slots:</type>
              </data>
              <function>
                <data>
                  <description>Called when the OK button is clicked. This applies all global settings and closes the dialog.</description>
                  <name>okClicked</name>
                  <operation>Apply all global settings of this dialog and close it.</operation>
                  <return_description></return_description>
                  <type>void</type>
                </data>
              </function>
              <function>
                <data>
                  <description>Called when the apply button is clicked. This applies the global setting values of this dialog.</description>
                  <name>applyClicked</name>
                  <operation>Get the global settings object and apply all settings.</operation>
                  <return_description></return_description>
                  <type>void</type>
                </data>
              </function>
            </access>
            <access>
              <data>
                <type>private:</type>
              </data>
              <function>
                <data>
                  <description>Creates and initializes all GUI elements for this new dialog.</description>
                  <name>setupGui</name>
                  <operation>Create a new vertical layout, adding the form layout and then the buttons layout.</operation>
                  <operation>Set the layout of this new dialog.</operation>
                  <return_description></return_description>
                  <type>void</type>
                </data>
              </function>
              <function>
                <data>
                  <description>Creates and initializes all edit widgets for this new dialog, returning a form layout containing the edit widgets.</description>
                  <name>setupForm</name>
                  <operation>Get the global settings instance.</operation>
                  <operation>Create the variable lines edit widget and set its value to the current global setting.</operation>
                  <operation>Create the structure lines edit widget and set its value to the current global setting.</operation>
                  <operation>Create the function lines edit widget and set its value to the current global setting.</operation>
                  <operation>Create the indent spaces edit widget and set its value to the current global setting.</operation>
                  <operation>Create the max columns edit widget and set its value to the current global setting.</operation>
                  <operation>Create a new form layout, adding the indent spaces widget then the header lines widget then the function lines widget and then the max columns widget.</operation>
                  <operation>Return the form layout.</operation>
                  <return_description>Form layout containing all edit widgets for this new dialog.</return_description>
                  <type>QLayout*</type>
                </data>
              </function>
              <function>
                <data>
                  <description>Creates and initializes the OK, apply, and cancel buttons for this new dialog, returning the buttons layout.</description>
                  <name>setupButtons</name>
                  <operation>Create the OK button for this dialog, connecting its clicked signal.</operation>
                  <operation>Create the apply button for this dialog, connecting its clicked signal.</operation>
                  <operation>Create the cancel button for this dialog, connecting its clicked signal.</operation>
                  <operation>Create a new horizontal layout, adding the OK button then the apply button then a stretch and then the cancel button.</operation>
                  <operation>Return the buttons layout.</operation>
                  <return_description>Layout containing buttons for this new dialog.</return_description>
                  <type>QLayout*</type>
                </data>
              </function>
              <variable>
                <data>
                  <description>The edit widget for the variable lines setting.</description>
                  <initializer></initializer>
                  <name>_variableLinesBox</name>
                  <type>QSpinBox*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The edit widget for the structure lines setting.</description>
                  <initializer></initializer>
                  <name>_structLinesBox</name>
                  <type>QSpinBox*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The edit widget for the function lines setting.</description>
                  <initializer></initializer>
                  <name>_functionLinesBox</name>
                  <type>QSpinBox*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The edit widget for the indent spaces setting.</description>
                  <initializer></initializer>
                  <name>_indentSpacesBox</name>
                  <type>QSpinBox*</type>
                </data>
              </variable>
              <variable>
                <data>
                  <description>The edit widget for the max columns setting.</description>
                  <initializer></initializer>
                  <name>_maxColumnsBox</name>
                  <type>QSpinBox*</type>
                </data>
              </variable>
            </access>
          </class>
        </access>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new settings global instance, retrieving all persistent settings from qt settings.</description>
              <name>^</name>
              <operation>Create a qt settings object and restore all global settings to their persistent values.</operation>
              <return_description></return_description>
              <type></type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the variable lines setting.</description>
              <name>variableLines</name>
              <return_description>Variable lines setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the structure lines setting.</description>
              <name>structLines</name>
              <return_description>Structure lines setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the function lines setting.</description>
              <name>functionLines</name>
              <return_description>Function lines setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the indent spaces setting.</description>
              <name>indentSpaces</name>
              <return_description>Indent spaces setting.</return_description>
              <type>int</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
