        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>Creates and returns a block of comment lines generated from the given header and text. The header can be empty, in that case it is ignored and the text is not justified. If a header is given the text will be justified to the right of the header after the first line. If the text is empty this returns an empty list.</description>
              <name>createComment</name>
              <operation>Make sure the given text is not empty.</operation>
              <operation>If the given header is not empty then append a single space to the end as a border between it and the comment text.</operation>
              <operation>Initialize the justified length, returned comment line list, and first line indicator.</operation>
              <operation>Split the given text into paragraphs using double newline characters as the separator and then iterate through all paragraphs.</operation>
              <operation>Split the paragraph into its separate words.</operation>
              <operation>Continue until the word list is empty.</operation>
              <operation>Initialize the total columns taken and new comment line to be added, middle token, and then another space.</operation>
              <operation>Check to see if this is the first comment line.</operation>
              <operation>Add the header to the total columns taken and the comment line, updating the first indicator to false.</operation>
              <operation>Else this is not the first comment line.</operation>
              <operation>Justify the words to be added to the right of the header on the first line.</operation>
              <operation>Add the first word to to the total columns taken and the comment line.</operation>
              <operation>Continue until there are no more words to add or the maximum column size for the comment line has been reached.</operation>
              <operation>Add the next word to the comment line, updating the total columns taken.</operation>
              <operation>Add the generated comment line to the line list.</operation>
              <operation>If this is not the last sentence then add an empty comment line to the line list.</operation>
              <operation>Return the generated comment block lines.</operation>
              <return_description>Block of comment lines generated from the given header and text.</return_description>
              <type>QStringList</type>
            </data>
            <variable>
              <data>
                <description>The optional header that the comment text if justified to the right after the first comment line generated.</description>
                <initializer></initializer>
                <name>header</name>
                <type>QString</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The main body text used to generate the returned comment block lines, wrapped to not exceed the maximum number of columns per line.</description>
                <initializer></initializer>
                <name>text</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The number of space characters prepended to each line of comment block output when this parser generates it for its parent scanner.</description>
              <initializer>0</initializer>
              <name>_indent</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The beginning line that is provided as the first line for this comment parser element.</description>
              <initializer></initializer>
              <name>_begin</name>
              <type>const QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The middle token that is prepended to each comment line provided by this comment parser element.</description>
              <initializer></initializer>
              <name>_middle</name>
              <type>const QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The ending line that is provided as the last line for this comment parser element.</description>
              <initializer></initializer>
              <name>_end</name>
              <type>const QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The maximum number of columns per comment line provided by this comment parser element.</description>
              <initializer></initializer>
              <name>_maxColumns</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The number of blank lines provided before the first comment block by this comment parser element.</description>
              <initializer>0</initializer>
              <name>_headerLines</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>List of comment blocks that are used for generating the provided lines in between the optional begin and end lines by this comment parser element.</description>
              <initializer></initializer>
              <name>_comments</name>
              <type>QList&lt;Node></type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This implements the abstract parser class. This provides lines representing a single function with this parser element's parent scanner's source file. This will grab input from the source file if the matching function is found, taking all lines of that function. These input lines are then parsed, cutting off any additional indent spacing and adding inline comments as needed. Steps of operation are provided for filling in the inline comments.

The function is matched in the source file based off a header regular expression that is built with provided methods of this class. Once matched lines will be read as input until the last out token is found signaling the end of the function. The first header line defining the function and last line with the final out token will be included in input.

Additional parsing is done with the input lines by looking for marker lines of inline comments. The provided comment begin string is matched with the beginning of the string, excluding any preceding white space. Each consecutive lines of inline comment matches will be treated as a single inline comment and filled in with the specific operation in the provided steps of operation. The order of inline comments will be matched with the order provided in the steps of operation.</description>
          <name>FunctionParser</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>Abstract::Parser</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>output</name>
              <operation>Copy this object's list of output lines, adding in and out token lines if it only contains a single header line.</operation>
              <operation>Return the output lines prepended with this object's indent spacing.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QStringList</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>needsInput</name>
              <operation>Make sure input has not been read and a header regular expression is defined.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>headerExpression</name>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>setIndent</name>
              <operation>Make sure the given indent is not negative.</operation>
              <operation>Set this object's indent to the new value.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>value</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>input</name>
              <operation>Check to see if this is the first input line parsed by this object.</operation>
              <operation>Determine the cut off and set it to the instance wide cut off value.</operation>
              <operation>Set the first line indicator to false and return true to get more input.</operation>
              <operation>Determine the cut off for this line based off the minimum of this lines spaces or the instance wide cutoff.</operation>
              <operation>Check to see if the given line is an inline comment line.</operation>
              <operation>Check to see if this is the first line of an inline comment block.</operation>
              <operation>Mark the comment block edge past indicator to true and process this inline comment block.</operation>
              <operation>Else the given line is not an inline comment.</operation>
              <operation>Mark the edge past indicator to false for the next possible inline comment block and add the given line to this object's output lines, cutting off the extra initial white space.</operation>
              <operation>Determine the depth of execution block this given line ends with.</operation>
              <operation>If this input line is the end of this function in this parent scanner's source file then return false to end getting input else return true to get more.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>bool</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>line</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Implements _Abstract::Parser_ interface.</description>
              <final/>
              <name>reset</name>
              <operation>Resets all instance variables used for processing input lines to their default state.</operation>
              <operation>Clear any generated output lines parsed from previous input lines.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
          </function>
        </access>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new function parser with the given in token, out token, comment begin string, maximum columns per inline comment, and steps of operation.</description>
              <explicit/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>The character used by this parent scanner's source file to begin a block of execution.</description>
                <initializer></initializer>
                <name>inToken</name>
                <type>QChar</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The character used by this parent scanner's source file to end a block of execution.</description>
                <initializer></initializer>
                <name>outToken</name>
                <type>QChar</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The characters used by this parent scanner's source file to begin an inline comment line.</description>
                <initializer></initializer>
                <name>commentBegin</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The maximum number of columns per line this parser will generate for inline comment blocks.</description>
                <initializer></initializer>
                <name>maxColumns</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The header or full name of this function that will be used as the first line of output for this function parser.</description>
                <initializer></initializer>
                <name>header</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>A list of operation step descriptions this function parser uses to generate inline comment block lines.</description>
                <initializer></initializer>
                <name>operations</name>
                <type>const QStringList&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Appends the given text to the header regular expression of this function parser, escaping all characters to be taken literally by the regular expression interpreter.</description>
              <name>add</name>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>Text that is escaped and then appended to the header expression of this function parser.</description>
                <initializer></initializer>
                <name>text</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Appends the given expression to the header regular expression of this function parser. The given expression is not escaped and appended without modification to the header.</description>
              <name>addExp</name>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>Expression that is appended to the header expression of this function parser.</description>
                <initializer></initializer>
                <name>expression</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Processes the given inline comment line, adding the next step of operations of this function parser as an inline comment to this object's output lines or a blank inline comment if there are no more steps of operation to use.</description>
              <name>processInlineComment</name>
              <operation>Calculate the number of spaces that should be used for this inline comment grouping.</operation>
              <operation>If the next operation iterator of this object is not past the end of this object's steps of operation then insert an inline comment with the next operation.</operation>
              <operation>Else there are no more steps of operation to add as inline comments so add a blank inline comment to this object's output lines.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The inline comment given as an input line from the input interface.</description>
                <initializer></initializer>
                <name>line</name>
                <type>const QString&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Inserts new inline comment lines to this object's output lines with the given steps of operation index and spacing.</description>
              <name>insertInlineComment</name>
              <operation>Split operation from this object's steps of operation with the given index into a list of words.</operation>
              <operation>Keep going until the list of words is empty.</operation>
              <operation>Create a total columns used variable with the first word's size plus one space.</operation>
              <operation>Create a new line string, adding spaces then comment characters then the first word from the list.</operation>
              <operation>Keep going until the word list is empty or the line has reached the maximum number of columns.</operation>
              <operation>Take and add the next word from the list, adding the number of columns the addition used.</operation>
              <operation>Add the inline comment line to this parser element's output list.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The index of the operation in this object's steps of operation used to generate the inline comment.</description>
                <initializer></initializer>
                <name>index</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The number of spaces added before every inline comment line generated.</description>
                <initializer></initializer>
                <name>spacing</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The character used to denote the beginning of a block of execution. This is used to determine the end of a function with this parser element's parent scanner's source file.</description>
              <initializer></initializer>
              <name>_inToken</name>
              <type>const QChar</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The character used to denote the end of a block of execution. This is used to determine the end of a function with this parser element's parent scanner's source file.</description>
              <initializer></initializer>
              <name>_outToken</name>
              <type>const QChar</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The string used at the beginning of an input line, excluding any preceding white space, to denote that input line is an inline comment.</description>
              <initializer></initializer>
              <name>_commentBegin</name>
              <type>const QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The maximum number of columns allowed for a single line of an inline comment.</description>
              <initializer></initializer>
              <name>_maxColumns</name>
              <type>const int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The header or full name of this function that will be used as the first line of output for this function parser.</description>
              <initializer></initializer>
              <name>_header</name>
              <type>const QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Steps of operation for this function. This is used as inline comments, following the same order as inline comments are found when parsing the input lines.</description>
              <initializer></initializer>
              <name>_operations</name>
              <type>const QStringList</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The regular expression used to match the first input line of this parser element's function within its parent scanner's source file.</description>
              <initializer></initializer>
              <name>_headerExp</name>
              <type>QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The number of indent spaces prepended to each output line of this function parser element.</description>
              <initializer>0</initializer>
              <name>_indent</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>True if the first line has not been read or false otherwise. This is used to determine the number of spaces on the first line.</description>
              <initializer>true</initializer>
              <name>_first</name>
              <type>bool</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The maximum number of spaces that are cut off from the beginning of each input line for this function parser. Only white space is cut off the beginning of input lines.</description>
              <initializer>0</initializer>
              <name>_cutOff</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The current execution block depth as this function parser is reading in input lines. This is used to determine when the function ends in this parent scanner's source file.</description>
              <initializer>0</initializer>
              <name>_depth</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>True when the first input line of a single inline comment block has been read or false otherwise. This is used to add only one step of operation per block of inline comment input lines.</description>
              <initializer>false</initializer>
              <name>_edgePast</name>
              <type>bool</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Index to the next step of operation to be used to generate an inline comment for this function parser.</description>
              <initializer>0</initializer>
              <name>_nextOperation</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The lines of output for this function parser generated by reading the input lines if found in its parent scanner's source file and used to provide its output lines with indent spaces prepended to each line.</description>
              <initializer></initializer>
              <name>_lines</name>
              <type>QStringList</type>
            </data>
          </variable>
        </access>
      </class>
