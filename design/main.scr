          </function>
          <function>
            <data>
              <const/>
              <description>Returns the value of this basic block's field with the given id. If the given id does not exist or is not a string list then an exception is thrown.</description>
              <name>getStringList</name>
              <operation>Get the data field of this basic block with the given id, making sure it is the correct type.</operation>
              <operation>Return the value of the data field.</operation>
              <return_description>Value of this basic block's field with the given id.</return_description>
