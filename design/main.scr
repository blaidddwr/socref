              <description>Tests if this function block's abstract property is set, returning true if it is.</description>
              <name>isAbstract</name>
              <return_description>True if this block's abstract property is set or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the base name for this function block. This overrides the method from the base class because of constructors and destructors.</description>
              <name>baseName</name>
              <operation>Create a new return string with the regular base name of this function.</operation>
              <operation>If this function is not a method then return the regular base name.</operation>
              <operation>If this function is a constructor or destructor then change its base name to the name of its class, prepending a ~ if it is a destructor.</operation>
              <operation>Return the base name.</operation>
              <return_description>Base name for this function block.</return_description>
              <type>QString</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns the return type for this function block.	</description>
