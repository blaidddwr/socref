          <function>
            <data>
              <description>Called when a cell in this qt table view has been double clicked by the mouse. This opens a text dialog for the string of the given model index double clicked if it is valid and within range.</description>
              <name>doubleClicked</name>
              <operation>Make sure the given index is valid and is within range of this object's string list.</operation>
              <operation>Create a new text dialog, setting its title to the item title and its text to the string with the given model index.</operation>
              <operation>Execute the text dialog and make sure it returned with accept.</operation>
              <operation>Set the value of the string with the given index to the text of the text dialog and auto fit the new text at the given row.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description></description>
                <initializer></initializer>
                <name>index</name>
                <type>const QModelIndex&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Implements _QAbstractItemView_ interface.</description>
              <final/>
              <name>selectionChanged</name>
              <operation>This does not care what was deselected.</operation>
              <operation>If the given list of selected indexes is empty then set this object's current model index to invalid, else set it to the first model index in the given list of selected indexes.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>selected</name>
                <type>const QItemSelection&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>See Qt docs.</description>
                <initializer></initializer>
                <name>deselected</name>
                <type>const QItemSelection&amp;</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private:</type>
          </data>
          <function>
            <data>
              <description>Moves this object's current index within this object's model by the amount given. This assumes this object's current index is valid and the given move amount does not remove it off the list itself.</description>
              <name>move</name>
              <operation>Make sure the current index is valid.</operation>
              <operation>Get the row and data of the current index.</operation>
              <operation>Remove the current row and then insert a new one, moved by the amount given.</operation>
              <operation>Update the current index to the moved data and set its data.</operation>
              <operation>Update the selection to the moved index and then auto fit the text of all rows.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The amount this object's current index is moved, negative being up and positive being down.</description>
                <initializer></initializer>
                <name>amount</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Initializes the table view along with creating its model for this new list edit widget.</description>
              <name>setupView</name>
              <operation>Create this object's model set it to this table view.</operation>
              <operation>Configure this new table view.</operation>
              <operation>Configure this table view's horizontal header.</operation>
              <operation>Connect the double clicked signal of this table view.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Constructs and initializes all shortcut actions for this new list edit widget.</description>
              <name>setupActions</name>
              <operation>Create and initialize this object's add action, connecting its triggered signal.</operation>
              <operation>Create and initialize this object's remove action, connecting its triggered signal.</operation>
              <operation>Create and initialize this object's move up action, connecting its triggered signal.</operation>
              <operation>Create and initialize this object's move down action, connecting its triggered signal.</operation>
              <operation>Add all shortcut actions to this new list edit widget.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Updates the row height of all text cells for this list edit widget so all the text fits within the current width of this widget.</description>
              <name>autoFitText</name>
              <operation>Iterate through all text rows and update their height to fit their text.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Updates the height of a given row of this list edit widget so all the text fits within the current width of its cell.</description>
              <name>autoFitText</name>
              <operation>Initialize wiggle and bias used to help determine the row height at the end.</operation>
              <operation>Create font metrics, get the cell width, and get the text of the string at the given row.</operation>
              <operation>Create and initialize all variables used for determining the number of lines required to fit the given row's text.</operation>
              <operation>Iterate through all characters of the given row's text.</operation>
              <operation>Check to see if this is a new line character.</operation>
              <operation>Add a line and reset the start and last space markers to the next character.</operation>
              <operation>Else if this character is a space then update the last space marker.</operation>
              <operation>Else check to see if the current line is too long for the limiting width factor.</operation>
              <operation>Add a line and reset the start marker to the character after the last space marker.</operation>
              <operation>Set the row height of the cell at the given row based off the calculated lines needed along with the wiggle and bias to fit within the cell's width.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The row whose height is updated so all text fits with the current width of this list edit widget.</description>
                <initializer></initializer>
                <name>row</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <variable>
            <data>
              <description>The title text used for the title of each text row in this list edit widget. This title is appended with the row number.</description>
              <initializer>"Step"</initializer>
              <name>_listItemTitle</name>
              <type>QString</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the string list model for this list edit widget.</description>
              <initializer></initializer>
              <name>_model</name>
              <type>QStringListModel*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The currently selected model index for this list edit widget.</description>
              <initializer></initializer>
              <name>_current</name>
              <type>QModelIndex</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Pointer to the block that is contextually being used in text dialog objects this widget opens.</description>
              <initializer></initializer>
              <name>_block</name>
              <type>Abstract::Block*</type>
            </data>
          </variable>
        </access>
      </class>
      <class>
        <data>
          <description>This is the primary view for an open project's block model. This class provides a tree view for the entire block model, a title, a detailed view of the currently selected block, and different actions to edit the underlying block model. Actions provided to the user through a context menu are add, remove, edit, cut, copy, paste, move up, and move down a block. These actions are updated depending on the current block selected. An external link to the context menu of this class is provided. The block model given to this class does not take ownership of it and is not responsible for its deletion.</description>
          <name>BlockView</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
            <class>QSplitter</class>
          </data>
        </parent>
        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <description>Constructs a new block view with no model and the optional given parent.</description>
              <explicit/>
              <name>^</name>
              <operation>Setup this object's GUI and update its context menu.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description></description>
                <initializer>nullptr</initializer>
                <name>parent</name>
                <type>QWidget*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Returns a pointer to this block view object's internal context menu.</description>
              <name>contextMenu</name>
              <return_description>Pointer to this block view object's internal context menu.</return_description>
              <type>QMenu*</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests whether the currently copied block can be pasted into the currently selected block. Returns true if it can be pasted or false otherwise.</description>
              <name>canPaste</name>
              <operation>Make sure this view has a model, the copy pointer is not null, and the block factory project types match.</operation>
              <operation>If this view's current index is not a null pointer and the copied block's type is contained within the current block's build list then return true, else return false.</operation>
              <return_description>True if the currently copied block can be pasted into the currently selected block or false if it cannot.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <description>Sets a new block model for this block view, releasing but not deleting any previous model set to it. If a null pointer is given this view is set to empty. This block view does not take ownership of the given model.</description>
              <name>setModel</name>
              <operation>If this view already had a model then disconnect its and its selection model's signals.</operation>
              <operation>Set the new model for this view and reset its current index to invalid.</operation>
              <operation>Check to see if the new model is a null pointer.</operation>
              <operation>Reset this view's factory and selection model pointers to null.</operation>
              <operation>Else the given pointer is not null and this view's new model is real.</operation>
              <operation>Set the block factory and selection model pointers of this view.</operation>
              <operation>Connect all selection model and model signals to this view.</operation>
              <operation>Update this object's view and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>Pointer to the new block model this block view will display for editing.</description>
                <initializer></initializer>
                <name>model</name>
                <type>BlockModel*</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>private slots:</type>
          </data>
          <function>
            <data>
              <description>Called when an add action is triggered. If this object has a model then this inserts a new block of the given type in the currently selected block.</description>
              <name>addTriggered</name>
              <operation>Make sure this view has a model.</operation>
              <operation>Insert a new block of the given type into this view's model with its current index, updating its current index and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The block type created and inserted into this object's model if it has one.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Called when the remove action is triggered. If this object has a valid current index then it is removed from its model.</description>
              <name>removeTriggered</name>
              <operation>Make sure this view's current index is valid.</operation>
              <operation>Remove the currently selected index from its model, updating this view's current index and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the edit action is triggered. If this object has a valid current index then this will open an edit dialog of the index's block.</description>
              <name>editTriggered</name>
              <operation>Make sure this view's current index is valid.</operation>
              <operation>Get the block pointer from the current index and make sure it is not null.</operation>
              <operation>Make a new edit dialog from the block pointer and make sure it is not null.</operation>
              <operation>Initialize the edit dialog and then execute it.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the cut action is triggered. If this object has a valid current index then this will cut it from this object's model.</description>
              <name>cutTriggered</name>
              <operation>Make sure this view's current index is valid.</operation>
              <operation>Delete any existing block copy. SPECIAL NOTE: This view's copy pointer must be set to null before a new block is cut from the model or else a dead copy pointer will cause a segmentation fault.</operation>
              <operation>Cut the current index's block from its model, updating this view's index and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the copy action is triggered. If this object has a valid current index then this will copy it from this object's model.</description>
              <name>copyTriggered</name>
              <operation>Make sure this view's current index is valid.</operation>
              <operation>Delete any existing block copy.</operation>
              <operation>Copy the current index's block from its model, updating this view's actions.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the paste action is triggered. If this object can paste its copied block into its model then it does so.</description>
              <name>pasteTriggered</name>
              <operation>If pasting is possible then insert a new copy of the copied block into this view's model at the current index.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the move up action is triggered. If this object has a valid current index then this will move it up by one.</description>
              <name>moveUpTriggered</name>
              <operation>If this view's current index is valid then move it up by one and update it.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when the move down action is triggered. If this object has a valid current index then this will move it down by one.</description>
              <name>moveDownTriggered</name>
              <operation>If this view's current index is valid then move it down by one and update it.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when this object's selection model has changed. This determines its object's new current index, updating its view and context menu afterwords.</description>
              <name>selectionModelChanged</name>
              <operation>This does not care what was deselected.</operation>
              <operation>Update this view's current index, setting it to invalid to no indexes are selected.</operation>
              <operation>Update this object's view and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>List of indexes that have been selected by the user.</description>
                <initializer></initializer>
                <name>selected</name>
                <type>const QItemSelection&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Unused list of indexes that have been deselected by the user.</description>
                <initializer></initializer>
                <name>deselected</name>
                <type>const QItemSelection&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <description>Called when this object's block model is about to be deleted. This clears its object's view to a null state and all internal pointers.</description>
              <name>modelDestroyed</name>
              <operation>Clear this view's title.</operation>
              <operation>Reset this view as empty with no model.</operation>
              <operation>Update this object's view and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
          </function>
          <function>
            <data>
              <description>Called when data in this object's block model has changed. If this object's current index is the one updated then this updates its object's view depending on the given roles.</description>
              <name>modelDataChanged</name>
              <operation>Ignore the given bottom right index and roles changed.</operation>
              <operation>Make sure the index whose data has changed is the current index and it is valid.</operation>
              <operation>Update this view's title and context menu.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The top left index of the rectangle of indexes whose data has changed.</description>
                <initializer></initializer>
                <name>topLeft</name>
                <type>const QModelIndex&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The bottom right index of the rectangle of indexes whose data has changed. This is not used in this view because only one index can change at a time.</description>
                <initializer></initializer>
                <name>bottomRight</name>
                <type>const QModelIndex&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The list of data roles that has changed.</description>
                <initializer></initializer>
                <name>roles</name>
