              <operation>Create the apply button for this dialog, connecting its clicked signal.</operation>
              <operation>Create the cancel button for this dialog, connecting its clicked signal.</operation>
              <operation>Create a new horizontal layout, adding the OK button then the apply button then a stretch and then the cancel button.</operation>
              <operation>Return the buttons layout.</operation>
              <return_description>Layout containing buttons for this new dialog.</return_description>
              <type>QLayout*</type>
            </data>
          </function>
