               <data version="1">
                  <name>convertScanDirectory</name>
                  <description>Converts the given scan directory path into its absolute canonical form and saves that form to this project's scan directory path. If the given path is not a valid directory than an exception is thrown.</description>
                  <type>void</type>
                  <operation>If the given path is not a valid directory then throw an exception.</operation>
                  <operation>Convert the given path to its canonical form and save it to this project's scan directory path.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>path</name>
                     <description>The given path to that is converted to its canonical form and saved as this project's scan directory.</description>
                     <type>const QString&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>readTypeElement</name>
                  <description>Reads the given element as the XML type element for this project, setting this project's type. If the given XML element is not a valid type element then an exception is thrown.</description>
                  <type>void</type>
                  <operation>Read in the project type from the given XML element as an integer and set this project's type to that value. If the read in type is out of range for all possible project types then throw an exception.</operation>
                  <operation>Read in the text field of the given XML element and make sure it matches the name of the project type read in. If they do not match then throw an exception.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>element</name>
                     <description>The XML element that is read in as this project's type element.</description>
                     <type>const QDomElement&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>write</name>
                  <description>Writes the given byte array to this project's file, overwriting anything the file contains beforehand. If opening or writing this project's file fails then an exception is thrown.</description>
                  <type>void</type>
                  <operation>Open this project's file and write the given byte array to the file, overwriting and erasing any data the file contained beforehand. If opening or writing failed then throw an exception.</operation>
                  <operation>Set this project's file hash used for watching.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>data</name>
                     <description>The byte array that is written to this project's file.</description>
                     <type>const QByteArray&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>saveBasicInfo</name>
                  <description>Saves this project's name, scan directory, and file filters to the given XML element as child elements.</description>
                  <type>void</type>
                  <operation>Create a name XML element and save this project's name to it, appending it to the given project element.
</operation>
                  <operation>Create a scan directory XML element and save this project's scan directory, appending it to the given project element. The scan directory path saved is relative to the directory where this project's save file is located.</operation>
                  <operation>Create a filters XML element and save this project's scan filters to it, appending it to the given project element.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>document</name>
                     <description>The XML document that is used to create the child elements.</description>
                     <type>QDomDocument&amp;</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="1">
                     <name>project</name>
                     <description>Pointer to the element which has child elements added to it to save this project's basic information.</description>
                     <type>QDomElement*</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>setFileHash</name>
                  <description>Sets this project's file hash with the hash of the given byte array. This is used for this project to watch for changes to its file.</description>
                  <type>void</type>
                  <operation>Get the hash value of the given byte array using md5 and set this project's file hash to the new value.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>bytes</name>
                     <description>The byte array whose hash is set as this project's file hash value.</description>
                     <type>const QByteArray&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>makeRoot</name>
                  <description>Makes a new root block for this project using the block factory this project's type, setting this project's root block pointer to the new root block created. If this project's type is out of range of possible project types or the block factory returns a null pointer than an exception is thrown.</description>
                  <type>void</type>
                  <operation>If this project's type is out of range for possible project types then throw an exception.</operation>
                  <operation>Create a new root block using this project type's block factory, setting this project's root block pointer to the new root block. If the block factory returns a null pointer than throw an exception, else set the new root block's parent to this object.</operation>
                  <operation>Connect the block modified signal between the new root block and this project. Create a new block model object with the new root block and this object as its parent, setting this object's block model pointer to the new block model.</operation>
               </data>
            </function>
