            <data>
              <const/>
              <description>This gets the index where the child with the given pointer is stored in this block's list of children. If no child with the given pointer is found then -1 is returned.</description>
              <name>indexOf</name>
              <operation>Return the index of the given child pointer using the qt method of this block's child list.</operation>
              <return_description>If a match is found then the index of the child with the given pointer, else -1.</return_description>
              <type>int</type>
            </data>
            <variable>
              <data>
                <description>Pointer of child block to match in this block's list and return its index.</description>
                <initializer></initializer>
                <name>pointer</name>
                <type>Block*</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>This returns a pointer to this block's child with the given index. If the index is out of range an exception is thrown.</description>
              <name>get</name>
              <operation>Make sure the given index is within range.</operation>
              <operation>Return a pointer to this block's child with the given index.</operation>
              <return_description>Pointer to this block's child with given index.</return_description>
              <type>Abstract::Block*</type>
            </data>
            <variable>
