            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Called when the root block contained within this model emits a body modified signal indicating a block with the given pointer within this model modified its body.</description>
            <name>blockBodyModified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to the block whose body has changed.</description>
              <initializer></initializer>
              <name>block</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>Determines the model index for the given block pointer and emits the data changed signal with that index and the given roles.</description>
            <name>notifyChange</name>
            <operation>Get the parent block pointer of the given block and make sure it is not null.</operation>
            <operation>Determine the index for the given block and signal the data changed for that index and given roles.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to the block whose index is found and used to emit data changed.</description>
              <initializer></initializer>
              <name>block</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The data roles used when emitting data changed.</description>
              <initializer></initializer>
              <name>roles</name>
              <type>const QVector&lt;int>&amp;</type>
            </data>
          </variable>
        </function>
        <variable>
          <data>
            <constexpr/>
            <description>The preferred icon size for indexes of this model when displayed in a view. This represents both the width and height.</description>
            <initializer>24</initializer>
            <name>_iconSize</name>
            <static/>
            <type>int</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>A pointer to the root block for this model's data. If this model is empty then this is null.</description>
            <initializer>nullptr</initializer>
            <name>_root</name>
            <type>AbstractBlock*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>A read only pointer to this model block type's block factory. If this model is empty then this is null.</description>
            <initializer>nullptr</initializer>
            <name>_factory</name>
            <type>const AbstractBlockFactory*</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This implements the qt thread class and is used to scan and parse an entire directory of source files with the given file filters and parser factory. This executes the scanning of files on the separate thread started by the qt thread class. Signals are emitted for the progress of the scanning and when it is complete. Because execution of parsing is done on a separate thread if an exception is thrown within that thread it is caught and saved within the class. This exception can be viewed from the main thread.</description>
        <name>ScanThread</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QThread</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>This constructs a new scan thread with the given parser factory, directory to scan, file filters, and possible parent.</description>
            <explicit/>
            <name>^</name>
            <operation>Set this object as the given factory's parent and build the list of files to parse.</operation>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The parser factory that this scan thread will use to make all parser objects for each matched source file. This scan thread takes ownership of the factory.</description>
              <initializer></initializer>
              <name>factory</name>
              <type>Soc::Ut::QPtr&lt;AbstractParserFactory>&amp;&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The directory that this scan thread will scan for source files.</description>
              <initializer></initializer>
              <name>scanDirectory</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The file filters this scan thread will use for filtering the files in the given scan directory. Only files that match any of these filters will be parsed.</description>
              <initializer></initializer>
              <name>filters</name>
              <type>const QStringList&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The parent of this object if any.</description>
              <initializer>nullptr</initializer>
              <name>parent</name>
              <type>QObject*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the total number of files that were matched for parsing.</description>
            <name>size</name>
            <return_description>Total number of files matched for parsing.</return_description>
            <type>int</type>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>signals:</type>
        </data>
        <function>
          <data>
            <description>Signals that the scan thread has started working on the given file index. The indexing starts at zero and ends at one less than the total number of files to process.</description>
            <name>progressChanged</name>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The current file index that is being parsed.</description>
              <initializer></initializer>
              <name>index</name>
              <type>int</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>protected:</type>
        </data>
        <function>
          <data>
            <description>Implements _QThread_ interface. This iterates through all files to be parsed and parses them, constantly checking for any requested interruption.</description>
            <final/>
            <name>run</name>
            <operation>Iterate through this object's list of files to be parsed.</operation>
            <operation>Check to see if interruption of this thread is requested.</operation>
            <operation>Signal progress has occurred.</operation>
            <operation>Make a parser object for the current file using this object's parser factory and run it if it is not null.</operation>
            <override/>
            <return_description></return_description>
            <type>void</type>
            <virtual/>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>Parses the given file using the given parser. If the file fails to open an exception is thrown.</description>
            <name>parse</name>
            <operation>Open the given file and make sure it did not fail.</operation>
            <operation>parse the opened file with the given parser.</operation>
            <return_description></return_description>
            <static/>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to the abstract parser that is used for parsing the given file.</description>
              <initializer></initializer>
              <name>parser</name>
              <type>AbstractParser*</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Info for the file that is parsed with the given parser.</description>
              <initializer></initializer>
              <name>info</name>
              <type>const QFileInfo&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Builds this scan thread's list of matched files that will be parsed from the given scan directory and file filters. A file must match only one file filter to be added to the list of matched files.</description>
            <name>buildList</name>
            <operation>Get the scan directory from the given path and make sure it exists.</operation>
            <operation>Make a list of files in the scan directory with the given filters and iterate through them all.</operation>
            <operation>If the file is a directory then recursively call this method on that directory else add the file to this object's list of files to be parsed.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The directory where files will be matched and added to the list.</description>
              <initializer></initializer>
              <name>scanDirectory</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The filters that will be used to match files. Each string in this list must be a single filter.</description>
              <initializer></initializer>
              <name>filters</name>
              <type>const QStringList&amp;</type>
            </data>
          </variable>
        </function>
        <variable>
          <data>
            <description>A pointer to the parser factory this scan thread uses for making parser objects.</description>
            <initializer></initializer>
            <name>_factory</name>
            <type>AbstractParserFactory*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>A list of matched files that his scan thread parses.</description>
            <initializer></initializer>
            <name>_list</name>
            <type>QFileInfoList</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This is a dictionary list model. This stores a list of unique words sorted alphabetically and provides a method for testing if it contains a given word. This is intended to be used to store a custom set of spell checker words on a per project bases. Copies of words cannot be stored in this model. The data of this model can be written or saved using XML elements.</description>
        <name>DictionaryModel</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QAbstractListModel</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface.</description>
            <final/>
            <name>rowCount</name>
            <operation>If this is the root index then return this model's list's size.</operation>
            <operation>Else this is not the root so return 0.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>int</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>parent</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Implements _QAbstractItemModel_ interface.</description>
            <final/>
            <name>data</name>
            <operation>Make sure the given index is valid, the role is display, and the index row is within range.</operation>
            <operation>Return the word of this model's list at the given index.</operation>
            <override/>
            <return_description>See Qt docs.</return_description>
            <type>QVariant</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>See Qt docs.</description>
              <initializer></initializer>
              <name>role</name>
              <type>int</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>Constructs a new dictionary model with the optional parent.</description>
            <explicit/>
            <name>^</name>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>Optional parent for this new dictionary model.</description>
              <initializer>nullptr</initializer>
              <name>parent</name>
              <type>QObject*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Tests if this model's word list contains the given word, returning true if it does.</description>
            <name>hasWord</name>
            <operation>Search this model's word list for a match with the given word.</operation>
            <return_description>True if this model's word list contains the given word or false otherwise.</return_description>
            <type>bool</type>
          </data>
          <variable>
            <data>
              <description></description>
              <initializer></initializer>
              <name>word</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Writes out this model's word list to an XML element, returning the XML element containing all the words.</description>
            <name>write</name>
            <operation>Create a new XML element.</operation>
            <operation>Iterate through all words of this model's word list, appending a new XML child element for each word. Each word is copied in the child element's enclosing text.</operation>
            <operation>Return the root XML element.</operation>
            <return_description>XML element that contains a copy of this model's word list.</return_description>
            <type>QDomElement</type>
          </data>
          <variable>
            <data>
              <description></description>
              <initializer></initializer>
              <name>document</name>
              <type>QDomDocument&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Adds the given word to this model's word list if it does not already contain it, returning true if the word was added.</description>
            <name>addWord</name>
            <operation>Make sure this model's word list doesn't already contain the given word.</operation>
            <operation>Iterate through this model's word list.</operation>
            <operation>Check to see if the given word is alphabetically less then the word at the current word list index.</operation>
            <operation>Insert the given word at the current index, notifying the model of a new row being inserted.</operation>
            <operation>The new word has been added so notify of modification and return true.</operation>
            <operation>Append the given word to the end of this model's word list, notifying the model of a new row being inserted.</operation>
            <operation>The new word has been added so notify of modification and return true.</operation>
            <return_description>True if the given word was added to this model's word list or false if the word is already contained in this model.</return_description>
            <type>bool</type>
          </data>
          <variable>
            <data>
              <description></description>
              <initializer></initializer>
              <name>word</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Remove the word at the given index from this model's word list, returning true if it was removed.</description>
            <name>removeWord</name>
            <operation>Make sure the given index is valid and within range of this model's word list.</operation>
            <operation>Remove the word at the given index's row from this model's word list, notifying the model that a row was removed.</operation>
            <operation>Notify of modification and return true on success.</operation>
            <return_description>True if the word at the given index was removed from this model's word list or false otherwise.</return_description>
            <type>bool</type>
          </data>
          <variable>
            <data>
              <description>The index of the word that is removed from this model's word list.</description>
              <initializer></initializer>
              <name>index</name>
              <type>const QModelIndex&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Read in a list of words from the given XML element to this model's word list, overwriting any words it currently contains. This also resets this model.</description>
            <name>read</name>
            <operation>Notify the model that a reset has begun and then clear this model's word list.</operation>
            <operation>Iterate through all children of the given XML element.</operation>
            <operation>If the child node is an element then append its text to this model's word list.</operation>
            <operation>Iterate to the next sibling node.</operation>
            <operation>Notify the model that the reset has finished.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The XML element whose child element's contain a list of words that is read into this model's word list.</description>
              <initializer></initializer>
              <name>element</name>
              <type>const QDomElement&amp;</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>signals:</type>
        </data>
        <function>
          <data>
            <description>Signals that this dictionary model has been modified.</description>
            <name>modified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <variable>
          <data>
            <description>The list of words this dictionary model contains.</description>
            <initializer></initializer>
            <name>_list</name>
            <type>QStringList</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This is a single open project which contains everything for that project, watching the file it was opened or saved with for changes made by any outside source. If the file this project is associated with is changed by an outside source a signal is emitted. This class also provides all generic information of a project along with being able to edit it. This generic information includes the name, scan directory, and scan filters. The block model for this project's block tree data and the ability to create a scan thread object for scanning and parsing is also provided.</description>
        <name>Project</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QFileSystemWatcher</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>This constructs a new project of the given type.</description>
            <explicit/>
            <name>^</name>
            <operation>Connect this project's custom dictionary modified signal.</operation>
            <operation>Initialize this new project's root block, file watcher signal, and default scan filters.</operation>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The project type this new project is constructed as.</description>
              <initializer></initializer>
              <name>type</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>This constructs a project loaded from the file from the given path. If any error occurs from loading the project file an exception is thrown.</description>
            <explicit/>
            <name>^</name>
            <operation>Connect this project's custom dictionary modified signal.</operation>
            <operation>Initialize the enumeration and static string list used for identifying different elements to read in based off their tag names.</operation>
            <operation>Initialize this project's file watcher signal.</operation>
            <operation>Read in the entire contents of the file located at the given path and then load it into a qt XML document.</operation>
            <operation>Iterate through all child nodes of the root XML document element.</operation>
            <operation>Check to see if this node is an element.</operation>
            <operation>Figure out what element this is based off its tag name and set the appropriate data for this project.</operation>
            <operation>First make a blank root block for this project and then read in the root block element.</operation>
            <operation>Move to the next node sibling.</operation>
            <operation>Add this project's file path to its file watcher.</operation>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The path of the file that this project is loaded from.</description>
              <initializer></initializer>
              <name>path</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Tests if this is a new project that has not yet been saved to a file.</description>
            <name>isNew</name>
            <operation>Return a boolean based off this project's file path being empty or not.</operation>
            <return_description>True if this is a new unsaved project or false otherwise.</return_description>
            <type>bool</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Tests of this project has unsaved modifications.</description>
            <name>isModified</name>
            <return_description>True if this project has unsaved content or false otherwise.</return_description>
            <type>bool</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the project type for this project.</description>
            <name>type</name>
            <return_description>This project's type.</return_description>
            <type>int</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the path of the file associated with this open project. If this is a new project that has not been saved yet this returns an empty string.</description>
            <name>path</name>
            <return_description>Path to file associated with this project or an empty string.</return_description>
            <type>QString</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the name of this project.</description>
            <name>name</name>
            <return_description>The project's name.</return_description>
            <type>QString</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the scan directory path of this project in its canonical form.</description>
            <name>scanDirectory</name>
            <return_description>Canonical path to this project's scan directory.</return_description>
            <type>QString</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns this project's file filters used for scanning of source files.</description>
            <name>scanFilters</name>
            <return_description>File filters used for this project's scanning.</return_description>
            <type>QString</type>
          </data>
        </function>
        <function>
          <data>
            <const/>
            <description>Makes and returns a pointer to a new scan thread that can be used for scanning and parsing matched source files in the scan directory of this project.</description>
            <name>makeScanner</name>
            <operation>Create a new scan thread with a newly created parser factory and this project's scan directory and filters, returning its pointer.</operation>
            <return_description>Pointer to new scan thread object.</return_description>
            <type>Soc::Ut::QPtr&lt;ScanThread></type>
          </data>
        </function>
        <function>
          <data>
            <description>Returns a pointer to the block model for this project used to view and edit the block data contained within it.</description>
            <name>model</name>
            <return_description>Pointer to this project's block model.</return_description>
            <type>BlockModel*</type>
          </data>
        </function>
        <function>
          <data>
            <description>Returns a pointer to the dictionary model for this project used for storing custom spell checking words.</description>
            <name>dictionary</name>
            <return_description>Pointer to this project's dictionary model.</return_description>
            <type>DictionaryModel*</type>
          </data>
        </function>
        <function>
          <data>
            <description>Sets a new name for this project with the given name.</description>
            <name>setName</name>
            <operation>Make sure the new value is different from the current one.</operation>
            <operation>Set this project's name to the new value and signal this project's name has changed and it has been modified.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The new name this project's name is set to.</description>
              <initializer></initializer>
              <name>value</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Sets a new scan directory path for this project to the given path. The given path can be relative to this program's present working directory. If the given path is not a valid directory then an exception is thrown.</description>
            <name>setScanDirectory</name>
            <operation>Get file info for this project's current scan directory and the new path given.</operation>
            <operation>Make sure the new path is different from the current path.</operation>
            <operation>Make sure the new path is a valid directory.</operation>
            <operation>Set this project's scan directory to the new path given in its canonical form and signal modification.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Path that this project's scan directory is set to.</description>
              <initializer></initializer>
              <name>path</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Sets new scanning file filters for this project. These filters are used to filter out what files are matched for parsing when a scan thread of this project is used. The filter filters must be separated by spaces.</description>
            <name>setScanFilters</name>
            <operation>Make sure the new value is different from the current one.</operation>
            <operation>Update this project's scan filters to the new value and signal modification.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The file filters that this project will use for scanning.</description>
              <initializer></initializer>
              <name>value</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Saves this project to its associated file. If this is a new project that has never been saved then an exception is thrown. If any writing error occurs while saving an exception is thrown.</description>
            <name>save</name>
            <operation>Make sure this is not a new project and has a file path.</operation>
            <operation>Create a new XML document, appending its XML processing instructions.</operation>
            <operation>Create the name element saving this project's name.</operation>
            <operation>Create the scan directory element saving this project's scan directory as the path relative to the file path of this project.</operation>
            <operation>Create the filters element saving this project's scan filters.</operation>
            <operation>Create the type element saving this project type's element name.</operation>
            <operation>Create the dictionary element saving this project's custom dictionary data.</operation>
            <operation>Create the root block element saving this project's root block and all its children.</operation>
            <operation>Create the root project element, adding all previous elements created, and then add the root element to the XML document.</operation>
            <operation>Save the XML document to a byte array and then write it out to this project's file path.</operation>
            <operation>Set this project as not being modified and signal it has been saved.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Saves this project to a new file with the given path. If any writing error occurs while saving an exception is thrown.</description>
            <name>saveAs</name>
            <operation>Remember this project's old path and then set it to the new path given.</operation>
            <operation>Attempt to save this project with the new path.</operation>
            <operation>If any exception is thrown while saving then revert this project's path back to the old one.</operation>
            <operation>Remove the old path from this project's file watcher if is exists and add the new path.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The path to the new file this project is saved to.</description>
              <initializer></initializer>
              <name>path</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>signals:</type>
        </data>
        <function>
          <data>
            <description>Signals that this project's name has changed.</description>
            <name>nameChanged</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Signals that this project has been modified and now has unsaved changes.</description>
            <name>modified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Signals that this project has been saved and no longer has unsaved changes.</description>
            <name>saved</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Signals that this project's file has been changed by an outside source and no longer contains the last save of this project.</description>
            <name>saveFileChanged</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>private slots:</type>
        </data>
        <function>
          <data>
            <description>Called when a block contained within this project or its custom dictionary has been modified. This in turn causes this project to change its state to modified.</description>
            <name>projectModified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Called when this project's file has changed. This is called even if the project itself is saved to the file, so this also checks to see it that is the case or not.</description>
            <name>fileChanged</name>
            <operation>Open this project's file and make sure it worked.</operation>
            <operation>Read in the entire contents of the file and make sure it worked.</operation>
            <operation>Generate the hash of the read in file's contents and if the hash is different from this project's saved hash then signal the save file has changed.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>Emits the modified signal of this project if and only if this project is not already modified. If the project is already modified this does nothing.</description>
            <name>signalModified</name>
            <operation>Make sure this project is not already modified.</operation>
            <operation>Set this project as modified and signal the same.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Reads in this project's file and returns its entire contents as a byte array. If opening or reading this project's file fails then an exception is thrown.</description>
            <name>read</name>
            <operation>Open this project's file and make sure it worked.</operation>
            <operation>Read in the entire contents of this project's file and make sure it worked.</operation>
            <operation>Set this project's file hash with the read in byte array and return it.</operation>
            <return_description>Contents of this project's file as a byte array.</return_description>
            <type>QByteArray</type>
          </data>
        </function>
        <function>
          <data>
            <description>Converts the given scan directory path into its absolute canonical form and saves that form to this project's scan directory path. If the given path is not a valid directory than an exception is thrown.</description>
            <name>convertScanDirectory</name>
            <operation>Make sure the given path is a valid directory relative to the directory this project's file is located.</operation>
            <operation>Set this project's scan directory to the path given in its canonical form.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The given path to that is converted to its canonical form and saved as this project's scan directory.</description>
              <initializer></initializer>
              <name>path</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Reads the given element as the XML type element for this project, setting this project's type. If the given XML element is not a valid type element then an exception is thrown.</description>
            <name>readTypeElement</name>
            <operation>Look up the project type with the element name supplied by the given XML element.</operation>
            <operation>Make sure the element name was recognized and a known type returned.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The XML element that is read in as this project's type element.</description>
              <initializer></initializer>
              <name>element</name>
              <type>const QDomElement&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Writes the given byte array to this project's file, overwriting anything the file contains beforehand. If opening or writing this project's file fails then an exception is thrown.</description>
            <name>write</name>
            <operation>Open this project's file for truncated writing and make sure it worked.</operation>
            <operation>Write out the given byte array to the opened file and make sure it worked.</operation>
            <operation>Set this project's file hash with the given byte array.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The byte array that is written to this project's file.</description>
              <initializer></initializer>
              <name>data</name>
              <type>const QByteArray&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Sets this project's file hash with the hash of the given byte array. This is used for this project to watch for changes to its file.</description>
            <name>setFileHash</name>
            <operation>Get the hash value of the given byte array using md5 and set it to this project's file hash.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The byte array whose hash is set as this project's file hash value.</description>
              <initializer></initializer>
              <name>bytes</name>
              <type>const QByteArray&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Makes a new root block for this project using the block factory this project's type, setting this project's root block pointer to the new root block created. If this project's type is out of range of possible project types or the block factory returns a null pointer than an exception is thrown.</description>
            <name>makeRoot</name>
            <operation>Make sure this project's type is within range and valid.</operation>
            <operation>Create a new root block for this project and make sure it is not null.</operation>
            <operation>Connect its modified signal and set it to this project's block model root block.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
