            <function type="2">
               <data version="1">
                  <name>name</name>
                  <description>This interface returns the name of this block. The name is used to display the block as text in a tree view and as a title when selected.</description>
                  <type>QString</type>
                  <virtual/>
                  <const/>
                  <abstract/>
                  <return_description>The name of this block.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>icon</name>
                  <description>This interface returns the icon of this block. The icon is displayed in a tree view of this block and its title if selected.</description>
                  <type>QIcon</type>
                  <virtual/>
                  <const/>
                  <abstract/>
                  <return_description>The icon of this block.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>buildList</name>
                  <description>This interface returns a list of types that this block can contain as children. If the same type is listed more than once any repeated occurrences are ignored and the type is allowed to be this block's parent.</description>
                  <type>QList&lt;int></type>
                  <virtual/>
                  <const/>
                  <abstract/>
                  <return_description>List of allowed types this block can contain as children.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>makeView</name>
                  <description>This interface returns a View that provides a detailed read only GUI representation of this block's data.</description>
                  <type>std::unique_ptr&lt;QWidget></type>
                  <virtual/>
                  <const/>
                  <abstract/>
                  <return_description>New GUI view that represents this block's data.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>makeEdit</name>
                  <description>This interface returns a editable GUI widget that provides the ability to edit this block's data.</description>
                  <type>std::unique_ptr&lt;::Gui::AbstractEdit></type>
                  <virtual/>
                  <abstract/>
                  <return_description>New editable GUI widget to edit this block's data.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>makeCopy</name>
                  <description>This interface makes an exact copy of this block. A default implementation of this interface is given that uses other virtual functions to create a copy of this block. The new block returned has no parent.</description>
                  <type>std::unique_ptr&lt;AbstractBlock></type>
                  <virtual/>
                  <const/>
                  <return_description>Exact copy of this block's data as a new block.</return_description>
                  <operation>Create a new empty block that is the same type as this block.</operation>
                  <operation>Copy all of this block's children and its data.</operation>
                  <operation>Return a pointer to the newly created block.</operation>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>root</name>
                  <description>This returns the root block in this block's tree structure. The root block is the common parent of all other blocks that has no parent itself.</description>
                  <type>AbstractBlock*</type>
                  <return_description>Pointer to the root block.</return_description>
                  <operation>Iterate through the parents of this block until the root block with no parent is reached.</operation>
                  <operation>Return the root node pointer.</operation>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>root</name>
                  <description>This returns the root block in this block's tree structure. The root block is the common parent of all other blocks that has no parent itself.</description>
                  <type>const AbstractBlock*</type>
                  <const/>
                  <return_description>Read only pointer to the root block.</return_description>
                  <operation>Iterate through the parents of this block until the root block with no parent is reached.</operation>
                  <operation>Return the root node pointer.</operation>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>parent</name>
                  <description>This returns a pointer to the parent of this block. If this block is the root block then null is returned.</description>
                  <type>AbstractBlock*</type>
                  <const/>
                  <return_description>If this block is the root then a null pointer, else a pointer to this block's parent.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>size</name>
                  <description>This returns the number of children this block contains.</description>
                  <type>int</type>
                  <const/>
                  <return_description>Number of children this block contains.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>list</name>
                  <description>This returns a read only reference to this block's list of children blocks. The list is a list of pointers to all child blocks.</description>
                  <type>const QList&lt;AbstractBlock*>&amp;</type>
                  <const/>
                  <return_description>Reference to this block's list of children.</return_description>
               </data>
            </function>
            <function type="2">
               <data version="1">
                  <name>indexOf</name>
                  <description>This gets the index where the child with the given pointer is stored in this node's list of children. If no child with the given pointer is found then -1 is returned.</description>
                  <type>int</type>
                  <const/>
                  <return_description>If a match is found then the index of the child with the given pointer, else -1.</return_description>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>pointer</name>
                     <description>Pointer of child block to match in this node's list and return its index.</description>
                     <type>AbstractBlock*</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>get</name>
                  <description>This returns a pointer to this node's child with the given index. If the index is out of range an exception is thrown.</description>
                  <type>AbstractBlock*</type>
                  <const/>
                  <return_description>Pointer to this node's child with given index.</return_description>
                  <operation>If the given index is out of range then throw an exception, else go to next step.</operation>
                  <operation>Return a pointer to this node's child with the given index.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>index</name>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>containsType</name>
                  <description>Tests if this node contains any children of the given type.</description>
                  <type>bool</type>
                  <const/>
                  <return_description>True if this node contains any children of the given type, else false.</return_description>
                  <operation>Iterate through list of this node's children.</operation>
                  <operation>If a child that matches the given type is found then return true, else if the end of the list is reached with no match then return false.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>type</name>
                     <description>The block type to search for within this block's list of children.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>containsType</name>
                  <description>Tests if this node contains any children of any type given.</description>
                  <type>bool</type>
                  <const/>
                  <return_description>True if this node contains any children of any type given, else false.</return_description>
                  <operation>Iterate through list of this node's children.</operation>
                  <operation>If a child that matches the given type is found then return true, else if the end of the list is reached with no match then return false.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>types</name>
                     <description>List of block types to search for within this block's list of children.</description>
                     <type>const QList&lt;int>&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>makeListOfType</name>
                  <description>Build a list of this node's children that matches the given type. The returned list has no other copies.</description>
                  <type>QList&lt;T*></type>
                  <const/>
                  <return_description>List of this node's children that is given type.</return_description>
                  <operation>Iterate through the list of this node's children.</operation>
                  <operation>Add a pointer of every child that matches the given type to the return list.</operation>
                  <operation>Return the list of matched children.</operation>
               </data>
               <template type="3">
                  <data version="1">
                     <name>T</name>
                     <description>The child class type that is matched.</description>
                     <type>class</type>
                  </data>
               </template>
               <variable type="1">
                  <data version="1">
                     <name>type</name>
                     <description>The type whose matches are added to the list.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>cast</name>
                  <description>This casts this block to a specific block type. If the given type does not match this block's type then a null pointer is returned. If this object fails to cast as the requested type an exception is thrown.</description>
                  <type>const T*</type>
                  <const/>
                  <return_description>If successful then a read only pointer of requested cast type, else a null pointer.</return_description>
                  <operation>If the given type to cast does not match this block's type then return a null pointer, else go to the next step.</operation>
                  <operation>Cast this block's pointer to the requested class type and return the cast pointer. If the cast fails then throw an exception.</operation>
               </data>
               <template type="3">
                  <data version="1">
                     <name>T</name>
                     <description>The class type that is cast.</description>
                     <type>class</type>
                  </data>
               </template>
               <variable type="1">
                  <data version="1">
                     <name>toType</name>
                     <description>The block type that this block is cast to.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>cast</name>
                  <description>This casts this block to a specific block type. If the given type does not match this block's type then a null pointer is returned. If this object fails to cast as the requested type an exception is thrown.</description>
                  <type>T*</type>
                  <return_description>If successful then a pointer of requested cast type, else a null pointer.</return_description>
                  <operation>If the given type to cast does not match this block's type then return a null pointer, else go to the next step.</operation>
                  <operation>Cast this block's pointer to the requested class type and return the cast pointer. If the cast fails then throw an exception.</operation>
               </data>
               <template type="3">
                  <data version="1">
                     <name>T</name>
                     <description>The class type that is cast.</description>
                     <type>class</type>
                  </data>
               </template>
               <variable type="1">
                  <data version="1">
                     <name>toType</name>
                     <description>The block type that this block is cast to.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>moveUp</name>
                  <description>Moves the child block with the given index up the list by one where the very top of the list is index 0. If the given index is already at the top of the list or out of range then this does nothing.</description>
                  <type>void</type>
                  <operation>If the given index is already at the top of the list or out of range then do nothing and exit, else go to the next step.</operation>
                  <operation>Swap the given child in this block's list with the child just above it, calling the interface function notifying a child has moved and emitting the modified signal.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>index</name>
                     <description>The index of the child block moved up by one.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>moveDown</name>
                  <description>Moves the child block with the given index down the list by one where the very top of the list is index 0. If the given index is already at the bottom of the list or out of range then this does nothing.</description>
                  <type>void</type>
                  <operation>If the given index is at the end of the list or out of range then do nothing and exit, else go to the next step.</operation>
                  <operation>Swap the child with the given index in this block's list with the child just below it, calling the interface function notifying a child has moved and emitting the modified signal.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>index</name>
                     <description>The index of the child block moved down by one.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>insert</name>
                  <description>Inserts a new child block into this block's list of children at the given index. If the given index is less than 0 it is prepended to this block's list, else if the given index is greater than this block's list size then it is appended. If the given pointer to the new block is null or it is a type this block cannot contain then an exception is thrown.</description>
                  <type>void</type>
                  <operation>If the given child pointer is null or its type is not contained in this blocks build list then throw an exception, else go to the next step.</operation>
                  <operation>Insert the new block into this block's list of children at the given index, releasing it from its smart pointer and setting this block as its parent.</operation>
                  <operation>Call the interface notifying a new child is added and emit the modified signal.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>index</name>
                     <description>The index where the new block is inserted.</description>
                     <type>int</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="1">
                     <name>child</name>
                     <description>Pointer to the new block that is inserted as this block's child.</description>
                     <type>std::unique_ptr&lt;AbstractBlock>&amp;&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>take</name>
                  <description>Takes the child block at the given index this block contains. The child block returned no longer has a parent. If the index is out of range then an exception is thrown.</description>
                  <type>std::unique_ptr&lt;AbstractBlock></type>
                  <return_description>Pointer to child that was taken from this block.</return_description>
                  <operation>If the given index is out of range then throw an exception, else go to the next step.</operation>
                  <operation>Remove the child at the given index from this block's list of children saving its pointer to a smart pointer.</operation>
                  <operation>Set the child's parent to nothing, call the interface that notifies a child is being removed, emit the modified signal, and return the smart pointer.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>index</name>
                     <description>The index of the child that is taken.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>remove</name>
                  <description>Removes the child block at the given index, deleting it and any children it may contain. If the given index is out of range then an exception is thrown.</description>
                  <type>void</type>
                  <operation>If the given index is out of range then throw an exception, else go to the next step.</operation>
                  <operation>Take the pointer to the child at the given index from this block's list of children, call the interface that notified a child is being removed, and emit the modified signal.</operation>
                  <operation>Delete the pointer by using a smart pointer when it goes out of scope.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>index</name>
                     <description>The index of the child that is removed and deleted.</description>
                     <type>int</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>read</name>
                  <description>Reads in block data from an XML element. This clears any existing data this block contains, including the removal and deletion of all existing children. This recursively adds any children contained in the XML reading in their data from child XML elements.</description>
                  <type>void</type>
                  <operation>Clear and delete any existing children this block may contain. Then read in this blocks data element.</operation>
                  <operation>If the data element could not be found in the XML element then throw an exception, else go to the next step.</operation>
                  <operation>Call the interface which reads in the data for this block's type.</operation>
                  <operation>Read in all children XML elements and add them to this block's list of children, creating a new child for each one and calling their read function.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>element</name>
                     <description>The XML element that stores block data this block reads as input.</description>
                     <type>const QDomElement&amp;</type>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>write</name>
                  <description>Writes out this blocks data as an XML element. This includes all children as child XML elements which have their write functions called recursively.</description>
                  <type>QDomElement</type>
                  <const/>
                  <return_description>XML element that stores this block's data and all children underneath it.</return_description>
                  <operation>Create a new XML element and add the data element to it derived by calling the interface for writing the data of this block's type as an XML element.</operation>
                  <operation>Call each child's write function and add their returned elements to the new XML element as children.</operation>
                  <operation>Return the newly created XML element containing the data and all children.</operation>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>document</name>
                     <type>QDomDocument&amp;</type>
                  </data>
               </variable>
            </function>
         </access>
