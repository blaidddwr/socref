                     <name>required</name>
                     <description>True if this match is required otherwise false.</description>
                     <type>bool</type>
                     <initializer>true</initializer>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="0">
                  <name>set</name>
                  <description>Set a new child element match with the given tag name. When this reader reads its element, if a child element is found with the given tag name then the XML element pointed to by the given pointer will be set to the matched child element.</description>
                  <type>DomElementReader&amp;</type>
                  <return_description>Reference to this element reader.</return_description>
               </data>
               <variable type="1">
                  <data version="0">
                     <name>tagName</name>
                     <description>Tag name to find in this reader's child elements.</description>
                     <type>const QString&amp;</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="0">
                     <name>pointer</name>
                     <description>Pointer to a XML element that will be set to a child element is matched.</description>
                     <type>QDomElement*</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="0">
                     <name>required</name>
                     <description>True if this match is required otherwise false.</description>
                     <type>bool</type>
                     <initializer>true</initializer>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="0">
                  <name>set</name>
                  <description>Set a new child element match with the given tag name. When this reader reads its element, if a child element is found with the given tag name then it is appended to the list of elements pointed to by the match.</description>
                  <type>DomElementReader&amp;</type>
                  <return_description>Reference to this element reader.</return_description>
               </data>
               <variable type="1">
                  <data version="0">
                     <name>tagName</name>
                     <description>Tag name to find in this reader's child elements.</description>
                     <type>const QString&amp;</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="0">
                     <name>pointer</name>
                     <description>Pointer to a list of XML elements that will have any matched child elements appended to it.</description>
                     <type>QList&lt;QDomElement>*</type>
                  </data>
               </variable>
               <variable type="1">
                  <data version="0">
                     <name>required</name>
                     <description>True if this match is required otherwise false.</description>
                     <type>bool</type>
                     <initializer>true</initializer>
                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="0">
                  <name>read</name>
                  <description>Reads this reader's XML element for child elements, finding any matches set before this is called. Before reading begins this clears all variables pointed to by the list of set matches.</description>
                  <type>void</type>
                  <operation>Clear all variables pointed to by this reader's list of matches.</operation>
                  <operation>Iterate through all child nodes of this reader's XML element. If the node is an element and its name matches one of the set matches then read in the match with the matched element.</operation>
               </data>
            </function>
            <function type="2">
               <data version="0">
                  <name>allRequiredFound</name>
                  <description>Tests if all required matches found at least one match after called the read method.</description>
                  <const/>
                  <type>bool</type>
                  <return_description>True if all required matches were found or false otherwise.</return_description>
                  <operation>Iterate through all matches. If a match is found that was not read then return false, else if all matches were read then return true.</operation>
               </data>
            </function>
