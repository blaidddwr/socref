              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>True to enable this editor's dialog popup shortcut or false to disable it.</description>
                <initializer></initializer>
                <name>enabled</name>
                <type>bool</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
