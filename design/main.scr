              <name>isPrivate</name>
              <return_description>True if this access block is a private type or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests of this access block is a signal type, returning true if it is.</description>
              <name>isSignal</name>
              <return_description>True if this access block is a signal type or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
