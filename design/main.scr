                <type>int</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this block contains any children of any type given.</description>
              <name>containsType</name>
              <operation>Iterate through list of this block's children.</operation>
              <operation>If the child matches any of the given types then return true.</operation>
              <operation>Return false because no child was found with the given type.</operation>
              <return_description>True if this block contains any children of any type given, else false.</return_description>
              <type>bool</type>
            </data>
            <variable>
              <data>
                <description>List of block types to search for within this block's list of children.</description>
                <initializer></initializer>
                <name>types</name>
                <type>const QList&lt;int>&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>creates and returns a list of this block's children that matches the given type. The returned list has no other copies.</description>
              <name>createListOfType</name>
              <operation>Generate a pointer list of all this block's children that match the given type.</operation>
              <operation>Return the pointer list of matched children.</operation>
              <return_description>List of this block's children that is given type.</return_description>
              <type>QList&lt;T*></type>
            </data>
            <template>
              <data>
                <description>The child class type that is matched.</description>
