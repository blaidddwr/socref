                     <function type="2">
                        <data version="0">
                           <name>data</name>
                           <description>Implements the qt model interface that returns data about a given model index with the given role. This implementation returns the string in it's string list.</description>
                           <virtual/>
                           <const/>
                           <override/>
                           <final/>
                           <type>QVariant</type>
                           <return_description>String of this model's string list at the given model index row or an empty variant of this model has no string list.</return_description>
                           <operation>If this model has no string list, the given index row is out of range, or the given role is not the display or edit role then return an empty variant, else return the string of this model's string list at the given model index row.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>index</name>
                              <description>Model index whose data with the given role is returned.</description>
                              <type>const QModelIndex&amp;</type>
                           </data>
                        </variable>
                        <variable type="1">
                           <data version="0">
                              <name>role</name>
                              <description>The role of the data that is returned.</description>
                              <type>int</type>
                           </data>
                        </variable>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>setData</name>
                           <description>Implements the qt model interface that sets data for a given model index with the given role. This implementation sets the strings in this model's string list.</description>
                           <virtual/>
                           <override/>
                           <final/>
                           <type>bool</type>
                           <return_description>True if the string at the given model index row was set or false otherwise.</return_description>
                           <operation>If this model has no string list, the given model index row is out of range, or the given role is not the edit role then return false.</operation>
                           <operation>Set the string in this model's string list at the given model index row, emit the data changed signal for the given index, and return true.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>index</name>
                              <description>Model index whose data is set if the given role is edit.</description>
                              <type>const QModelIndex&amp;</type>
                           </data>
                        </variable>
                        <variable type="1">
                           <data version="0">
                              <name>value</name>
                              <description>The new string value that the string with the given model index row is set to if the given role is edit.</description>
                              <type>const QVariant&amp;</type>
                           </data>
                        </variable>
                        <variable type="1">
                           <data version="0">
                              <name>role</name>
                              <description>This must be the edit role for this to set the model index data.</description>
                              <type>int</type>
                           </data>
                        </variable>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>addAfter</name>
                           <description>Adds a new string after the given model index, returning true on success.</description>
                           <type>bool</type>
                           <return_description>True on success or false otherwise.</return_description>
                           <operation>If this model has no string list or the given index row is out of range then return false.</operation>
                           <operation>Create the integer _row_, setting it to 0 if the given index is invalid else setting it to the given index row plus one.</operation>
                           <operation>Signal that a row insertion is happening to this model, then insert a new empty string at _row_, then signal the row insertion is finished to this model, and then return true.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>index</name>
                              <description>The index which has a new string added after it in this model's string list.</description>
                              <type>const QModelIndex&amp;</type>
                           </data>
                        </variable>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>remove</name>
                           <description>Removes a string with the given model index, returning true on success.</description>
                           <type>bool</type>
                           <return_description>True on success or false otherwise.</return_description>
                           <operation>If this model has no string list, the given index is not valid, or the given index row is out of range then return false.</operation>
                           <operation>Remove the string with the given index row from this model's string list, signaling to this model that a row has been removed.</operation>
                           <operation>Return true.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>index</name>
                              <description>The model index of the string that is removed.</description>
                              <type>const QModelIndex&amp;</type>
                           </data>
                        </variable>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>moveUp</name>
                           <description>Moves the string with the given model index up its model's string list by one, returning a new model index for the moved string. Moving up means decreasing its index by one. The given index becomes invalid if the string is moved and should always be overwritten by the returned index. If this model has no string list then an exception is thrown.</description>
                           <type>QModelIndex</type>
                           <return_description>New model index for the string with the given index.</return_description>
                           <operation>If this model has no string list then throw an exception.</operation>
                           <operation>If the given index is not valid or it is out of range then return the given index.</operation>
                           <operation>Move the string with the given index up this model's string list by one by decreasing its index, signaling to this model that a row has been moved.</operation>
                           <operation>Return a new model index for the moved string.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>index</name>
                              <description>The model index of the string that is moved.</description>
                              <type>const QModelIndex&amp;</type>
                           </data>
                        </variable>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>moveDown</name>
                           <description>Moves the string with the given model index down its model's string list by one, returning a new model index for the moved string. Moving down means increasing its index by one. The given index becomes invalid if the string is moved and should always be overwritten by the returned index. If this model has no string list then an exception is thrown.</description>
                           <type>QModelIndex</type>
                           <return_description>New model index for the string with the given index.</return_description>
                           <operation>If this model has no string list then throw an exception.</operation>
                           <operation>If the given index is not valid or it is out of range then return the given index.</operation>
                           <operation>Move the string with the given index down this model's string list by one by increasing its index, signaling to this model that a row has been moved.</operation>
                           <operation>Return a new model index for the moved string.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>index</name>
                              <description>The model index of the string that is moved.</description>
                              <type>const QModelIndex&amp;</type>
                           </data>
                        </variable>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>setList</name>
                           <description>Sets the string list for this model. This model does not take ownership of the given string list and must not be deleted as long as it is part of this model. A null pointer can be passed to set this model to a null state.</description>
                           <type>void</type>
                           <operation>Set this model's string list pointer to the given one, signaling to this model that a reset of the entire model has occurred.</operation>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>list</name>
                              <description>Pointer to the string list this model is set to or null to set this model to a null state.</description>
                              <type>QStringList*</type>
                           </data>
                        </variable>
                     </function>
                  </access>
                  <access type="5">
                     <data version="0">
                        <type>private:</type>
                     </data>
                     <variable type="1">
                        <data version="0">
                           <name>_list</name>
                           <description>Pointer to the string list this model represents.</description>
                           <type>QStringList*</type>
                           <initializer>nullptr</initializer>
                        </data>
                     </variable>
                  </access>
               </class>
               <function type="2">
                  <data version="0">
                     <name>setupView</name>
                     <description>Constructs this new object's model and initializes the model and this qt table view.</description>
                     <type>void</type>
                     <operation>Create this object's model with this object's list and set this qt table view's model to the new model.</operation>
                     <operation>Initialize this qt table view and connect its relevant signals.</operation>
                  </data>
               </function>
