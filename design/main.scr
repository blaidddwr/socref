        <access>
          <data>
            <type>public:</type>
          </data>
          <function>
            <data>
              <default/>
              <description>Constructs a new basic block.</description>
              <explicit/>
              <invokable/>
              <name>^</name>
              <return_description></return_description>
              <type></type>
            </data>
          </function>
          <function>
            <data>
              <description>Initializes this basic block to the given type. This must be called before this basic block can be used and cannot be called again.</description>
              <name>initialize</name>
              <operation>Make sure this basic block has NOT been initialized.</operation>
              <operation>Set the type, factory, and build list for this new basic block.</operation>
              <operation>Save the XML element definition for making copies of this basic block.</operation>
              <operation>Prepare an enumeration and string list that stores all possible element tag names that are recognized.</operation>
              <operation>Iterate through all node children of the given XML definition element.</operation>
              <operation>Check to see if the node is an element.</operation>
              <operation>Determine if the tag name of this element is recognized as a configuration option, adding the field or setting the option if it is.</operation>
              <operation>Move to the next sibling node.</operation>
              <return_description></return_description>
              <type>void</type>
            </data>
            <variable>
              <data>
                <description>The block type of this new basic block.</description>
                <initializer></initializer>
                <name>type</name>
                <type>int</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The basic block factory that made this new basic block.</description>
                <initializer></initializer>
                <name>factory</name>
                <type>const Abstract::BlockFactory*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The XML element that defines all data fields and options of the basic block type this new basic block is being initialized to.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>The build list of the basic block type this new basic block is being initialized to.</description>
                <initializer></initializer>
                <name>buildList</name>
                <type>const QList&lt;int>&amp;</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>True if the data fields should be set to default values or false to set them to their null values.</description>
                <initializer></initializer>
                <name>isDefault</name>
                <type>bool</type>
              </data>
            </variable>
          </function>
        </access>
        <access>
          <data>
            <type>protected:</type>
          </data>
          <function>
            <data>
              <const/>
              <description>This interface returns a new basic block view implementation for this basic block. The default interface returns a generic basic block view. This should be used for basic block views that use the custom view element in its definition.</description>
              <name>makeBasicView</name>
              <return_description>New basic block view implementation for this basic block.</return_description>
              <type>Soc::Ut::QPtr&lt;Basic::BlockView></type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>readData</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Iterate through all node children of the given data element.</operation>
              <operation>Check to see if the node is an element.</operation>
              <operation>Find the data field with the id that matches the element's tag name, making sure it exists.</operation>
              <operation>Set the data field based off what type it is, throwing an exception if it is an unknown type.</operation>
              <operation>Move to the next sibling node.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>element</name>
                <type>const QDomElement&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>writeData</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Create the return data element.</operation>
              <operation>Iterate through all data fields of this basic block.</operation>
              <operation>Based off the data field type write out its data as child elements appended to the data element to be returned, marking sure the field type is recognized.</operation>
              <operation>Return the complete data element that stores this basic block's field data.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QDomElement</type>
              <virtual/>
            </data>
            <variable>
              <data>
                <description>See interface docs.</description>
                <initializer></initializer>
                <name>document</name>
                <type>QDomDocument&amp;</type>
              </data>
            </variable>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>createBlank</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Create a new uninitialized basic block, making sure it worked.</operation>
              <operation>Initialize the new basic block to this basic block's type.</operation>
              <operation>Return the initialized basic block.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>Soc::Ut::QPtr&lt;Abstract::Block></type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <description>Implements _Abstract::Block_ interface.</description>
              <final/>
              <name>copyDataFrom</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Cast the given abstract block to a basic block, making sure it worked.</operation>
              <operation>Iterate through all the fields of the given basic block.</operation>
              <operation>Find the corresponding field of this basic block, making sure it was found.</operation>
              <operation>Make sure the field types matched between this and the other basic block.</operation>
              <operation>Copy the value of the given basic block field to this basic block.</operation>
              <override/>
              <return_description></return_description>
              <type>void</type>
              <virtual/>
            </data>
