          </data>
          <variable>
            <data>
              <description>The index of the child that is taken.</description>
              <initializer></initializer>
              <name>index</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Removes the child block at the given index, deleting it and any children it may contain. If the given index is out of range then an exception is thrown.</description>
            <name>remove</name>
            <operation>Take this block's child from the given index and delete it.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The index of the child that is removed and deleted.</description>
              <initializer></initializer>
              <name>index</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Reads in block data from an XML element. This clears any existing data this block contains, including the removal and deletion of all existing children. This recursively adds any children contained in the XML reading in their data from child XML elements.</description>
            <name>read</name>
            <operation>Delete and clear any existing children this block may contain.</operation>
            <operation>Iterate through all children nodes of the given element.</operation>
            <operation>Check if the node is an element.</operation>
            <operation>If the tag name is the data tag then read in this block's data else read in the element as a new child for this block.</operation>
            <operation>Move to the next node sibling.</operation>
            <operation>Make sure all children of this block is allowed to this block's child list.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The XML element that stores block data this block reads as input.</description>
              <initializer></initializer>
              <name>element</name>
              <type>const QDomElement&amp;</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>signals:</type>
        </data>
        <function>
          <data>
            <description>Signals that a child block of this block has been modified. The given child block could be any depth below this block. Only the root block emits this signal.</description>
            <name>modified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Signals that a child block of this block with the given pointer has modified its name. The given child block could be any depth below this block. Only the root block emits this signal.</description>
            <name>nameModified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer of the child whose name has changed.</description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Signals that a child block of this block with the given pointer has modified its body. The given child block could be any depth below this block. Only the root block emits this signal.</description>
            <name>bodyModified</name>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description></description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>protected:</type>
        </data>
        <function>
          <data>
            <abstract/>
            <description>This interface reads in the data for this block from the given XML element, overwriting any data this block currently holds.</description>
            <name>readData</name>
            <return_description></return_description>
            <type>void</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>The XML element used to read in this blocks data.</description>
              <initializer></initializer>
              <name>element</name>
              <type>const QDomElement&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns a XML element containing the data for this block using the current version number. Attributes should never be used with this element because of their indeterminate nature.</description>
            <name>writeData</name>
            <return_description>XML element containing the data of this block.</return_description>
            <type>QDomElement</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>XML document to use for creating new elements.</description>
              <initializer></initializer>
              <name>document</name>
              <type>QDomDocument&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface makes a new block object of this block's type with no data and returns a pointer to the new block.</description>
            <name>makeBlank</name>
            <return_description>Pointer to the newly created block.</return_description>
            <type>Soc::Ut::QPtr&lt;AbstractBlock></type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <abstract/>
            <description>This interface copies all data from the given block to this block, overwriting any data this block may already contain. This does not copy any children.</description>
            <name>copyDataFrom</name>
            <return_description></return_description>
            <type>void</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>The other block whose data will be copied.</description>
              <initializer></initializer>
              <name>other</name>
              <type>const AbstractBlock*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>This interface is called whenever a child below this block has modified its name. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
            <name>childNameModified</name>
            <operation>Return false.</operation>
            <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
            <type>bool</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Pointer to the child block that has modified its name.</description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>This interface is called whenever a new child below this block has been added. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
            <name>childAdded</name>
            <operation>Return false.</operation>
            <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
            <type>bool</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Pointer to the child block that been added to its new parent block.</description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>This interface is called whenever an existing child below this block has been removed. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
            <name>childRemoved</name>
            <operation>Return false.</operation>
            <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
            <type>bool</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Pointer to the child block that has been removed from its former parent block. This object can be deleted right after this call.</description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>This interface is called whenever an existing child below this block has been moved. This keeps getting called on the next block parent until this returns false. The default implementation does nothing and returns false.</description>
            <name>childMoved</name>
            <operation>Return false.</operation>
            <return_description>True if this interface should be called again on this blocks parent or false otherwise.</return_description>
            <type>bool</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Pointer to the child block that has been moved in its parent's list of children.</description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractBlock*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>protected:</type>
        </data>
        <function>
          <data>
            <description>Notifies this block has been modified by finding its root block and emitting its modified signal.</description>
            <name>notifyModified</name>
            <operation>Find the root block of this block and emit its modified signal.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Notifies this block's name has been modified by finding its root block and emitting its name modified signal. If this is called by a root block an exception is thrown because the root has no name.</description>
            <name>notifyNameModified</name>
            <operation>Get a pointer to this block's parent block.</operation>
            <operation>Make sure the parent block pointer is not null.</operation>
            <operation>Starting with this block's parent iterate up the tree of parents, calling their child name modified interface, until the root block is reached or the child name modified interface returns false.</operation>
            <operation>Find the root block of this block and emit its name modified signal.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Notifies this block's body has been modified by finding its root block and emitting its name modified signal. If this is called by a root block an exception is thrown because the root has no body.</description>
            <name>notifyBodyModified</name>
            <operation>Get a pointer to this block's parent block.</operation>
            <operation>Make sure the parent block pointer is not null.</operation>
            <operation>Find the root block of this block and emit its body modified signal.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>Copies all children from the given block and appends the copies to the list of this block's children. This does not remove any previous children already part of this block.</description>
            <name>copyChildren</name>
            <operation>Iterate through all the children of the given block.</operation>
            <operation>Make a copy of the child and append it to this block.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to block whose children are copied.</description>
              <initializer></initializer>
              <name>parent</name>
              <type>const AbstractBlock*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Creates a new child reading it in from the given XML element. The new child is then appended to this block's list of children.</description>
            <name>readChild</name>
            <operation>Read in the type attribute from the given child element.</operation>
            <operation>Make sure reading in the type did not fail.</operation>
            <operation>Make sure the read in type is within range of this block's factory.</operation>
            <operation>Create a new block with the read in type and append it to this block's child list.</operation>
            <operation>Have the new block read in its data and children from the given element.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>XML element used to read in the new child.</description>
              <initializer></initializer>
              <name>element</name>
              <type>const QDomElement&amp;</type>
            </data>
          </variable>
        </function>
        <variable>
          <data>
            <description>The name for version attributes.</description>
            <initializer>"version"</initializer>
            <name>_versionTag</name>
            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The tag name for data elements.</description>
            <initializer>"data"</initializer>
            <name>_dataTag</name>
            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>The name for type attributes.</description>
            <initializer>"type"</initializer>
            <name>_typeTag</name>
            <static/>
            <type>const char*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Pointer list of this block's children.</description>
            <initializer></initializer>
            <name>_children</name>
            <type>QList&lt;AbstractBlock*></type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This represents the factory that can produce blocks for a specific project type. There should only be one instance of this class for each project type. Along with making new blocks this factory also gives basic information about each block type such as its display and element names. The two element name functions must mirror one another in an implementation or undefined behavior will occur.</description>
        <name>AbstractBlockFactory</name>
      </data>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <default/>
            <description>Virtual destructor so implemented classes have their destructor called correctly.</description>
            <name>~^</name>
            <return_description></return_description>
            <type></type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns the project type of this block factory.</description>
            <name>type</name>
            <return_description>Project type.</return_description>
            <type>int</type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns the number of block types that exist for this factory. Block types must be defined for all integers from 0 to one less than the number of block types returned by this interface.</description>
            <name>size</name>
            <return_description>Number of block types that exist for this factory.</return_description>
            <type>int</type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns the display name for the given block type.</description>
            <name>name</name>
            <return_description>Display name for the given block type.</return_description>
            <type>QString</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Block type whose display name is returned.</description>
              <initializer></initializer>
              <name>type</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns the integer type of the block with the given element name. If no block type exists with the given name then -1 is returned.</description>
            <name>typeByElementName</name>
            <return_description>The integer type of the block with the given element name if found or -1 if no block type is found with that element name.</return_description>
            <type>int</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>The given element name whose integer type is returned if found.</description>
              <initializer></initializer>
              <name>elementName</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns the element name for the given block type. The element name is used as the tag name in XML elements for reading/writing of blocks.</description>
            <name>elementName</name>
            <return_description>Element name for the given block type.</return_description>
            <type>QString</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Block type whose element name is returned.</description>
              <initializer></initializer>
              <name>type</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface makes a new block of the given type and returns its pointer. The new block is expected to have either a null data or new default state, depending on the given flag.</description>
            <name>makeBlock</name>
            <return_description>Pointer to new block with given type.</return_description>
            <type>Soc::Ut::QPtr&lt;AbstractBlock></type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Block type which is made and returned.</description>
              <initializer></initializer>
              <name>type</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>True if the new block is initialized to a default state or false if it is uninitialized in a null state.</description>
              <initializer></initializer>
              <name>isDefault</name>
              <type>bool</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface makes a new root block and returns its pointer. The root block is used as the root block for all projects of this project type. The new root block is expected to have a null data state.</description>
            <name>makeRootBlock</name>
            <return_description>Pointer to new root block for this project type.</return_description>
            <type>Soc::Ut::QPtr&lt;AbstractBlock></type>
            <virtual/>
          </data>
        </function>
      </access>
    </class>
    <class>
      <data>
        <description>This represents a parser object which takes in a single source code file to parse and outputs the results, overwriting the file if the results are different from the original contents. It can contain child parser objects which can be used for parsing segments of the source file allowing for specializing of parsing within segments of the file. Children parser objects will write lines to its root parser object. This allows for parsing the same file but using different parser object types when different parts of the file are reached. This class is designed to only have implementations executed once and then destroyed.</description>
        <name>AbstractParser</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QObject</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <description>Constructs a new parser object that will be a root or primary parser. This means this parser will be assumed to be the root parser of a source file.</description>
            <explicit/>
            <name>^</name>
            <operation>Allocate new resources required for this new parser object.</operation>
            <return_description></return_description>
            <type></type>
          </data>
        </function>
        <function>
          <data>
            <description>Constructs a new parser object that is a child of another parser object. This sets up this object to use the resources of its root parser object.</description>
            <explicit/>
            <name>^</name>
            <operation>Set this object's parent as the given parent parser and add this parser to its parent's list of children.</operation>
            <operation>Find the root parser and this object's root parser pointer.</operation>
            <operation>Set all resource pointers to point to this object's root parser resources.</operation>
            <return_description></return_description>
            <type></type>
          </data>
          <variable>
            <data>
              <description>The parent parser object for this new parser object.</description>
              <initializer></initializer>
              <name>parent</name>
              <type>AbstractParser*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Deletes the dynamically allocated resources if this is a root parser. If this object is a child parser then nothing is done.</description>
            <name>~^</name>
            <operation>Make sure this is the root parser.</operation>
            <operation>Delete all resources of this root parser.</operation>
            <return_description></return_description>
            <type></type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <description>Parses the given file using this parser as the root parser. If this is a child parser then this does nothing.</description>
            <name>execute</name>
            <operation>Make sure this is a root parser.</operation>
            <operation>Initialize this parser and read in the given file.</operation>
            <operation>Process the input from the read in file then process the output making a temporary output.</operation>
            <operation>Possibly write the processed output to the given file.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Qt file handle to the file that is parsed.</description>
              <initializer></initializer>
              <name>file</name>
              <type>QFile*</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>protected:</type>
        </data>
        <function>
          <data>
            <description>This interface initializes this parser and is called before any parsing begins. The default implementation does nothing.</description>
            <name>initialize</name>
            <return_description></return_description>
            <type>void</type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <abstract/>
            <description>This interface is called for each line of the input source file, reading in all lines of the file until the end is reached or this returns false. If false is returned and this is a child parser then this interface keeps getting called on this object's parent parser under the same conditions. A different function is used to signal this parser should start feeding input lines to a child parser this parser contains.</description>
            <name>readLine</name>
            <return_description>True signals this interface should continue being called on lines else false signals this parser is finished processing input.</return_description>
            <type>bool</type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>The line from the source file that is processed.</description>
              <initializer></initializer>
              <name>line</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <abstract/>
            <description>This interface creates the output lines for the source file, using the add and indent functions to do so.</description>
            <name>makeOutput</name>
            <return_description></return_description>
            <type>void</type>
            <virtual/>
          </data>
        </function>
      </access>
      <access>
        <data>
          <type>protected:</type>
        </data>
        <function>
          <data>
            <description>Signals this parser that the given child parser should be used for reading lines until it returns false or the last line is processed. If the given parser is not a direct child of this parser then an exception is thrown.</description>
            <name>stepIntoChild</name>
            <operation>Make sure the given parser is a direct child of this parser.</operation>
            <operation>Set this object's step into child pointer to the given parser.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Pointer to the child parser whose interface for reading lines will be called from now on.</description>
              <initializer></initializer>
              <name>child</name>
              <type>AbstractParser*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <const/>
            <description>Returns the indent, in spaces, that is prepended to each line added to the output.</description>
            <name>indent</name>
            <return_description>Number of spaces prepended to each added line of output.</return_description>
            <type>int</type>
          </data>
        </function>
        <function>
          <data>
            <description>Sets the indent, in spaces, that is prepended to each line added to output.</description>
            <name>setIndent</name>
            <operation>Make sure the given indent is not negative.</operation>
            <operation>Set the this object's root indent to the new value.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The new indent value in spaces.</description>
              <initializer></initializer>
              <name>indent</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Adds the given line as a new line to output, appending it to the end of any existing lines. The line is prepended with a number of spaces equal to the indent.</description>
            <name>add</name>
            <operation>Add white space equal to this object's root indent to the beginning of the given line and then append the line as a new output line.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The line that is prepended with the indent and appended to the output.</description>
              <initializer></initializer>
              <name>line</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Appends multiple lines to the output, each one being prepended with spaces equal to the indent.</description>
            <name>add</name>
            <operation>Iterate through all strings of the given string list and add each one as output.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>Lines that are appended to the output.</description>
              <initializer></initializer>
              <name>lines</name>
              <type>const QStringList&amp;</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Appends the given number of blank lines to the output. If the given number is less than 1 then nothing is added to the output.</description>
            <name>add</name>
            <operation>Add the given number of blank lines to output.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The number of blank lines added to the output.</description>
              <initializer></initializer>
              <name>count</name>
              <type>int</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Adds output lines from the given text with the given justification, max columns per line, and comment token. The lines are formatted as paragraphs, using double newline characters to separate the paragraphs. The justification is used to add extra space to every other line after the first one. This does not add the  opening and closing comment lines. At the beginning of each line the given comment characters are added.</description>
            <name>addComment</name>
            <operation>Make sure the given justified value is valid.</operation>
            <operation>Make sure the given text is not empty.</operation>
            <operation>Split the given text into paragraphs, using double newline characters as the separator and skipping empty paragraphs.</operation>
            <operation>Iterate through all the paragraphs.</operation>
            <operation>Split the paragraph into its individual words.</operation>
            <operation>Keep working until all words have been processed.</operation>
            <operation>Initialize the total number of columns used and the next output line.</operation>
            <operation>Check if this is the first line.</operation>
            <operation>Else this is not the first line so append the number of justification spaces to the output line and add the number of columns used to the total.</operation>
            <operation>Append the first word to the output line. The columns used was already added to the total when it was initialized.</operation>
            <operation>Keep working until there are no more words to process or the output line has reached the maximum number of columns.</operation>
            <operation>Add the number of columns the next word will use to the total and then add the next word to the output line.</operation>
            <operation>Add the finished output line to the output file of this parser.</operation>
            <operation>If this is not the last paragraph add a separator line for the next one.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The comment token that is added to the beginning of each comment line added to this parser object's output file.</description>
              <initializer></initializer>
              <name>token</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The text that is used to make and added and formatted output lines.</description>
              <initializer></initializer>
              <name>text</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The justification used for adding extra spaces before every output line after the first.</description>
              <initializer></initializer>
              <name>justified</name>
              <type>int</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>The maximum number of columns each line of a comment can possess.</description>
              <initializer></initializer>
              <name>max</name>
              <type>int</type>
            </data>
          </variable>
        </function>
      </access>
      <access>
        <data>
          <type>private:</type>
        </data>
        <function>
          <data>
            <description>Reads in the source file, splitting them into lines, and prepares the output.</description>
            <name>read</name>
            <operation>Read in the entire contents of the given file to this object's original string.</operation>
            <operation>Make sure reading in the given file did not fail.</operation>
            <operation>Split this object's original content by line and save it to this object's list of input lines to be processed.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The file used as input.</description>
              <initializer></initializer>
              <name>file</name>
              <type>QFile*</type>
            </data>
          </variable>
        </function>
        <function>
          <data>
            <description>Processes the input of the source file, using the read line interface for processing.</description>
            <name>processInput</name>
            <operation>Iterate through all input lines using this object's root index to keep track of which line is next.</operation>
            <operation>Process the next line, returning from this function if the interface returns false. This will move parsing back to the parent parser unless this is the root parser in which case processing of input will end.</operation>
            <operation>Check if the step into child pointer was set.</operation>
            <operation>Step into this object's step into child pointer for processing until it returns and then clear the step into child pointer.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Processes the output by calling the make output interface.</description>
            <name>processOutput</name>
            <operation>Clear any output lines this parser may contain and reset the root indent to 0.</operation>
            <operation>Call the make output interface responsible for building all output lines.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
        </function>
        <function>
          <data>
            <description>Write the processed output to the given file if, after joining the output lines, it is different from the original. If the output is the same as the original then this does nothing.</description>
            <name>write</name>
            <operation>Join the root parser object's output lines into a single new source string.</operation>
            <operation>Make sure the new source string is different from the original file.</operation>
            <operation>Truncate the given file and make sure it did not fail.</operation>
            <operation>Write the new source string to the given file and make sure it did not fail.</operation>
            <return_description></return_description>
            <type>void</type>
          </data>
          <variable>
            <data>
              <description>The file that is truncated and written to if the output is different from the original.</description>
              <initializer></initializer>
              <name>file</name>
              <type>QFile*</type>
            </data>
          </variable>
        </function>
        <variable>
          <data>
            <description>The original content of the file that is used to compare the output once parsing is complete.</description>
            <initializer></initializer>
            <name>_original</name>
            <type>QString</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Pointer to the input lines of the parsed source file. All parsing object's with the same root share this as a single resource where the root parser is responsible for allocating and destroying it.</description>
            <initializer>nullptr</initializer>
            <name>_input</name>
            <type>QStringList*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>This stores the index pointing to the next input line to be processed. All parsing object's with the same root share this as a single resource where the root parser is responsible for allocating and destroying it.</description>
            <initializer>nullptr</initializer>
            <name>_index</name>
            <type>int*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Pointer to the indent that is used for prepending spaces to all output lines when they are added. All parsing object's with the same root share this as a single resource where the root parser is responsible for allocating and destroying it.</description>
            <initializer>nullptr</initializer>
            <name>_indent</name>
            <type>int*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Pointer to the output lines of the parsed file. All parsing object's with the same root share this as a single resource where the root parser is responsible for allocating and destroying it.</description>
            <initializer>nullptr</initializer>
            <name>_output</name>
            <type>QStringList*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Pointer to this parser object's root parser object. If this parser is the root then this is null.</description>
            <initializer>nullptr</initializer>
            <name>_root</name>
            <type>AbstractParser*</type>
          </data>
        </variable>
        <variable>
          <data>
            <description>A list of pointers to all of this parser object's children.</description>
            <initializer></initializer>
            <name>_children</name>
            <type>QList&lt;AbstractParser*></type>
          </data>
        </variable>
        <variable>
          <data>
            <description>Special pointer signal variable set by the step into child function. It is used to signal the process input function that it should step into the pointed to child parser object's process input function.</description>
            <initializer>nullptr</initializer>
            <name>_child</name>
            <type>AbstractParser*</type>
          </data>
        </variable>
      </access>
    </class>
    <class>
      <data>
        <description>This represents the factory that can produce parser objects for a specific project type. It is a very simple class that has only one interface for producing new parser objects to parse individual source files.</description>
        <name>AbstractParserFactory</name>
        <qtobject/>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>QObject</class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface makes a new parser object from the given file and and extension. This can return a null pointer in which case the source file is ignored and skipped.</description>
            <name>make</name>
            <return_description>Pointer to new parser object or null pointer.</return_description>
            <type>Soc::Ut::QPtr&lt;AbstractParser></type>
            <virtual/>
          </data>
          <variable>
            <data>
              <description>Name of the source file that is parsed with the returned parser object.</description>
              <initializer></initializer>
              <name>name</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
          <variable>
            <data>
              <description>Extension of the file that is parsed with the returned parser object.</description>
              <initializer></initializer>
              <name>extension</name>
              <type>const QString&amp;</type>
            </data>
          </variable>
        </function>
      </access>
    </class>
    <class>
      <data>
        <description>This represents the factory that provides all other factories and information to define a project type. A project type is defined as a specific programming language that a project references. This is a global singleton class so only one instance of this factory is available for the entire application. A new factory instance must be set at initialization of the program and should not be set again after that. To maintain backwards compatibility all previously defined project type element names must never change and the two element methods must mirror one another.</description>
        <name>AbstractProjectFactory</name>
      </data>
      <parent>
        <data>
          <access>public</access>
          <class>Soc::Ut::SingletonFactory&lt;AbstractProjectFactory></class>
        </data>
      </parent>
      <access>
        <data>
          <type>public:</type>
        </data>
        <function>
          <data>
            <default/>
            <description>Virtual destructor so implemented classes have their destructor called correctly.</description>
            <name>~^</name>
            <return_description></return_description>
            <type></type>
            <virtual/>
          </data>
        </function>
        <function>
          <data>
            <abstract/>
            <const/>
            <description>This interface returns the number of project types that exist. Project types must be defined for all integers from 0 to one less than the number of project types returned by this interface.</description>
            <name>size</name>
            <return_description>Number of project types that exist.</return_description>
            <type>int</type>
            <virtual/>
          </data>
        </function>
