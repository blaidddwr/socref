      <class type="4">
         <data version="1">
            <name>Application</name>
            <description>This is the main application class for this program. It implements the notify interface to be able to handle exceptions. It also contains the version of the program, along with the keys used to access this program's qt settings.</description>
            <qtobject/>
         </data>
         <parent type="13">
            <data version="2">
               <access>public</access>
               <class>QApplication</class>
            </data>
         </parent>
         <access type="5">
            <data version="1">
               <type>public:</type>
            </data>
            <constructor type="9">
               <data version="1">
                  <description>Constructs a new application instance.</description>
                  <type></type>
                  <explicit/>
               </data>
               <variable type="1">
                  <data version="1">
                     <name>argc</name>
                     <description>The argument count from main.</description>
                     <type>int&amp;</type>
                  </data>
               </variable>
