                  <data version="0">
                     <name>setupActions</name>
                     <description>Constructs and initializes all shortcut actions for this new list edit widget.</description>
                     <type>void</type>
                     <operation>Add the new action.</operation>
                     <operation>Add the remove action.</operation>
                     <operation>Add the move up action.</operation>
                     <operation>Add the move down action.</operation>
