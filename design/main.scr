               <class type="4">
                  <data version="0">
                     <name>View</name>
                     <description>This is the view class for the function block. This is designed so any inherited classes using the function block should not and cannot implement their own view.</description>
                     <qtobject/>
                  </data>
                  <parent type="13">
                     <data version="0">
                        <access>public</access>
                        <class>Base::View</class>
                     </data>
                  </parent>
                  <access type="5">
                     <data version="0">
                        <type>public:</type>
                     </data>
                     <constructor type="9">
                        <data version="0">
                           <description>Constructs a new view object with the given function block.</description>
                        </data>
                        <variable type="1">
                           <data version="0">
                              <name>block</name>
                              <description>Function block this new view displays.</description>
                              <type>const Function*</type>
                           </data>
                        </variable>
                     </constructor>
                  </access>
                  <access type="5">
                     <data version="0">
                        <type>private:</type>
                     </data>
                     <function type="2">
                        <data version="0">
                           <name>displayText</name>
                           <description>Returns the HTML rich text that displays the body of this view's function block.</description>
                           <type>QString</type>
                           <return_description>HTML rich text that displays the body of this view's function block.</return_description>
                        </data>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>displayArguments</name>
                           <description>Returns a HTML string that displays any arguments this view's function block contains. If this view's function block has no arguments then this returns an empty string.</description>
                           <type>QString</type>
                           <return_description>HTML string that displays any arguments this view's function block contains or an empty string if there are no arguments.</return_description>
                           <operation>Create an empty string _ret_ and then a pointer list _list_ of this object's function block's arguments. If _list_ is empty then return _ret_.</operation>
                           <operation>Append an HTML title to _ret_, then all arguments from _list_ as an HTML list to _ret_. Include the variable type, base name, initialized value, and description for each argument listing.</operation>
                           <operation>Return _ret_.</operation>
                        </data>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>displayProperties</name>
                           <description>Returns a HTML string that displays any properties this view's function block has set. If this view's function block has no properties set then this returns an empty string.</description>
                           <type>QString</type>
                           <return_description>HTML string that displays any properties this view's function block has set or an empty string if no properties are set.</return_description>
                           <operation>Create an empty string _ret_ and then an empty string list _list_. Append any properties this object's function block has set to _list_. If _list_ is empty then return _ret_.</operation>
                           <operation>Append an HTML title, then all set properties as an HTML list to _ret_, and then return _ret_.</operation>
                        </data>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>displayReturn</name>
                           <description>Returns a HTML string that displays the return type field for this view's function block.</description>
                           <type>QString</type>
                           <return_description>HTML string that displays the return type field of this view's function block.</return_description>
                           <operation>Create and return a string that contains HTML for this object's function return type field along with a title. Replace any special carrot characters so it doesn't break the HTML code.</operation>
                        </data>
                     </function>
                     <function type="2">
                        <data version="0">
                           <name>displayOperations</name>
                           <description>Returns a HTML string that displays the operations of this view's function block. If the function block has operations then an empty string is returned.</description>
                           <type>QString</type>
                           <return_description>HTML string that displays the operations of this view's function block or an empty string if there are no operations.</return_description>
                           <operation>Create an empty string _ret_ and then get this view's function block's operations saving it to _list_. If _list_ is empty then return _ret_.</operation>
                           <operation>Append an HTML title and then the list of operations stored in _list_ as an HTML list to _ret_.</operation>
                           <operation>Return _ret_.</operation>
                        </data>
                     </function>
                     <variable type="1">
                        <data version="0">
                           <name>_block</name>
                           <description>The function block that this view is displaying.</description>
                           <type>const Function*</type>
                        </data>
                     </variable>
                  </access>
               </class>
            </access>
