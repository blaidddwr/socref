              <operation>Setup this new object's view and actions.</operation>
              <return_description></return_description>
              <type></type>
            </data>
            <variable>
              <data>
                <description>Pointer to the block that is contextually being used in text dialog objects this widget opens.</description>
                <initializer></initializer>
                <name>block</name>
                <type>Abstract::Block*</type>
              </data>
            </variable>
            <variable>
              <data>
                <description>Optional parent for this new list edit widget.</description>
                <initializer>nullptr</initializer>
                <name>parent</name>
