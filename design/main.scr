              <name>isQtObject</name>
              <return_description>True if this class is a qt object or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if any methods of this class are virtual.</description>
              <name>isVirtual</name>
              <operation>Iterate through all access block children of this class block, returning true if any of them has any virtual functions.</operation>
              <operation>If this is reached then this class has no virtual methods so return false.</operation>
              <return_description>True if any methods of this class are virtual or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this class has any methods that are abstract.</description>
              <name>isAbstract</name>
              <operation>Iterate through all access block children of this class block, returning true if any of them has any abstract functions.</operation>
              <operation>If this is reached then this class has no abstract methods so return false.</operation>
              <return_description>True if this class has any abstract methods or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this class has any template arguments.</description>
              <name>hasTemplates</name>
              <return_description>True if this class has any template arguments or false otherwise.</return_description>
              <type>bool</type>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Tests if this class or any parent classes contain any template arguments.</description>
              <name>hasAnyTemplates</name>
              <operation>Make sure this class block does not have any template arguments.</operation>
              <operation>Iterate up the chain of block parents starting with this block's parent until a namespace or null pointer is reached.</operation>
              <operation>If this parent is a class and it has template arguments then return true.</operation>
              <operation>Move up to the next parent block.</operation>
              <operation>If this is reached then no template arguments were found so return false.</operation>
              <return_description>True if this class or any parent class contains any template arguments, otherwise false is returned.</return_description>
              <type>bool</type>
            </data>
