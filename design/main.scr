                  </data>
               </variable>
            </function>
            <function type="2">
               <data version="1">
                  <name>makeBlank</name>
                  <description>This interface makes a new block object of this block's type with no data and returns a pointer to the new block.</description>
                  <type>std::unique_ptr&lt;AbstractBlock></type>
