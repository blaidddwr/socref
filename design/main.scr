      <class>
        <data>
          <description>This is the variable block. This represents any global, class member, or function argument variable. This supports the constant expression, static, mutable, and thread local properties. This also supports having an initial value.</description>
          <name>Variable</name>
          <qtobject/>
        </data>
        <parent>
          <data>
            <access>public</access>
