              <operation>Return a reference to this basic block's factory.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>const Abstract::BlockFactory&amp;</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <name>name</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Make sure this basic block's name field id is not empty.</operation>
              <operation>Get this basic block's field with its name field id, making it exists and is the correct field type.</operation>
              <operation>Return the found string field.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QString</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <name>icon</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Return this basic block type's icon.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QIcon</type>
              <virtual/>
            </data>
          </function>
          <function>
            <data>
              <const/>
              <description>Implements _Abstract::Block_ interface.</description>
              <name>buildList</name>
              <operation>Make sure this basic block has been initialized.</operation>
              <operation>Return this basic block type's build list.</operation>
              <override/>
              <return_description>See interface docs.</return_description>
              <type>QList&lt;int></type>
