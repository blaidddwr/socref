<glsl>



<namespace display="Namespace" root="yes">
    <icon>:/icons/namespace.svg</icon>
    <string id="name" default="space"/>
    <string id="description"/>
    <name>name</name>
    <buildlist>
        <namespace/>
        <shader/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</namespace>



<shader display="Shader">
    <icon>:/icons/shader.svg</icon>
    <string id="name" default="shader"/>
    <string id="description"/>
    <string id="type" default="vertex"/>
    <buildlist>
        <variable/>
        <struct/>
        <function/>
    </buildlist>
    <edit>
        <form>
            <combo id="type" display="Type:">
                <option value="vertex"/>
                <option value="tesselation control"/>
                <option value="tesselation evaluation"/>
                <option value="geometry"/>
                <option value="fragment"/>
                <option value="compute"/>
            </combo>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Type</h3>
        <ps id="type"/>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</shader>



<variable display="Variable">
    <icon>:/icons/variable.svg</icon>
    <string id="name" default="var"/>
    <string id="description"/>
    <string id="type" default="vec3"/>
    <string id="layout"/>
    <name>name</name>
    <edit>
        <form>
            <text id="layout" spell="no" dialog="no" display="Layout:"/>
            <line id="type" display="Type:"/>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Type</h3>
        <ps id="type"/>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayLayout"/>
    </view>
</variable>



<struct display="Structure">
    <icon>:/icons/struct.svg</icon>
    <string id="name" default="struct"/>
    <string id="description"/>
    <string id="type" default="STRUCT"/>
    <string id="layout"/>
    <name>name</name>
    <buildlist>
        <variable/>
    </buildlist>
    <edit>
        <form>
            <text id="layout" display="Layout:"/>
            <line id="type" display="Type Name:"/>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Type Name</h3>
        <ps id="type"/>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayLayout"/>
    </view>
</struct>



<function display="Function">
    <icon>:/icons/function.svg</icon>
    <string id="name" default="foo"/>
    <string id="description"/>
    <string id="type" default="void"/>
    <string id="return_description"/>
    <stringlist id="operation"/>
    <buildlist>
        <variable/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <line id="type" display="Return Type:"/>
            <text id="return_description" display="Return Description:"/>
        </form>
        <layout>
            <list id="operation" display="Steps of Operation"/>
        </layout>
    </edit>
    <view>
        <custom name="displayArguments"/>
        <custom name="displayReturn"/>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayOperations"/>
    </view>
</function>



</glsl>
