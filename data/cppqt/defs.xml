<cppqt>



<namespace display="Namespace" root="yes">
    <icon>:/icons/namespace.svg</icon>
    <string id="name" default="space"/>
    <string id="description"/>
    <name>name</name>
    <buildlist>
        <namespace/>
        <enumeration/>
        <variable/>
        <function/>
        <class/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</namespace>



<enumeration display="Enumeration">
    <icon>:/icons/enumeration.svg</icon>
    <string id="name" default="space"/>
    <string id="description"/>
    <bool id="class"/>
    <name>name</name>
    <buildlist>
        <enumvalue/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <checkboxes display="Properties:">
                <checkbox id="class" display="Class"/>
            </checkboxes>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</enumeration>



<enumvalue display="Enumeration Value">
    <icon>:/icons/enumvalue.svg</icon>
    <string id="name" default="value"/>
    <string id="description"/>
    <string id="value"/>
    <name>name</name>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <line id="value" display="Value:"/>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayValue"/>
    </view>
</enumvalue>



<variable display="Variable">
    <string id="name" default="var"/>
    <string id="description"/>
    <string id="type" default="int"/>
    <string id="initializer"/>
    <bool id="constexpr"/>
    <bool id="static"/>
    <bool id="mutable"/>
    <bool id="threadlocal"/>
    <edit>
        <form>
            <line id="type" display="Type:"/>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <line id="initializer" display="Initializer:"/>
            <checkboxes display="Properties:" rowsize="4">
                <checkbox id="constexpr" display="Constant Expression"/>
                <checkbox id="static" display="Static"/>
                <checkbox id="mutable" display="Mutable"/>
                <checkbox id="threadlocal" display="Thread Local"/>
            </checkboxes>
        </form>
    </edit>
    <view>
        <h3>Type</h3>
        <ps id="type"/>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayProperties"/>
        <custom name="displayInitializer"/>
    </view>
</variable>



<template display="Template">
    <icon>:/icons/template.svg</icon>
    <string id="type" default="class"/>
    <string id="name" default="T"/>
    <string id="description"/>
    <name>name</name>
    <edit>
        <form>
            <line id="type" display="Type:"/>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Type</h3>
        <ps id="type"/>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</template>



<function display="Function">
    <string id="name" default="foo"/>
    <string id="description"/>
    <string id="type" default="void"/>
    <string id="return_description"/>
    <stringlist id="operation"/>
    <bool id="default"/>
    <bool id="deleted"/>
    <bool id="invokable"/>
    <bool id="explicit"/>
    <bool id="virtual"/>
    <bool id="const"/>
    <bool id="constexpr"/>
    <bool id="static"/>
    <bool id="noexcept"/>
    <bool id="override"/>
    <bool id="final"/>
    <bool id="abstract"/>
    <buildlist>
        <variable/>
        <template/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <line id="type" display="Return Type:"/>
            <text id="return_description" display="Return Description:"/>
            <checkboxes display="Properties:" rowsize="8">
                <checkbox id="default" display="Default"/>
                <checkbox id="deleted" display="Deleted"/>
                <checkbox id="invokable" display="Qt Invokable"/>
                <checkbox id="explicit" display="Explicit"/>
                <checkbox id="const" display="Constant"/>
                <checkbox id="constexpr" display="Constant Expression"/>
                <checkbox id="static" display="Static"/>
                <checkbox id="noexcept" display="No Exceptions"/>
                <checkbox id="virtual" display="Virtual"/>
                <checkbox id="override" display="Override"/>
                <checkbox id="final" display="Final"/>
                <checkbox id="abstract" display="Abstract"/>
            </checkboxes>
        </form>
        <layout>
            <list id="operation" display="Steps of Operation"/>
        </layout>
    </edit>
    <view>
        <custom name="displayArguments"/>
        <custom name="displayReturn"/>
        <custom name="displayTemplates"/>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayOperations"/>
        <custom name="displayProperties"/>
    </view>
</function>



<class display="Class">
    <string id="name" default="object"/>
    <string id="description"/>
    <bool id="qtobject"/>
    <buildlist>
        <template/>
        <access/>
        <parent/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <checkboxes display="Properties:" rowsize="1">
                <checkbox id="qtobject" display="Qt Object"/>
            </checkboxes>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayQtObject"/>
        <custom name="displayParents"/>
    </view>
</class>



<access display="Access">
    <string id="type" default="public:"/>
    <buildlist>
        <enumeration/>
        <variable/>
        <function/>
        <class/>
        <declaration/>
    </buildlist>
    <edit>
        <form>
            <combo id="type" display="Type:">
                <option value="public:"/>
                <option value="protected:"/>
                <option value="private:"/>
                <option value="signals:"/>
                <option value="public slots:"/>
                <option value="protected slots:"/>
                <option value="private slots:"/>
            </combo>
        </form>
    </edit>
    <view>
        <h3>Tally</h3>
        <custom name="displayInfo"/>
    </view>
</access>



<parent display="Parent">
    <string id="access" default="public"/>
    <string id="class" default="parent"/>
    <name>class</name>
    <edit>
        <form>
            <combo id="access" display="Access:">
                <option value="public"/>
                <option value="protected"/>
                <option value="private"/>
            </combo>
            <line id="class" display="Class:"/>
        </form>
    </edit>
    <view>
        <h3>Access</h3>
        <ps id="access"/>
        <h3>Class</h3>
        <ps id="class"/>
    </view>
</parent>



<declaration display="Declaration">
    <icon>:/icons/declaration.svg</icon>
    <string id="line" default="friend foo()"/>
    <edit>
        <form>
            <line id="line" display="Line:"/>
        </form>
    </edit>
    <view>
        <h3>Line</h3>
        <ps id="line"/>
    </view>
</declaration>



</cppqt>
