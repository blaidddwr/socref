<cppqt>



<typelist display="Type List">
    <icon>:/icons/typelist.svg</icon>
    <string id="name" default="list"/>
    <name>name</name>
    <buildlist>
        <typelist/>
        <type/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Title:"/>
        </form>
    </edit>
    <view>
        <custom name="displayTypeLists"/>
        <custom name="displayTypes"/>
    </view>
</typelist>



<type display="Type">
    <icon>:/icons/type.svg</icon>
    <string id="type" default="int"/>
    <name>type</name>
    <edit>
        <form>
            <line id="type" display="Type:"/>
        </form>
    </edit>
    <view>
        <h3>Type Definition</h3>
        <ps id="type"/>
    </view>
</type>



<namespace display="Namespace" root="yes">
    <icon>:/icons/namespace.svg</icon>
    <string id="name" default="space"/>
    <string id="description"/>
    <name>name</name>
    <buildlist>
        <typelist/>
        <namespace/>
        <enumeration/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</namespace>



<enumeration display="Enumeration">
    <icon>:/icons/enumeration.svg</icon>
    <string id="name" default="space"/>
    <string id="description"/>
    <bool id="class"/>
    <name>name</name>
    <buildlist>
        <enumvalue/>
    </buildlist>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <checkboxes display="Properties:">
                <checkbox id="class" display="Class"/>
            </checkboxes>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
    </view>
</enumeration>



<enumvalue display="Enumeration Value">
    <icon>:/icons/enumvalue.svg</icon>
    <string id="name" default=""/>
    <string id="value"/>
    <name>name</name>
    <edit>
        <form>
            <line id="name" display="Name:"/>
            <text id="description" display="Description:"/>
            <line id="value" display="Value:"/>
        </form>
    </edit>
    <view>
        <h3>Description</h3>
        <ps id="description"/>
        <custom name="displayValue"/>
    </view>
</enumvalue>



</cppqt>
