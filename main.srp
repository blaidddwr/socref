                            <__p_name>__scanFunction_</__p_name>
                            <__p_description>Getter method.</__p_description>
                            <__p_returnsDescription>list
Code lines scanned from the given input file, assuming it is at the beginning of a function definition. It stops scanning lines when the final enclosing bracket is found. The line with the last ending bracket is not included with the returned lines.</__p_returnsDescription>
                            <__p_static>0</__p_static>
                            <__p_class>0</__p_class>
                            <__p_abstract>0</__p_abstract>
                            <Object>
                                <__p_name>ifile</__p_name>
                                <__p_description>io.TextIOWrapper
The input file positioned at the beginning of a function definition whose lines of code are scanned and returned.</__p_description>
                            </Object>
                        </Function>
