                        <Class>
                            <__p_name>SpellChecker</__p_name>
                            <__p_description>This is the spell checker class. It provides a spell checking and correction interface using the Hunspell library. It begins spell checking with its start slot, providing it a Qt text cursor that is used to parse the entire document of the text cursor, checking for misspelled words. Each misspelled word is highlighted and waits on the user to correct. The user is given options to use a suggestion, replace, ignore, or stop. The cursor is updated to highlight each misspelled word found while waiting for the user to make a choice about it.</__p_description>
                            <__p_parents>QGroupBox</__p_parents>
                            <__p_infile>0</__p_infile>
                            <Object>
                                <__p_name>cursorChanged</__p_name>
                                <__p_description>Signals this spell checker has changed the cursor given to it.</__p_description>
                                <__p_assignment>Signal(QTextCursor)</__p_assignment>
                            </Object>
                            <Object>
                                <__p_name>finished</__p_name>
                                <__p_description>Signals this spell checker has finished checking and correcting for misspelled words.</__p_description>
                                <__p_assignment>Signal()</__p_assignment>
                            </Object>
