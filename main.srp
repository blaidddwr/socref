                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
                                <Object>
                                    <__p_name>parent</__p_name>
                                    <__p_description>QObject
The optional Qt object parent.</__p_description>
                                    <__p_assignment>None</__p_assignment>
                                </Object>
                            </Function>
                            <Function>
                                <__p_name>setView</__p_name>
                                <__p_description>Sets this dock's project view to the one given. The given project view is not made the Qt child of this dock. If this dock currently has a view then it is unset from this dock.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
                                <Object>
                                    <__p_name>view</__p_name>
                                    <__p_description>ProjectView
The project view.</__p_description>
                                </Object>
                            </Function>
