                                <__p_name>__init__</__p_name>
                                <__p_description>Initialize this new command base instance with the given project model.</__p_description>
                                <__p_static>0</__p_static>
                                <__p_class>0</__p_class>
                                <__p_abstract>0</__p_abstract>
